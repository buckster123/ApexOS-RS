// Shared struct definitions — exported for Rust and all components.

// System stats polled from agentd /api/run + sensor_reading WS events.
export struct SysStats {
    cpu-pct:      float,   // 0–100  (load avg / nproc * 100, capped)
    ram-pct:      float,   // 0–100
    disk-pct:     float,   // 0–100
    iaq-score:    float,   // IAQ index 0–500 (BSEC2 scale)
    iaq-label:    string,  // "Good" | "Moderate" | "Unhealthy" | "Hazardous" | "—"
    temp-c:       float,   // ambient temperature °C from BME688
    humidity-pct: float,   // relative humidity % from BME688
    online:       bool,    // true once first successful poll
    // Thermal camera (MLX90640) — populated by thermal_frame sensor_reading events
    thermal-min-c:  float,
    thermal-max-c:  float,
    thermal-mean-c: float,
    thermal-active: bool,
}

export struct SessionItem {
    session-id:    int,
    time-ago:      string,   // "2 min ago", "3 hr ago", etc.
    message-count: int,
    preview:       string,   // first 80 chars of first user message
}

export struct MessageItem {
    role: string,             // "user" | "agent" | "tool"
    text: string,
    streaming: bool,

    // Tool-card fields (only used when role == "tool")
    call-id: string,          // matches tool_requested / tool_result call_id
    tool-name: string,        // e.g. "read_file", "run_command"
    tool-args: string,        // JSON args, shown collapsed
    tool-output: string,      // populated on tool_result
    tool-status: string,      // "running" | "done" | "error"
    awaiting-approval: bool,  // true while approval_pending, false after
}
