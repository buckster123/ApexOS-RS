// Shared struct definitions — exported for Rust and all components.

// ── Shell ───────────────────────────────────────────────────────────────
// The shell has two modes (glowup G1). Desktop = windowed face (wallpaper +
// dock + app windows); Focus = a single full-screen app (the appliance face).
// Runtime-switchable; tier-clamped by Rust (Nano defaults to Focus).
export enum ShellMode { desktop, focus }

// ── Window manager (glowup G2) ──────────────────────────────────────────
// Every app is a window. Rust owns the set (which windows exist, z-order =
// model order with the last element on top); Slint owns live-drag geometry
// for smoothness and commits back to Rust on release.
export enum AppKind { chat, system, sensor, sessions, settings, terminal, council, event-log, mesh, inference, audio-editor, sonus, notes, face, sketchpad, web, calculator, explorer, occipital }

// ── Persona system (glowup G4) ───────────────────────────────────────────
// A persona is a named bundle: theme + chrome + wallpaper + default shell mode
// (+ behaviour, G5). Resolution lives in Rust (apply_persona); the Personas
// global derives the live structural bits Slint components read. Ordinals MUST
// match the Rust Persona<->ordinal mapping: 0 apex, 1 mom, 2 ubuntu-dad,
// 3 windows-dad, 4 tech-kid, 5 aurum.
export enum Persona { apex, mom, ubuntu-dad, windows-dad, tech-kid, aurum }

// Structural caption-bar variant. G4 implements `mac` (traffic-lights, centred
// title) vs the right-buttons family (apex/adwaita/win/hud differ by glyph +
// accent only); full Win-98 bevel fidelity is G6.
export enum ChromeKind { apex, mac, adwaita, win, hud }

// One entry in the persona catalogue (first-boot wizard + picker tiles). Built
// once by Rust; both surfaces iterate it. `id` is the Persona ordinal.
export struct PersonaDef {
    id:        int,
    name:      string,   // "Apex"
    title:     string,   // "Developer"
    tagline:   string,   // one-line "who's this for"
    glyph:     string,   // emoji / icon
    swatch:    color,    // accent preview
    swatch-bg: color,    // tile background preview
}

// ── Identity boot wizard (agent-identity.md slice 3d) ────────────────────
// A user profile and an agent, surfaced as tiles in the boot wizard. Rust owns
// both VecModels (from GET /api/identities); the wizard filters agents to the
// selected user's owner before showing the agent step.
export struct UserDef {
    id:      string,
    name:    string,
    has-pin: bool,
    glyph:   string,   // emoji/initial preview
}

export struct AgentDef {
    id:      string,
    name:    string,
    glyph:   string,
}

// ── Council (glowup G3d) ─────────────────────────────────────────────────
// One deliberating agent in a council session. Rust owns the VecModel: delta
// events append to `text`, agent_done sets `done`. `accent` is parsed from the
// CouncilAgentDef hex colour (or a rotating default) by Rust.
export struct CouncilAgent {
    id:      string,
    persona: string,
    accent:  color,
    text:    string,
    done:    bool,
}

export struct WindowDesc {
    id:        int,        // stable identity assigned by Rust
    kind:      AppKind,
    title:     string,
    x:         length,
    y:         length,
    w:         length,
    h:         length,
    minimized: bool,
    maximized: bool,
}

// ── AgentBridge global ──────────────────────────────────────────────────
// Decouples chat tool-approval + scroll from the AppWindow element tree so
// ChatView can be instantiated freely (Focus surface AND a Desktop window)
// without the single-instance callback-alias constraint. Rust wires the
// callbacks once; any ChatView instance calls them. Rust bumps
// chat-scroll-tick to request an auto-scroll-to-bottom.
export global AgentBridge {
    callback approve-tool(string);   // call_id
    callback reject-tool(string);    // call_id
    in property <int> chat-scroll-tick: 0;
}

// ── FaceGl global (Phase-2 GL face) ─────────────────────────────────────
// Bridges the FaceView's live on-window rect to Rust's rendering-notifier GL
// pass, so the shader face can be scissored to the (movable, resizable) face
// window instead of painting the whole surface. FaceView writes its face-stage
// absolute-position + size here (logical px, window coords) from a sampling
// Timer; Rust reads them in the AfterRendering notifier, converts to
// physical px (× scale-factor, Y-flipped for GL's bottom-left origin) and sets
// glViewport + glScissor. "Is the face window open?" gating stays in Rust (it
// owns the windows model) — Slint has no element-destroyed hook to clear this.
export global FaceGl {
    in-out property <bool>   active;  // Rust sets true only on the GL face path
    in-out property <length> x;       // face-stage left,  window coords (logical px)
    in-out property <length> y;       // face-stage top,   window coords (logical px)
    in-out property <length> w;       // face-stage width
    in-out property <length> h;       // face-stage height

    // ── Expression (slice 2) ────────────────────────────────────────────
    // Mirrors FaceView's 2D state→feature derivations so the GL shader and the
    // 2D fallback render from one source and can't drift. FaceView publishes
    // these from the same sample Timer; Rust forwards them to shader uniforms.
    in-out property <color>  accent;       // per-state head tint (carries the read)
    in-out property <float>  eye-l;        // left-eye  openness 0..1 (incl. blink/wink)
    in-out property <float>  eye-r;        // right-eye openness 0..1 (incl. blink/skeptical)
    in-out property <float>  brow;         // symmetric brow raise (+up / −down)
    in-out property <float>  brow-skew;    // L/R brow asymmetry (confused/skeptical)
    in-out property <float>  brow-angle;   // inner-end tilt (+up = worried, −down = angry)
    in-out property <float>  mouth;        // mouth curve −1..1 (smile ↔ frown)
    in-out property <float>  mouth-open;   // open-mouth amount 0..1 (0 = stroked curve)
    in-out property <float>  gaze-x;       // gaze offset fraction (−left / +right)
    in-out property <float>  gaze-y;       // gaze offset fraction (−up / +down)
    in-out property <float>  intensity;    // expression strength 0..1
    in-out property <float>  blush;        // warm-cheek amount 0..1 (love/happy/proud)
    // ── Motion / life (GL only) ─────────────────────────────────────────
    in-out property <float>  talk;         // 1 = speaking → animated mouth-flap
    in-out property <float>  head-roll;    // head tilt/cock (curious/confused/amused)
    in-out property <float>  head-pitch;   // chin lift (+proud) / drop (−sad)
    in-out property <float>  tear;         // 1 = a sliding teardrop (sad)
    in-out property <float>  cheek;        // cheek-raise / lower-lid squint (Duchenne, focus)
}

// ── Clock global (glowup G6.1) ──────────────────────────────────────────
// A Rust timer (chrono Local) ticks `time`/`date` every second on the Slint
// thread. Drives the taskbar tray clock and gives the desktop a temporal
// anchor. Chat time-dividers are pushed as role="time" MessageItems (the label
// rides in `text`) — interval markers, not a per-message field.
export global Clock {
    in property <string> time: "";   // "20:36"
    in property <string> date: "";   // "Thu 12 Jun"
}

// System stats polled from agentd /api/run + sensor_reading WS events.
export struct SysStats {
    cpu-pct:      float,   // 0–100  (load avg / nproc * 100, capped)
    ram-pct:      float,   // 0–100
    disk-pct:     float,   // 0–100
    iaq-score:    float,   // IAQ index 0–500 (BSEC2 scale)
    iaq-label:    string,  // "Good" | "Moderate" | "Unhealthy" | "Hazardous" | "—"
    temp-c:       float,   // ambient temperature °C from BME688
    humidity-pct: float,   // relative humidity % from BME688
    online:       bool,    // true once first successful poll
    // Thermal camera (MLX90640) — populated by thermal_frame sensor_reading events
    thermal-min-c:  float,
    thermal-max-c:  float,
    thermal-mean-c: float,
    thermal-active: bool,
}

export struct ModelItem {
    model-id:   string,   // e.g. "claude-sonnet-4-6"
    model-name: string,   // e.g. "Sonnet 4.6"
}

// Tokenomics / cache-bank readout for the ⚡ Inference view. Rust formats every
// field into a display string from GET /api/usage (cumulative since daemon boot).
export struct Usage {
    turns:    string,   // "142"
    hit-rate: string,   // "98.2%"  — share of input served from cache
    banked:   string,   // "2.5M"   — net tokens kept off the bill (the cache bank)
    saved:    string,   // "$7.95"  — vs the no-cache baseline (current model price)
    spent:    string,   // "$1.79"
    detail:   string,   // "2.77M cached · 31K fresh · 84K out"
    model:    string,   // "claude-sonnet-4-6" (the price basis)
}

// ── Feedback subsystem ──────────────────────────────────────────────────
// Transient toast notifications. Severity drives accent colour + icon.
export enum ToastKind { info, success, warn, error }

export struct ToastItem {
    id:         int,     // monotonic, assigned by Rust; used for dismiss()
    kind:       ToastKind,
    text:       string,
    timeout-ms: int,     // auto-dismiss after this many ms; 0 = sticky
}

export struct SessionItem {
    session-id:    int,
    time-ago:      string,   // "2 min ago", "3 hr ago", etc.
    message-count: int,
    preview:       string,   // first 80 chars of first user message
}

// ── App-parity Tier A: read/light-action viewers over existing agentd routes ──

// One row in the Event Log app (📜) — a filtered entry from /api/events/recent.
export struct EventLogItem {
    ev-type: string,   // raw Event "type" (e.g. "tool_requested", "wake_triggered")
    summary: string,   // one-line detail derived from the event's notable fields
    accent:  color,    // severity/category tint
}

// One node in the Mesh app (🕸). `is-peer` true = saved peer (peers.toml);
// false = an mDNS-discovered node not yet added. /api/mesh/{peers,nodes}.
export struct MeshNode {
    node-id:   string,
    detail:    string,   // ws_url (peer) or "ip:port" (discovered)
    role:      string,   // "full" | "sensor" | "thin" | "—"
    status:    string,   // "online" | "discovered" | …
    is-peer:   bool,
    has-token: bool,     // saved peer carries an a2a token (GET /api/mesh/peers has_token)
}

// One audio file in the Audio Editor (🎛️) list. /api/audio/files.
export struct AudioFileItem {
    path:       string,
    name:       string,
    size-label: string,   // "3.2 MB"
}

// One track in the Sonus player (🎵). /api/sonus/files.
export struct SonusFileItem {
    name:       string,
    size-label: string,   // "3.2 MB"
}

// One note in the Notes app (📝). /api/notes — markdown files shared with APEX.
export struct NoteItem {
    name:       string,   // "ideas.md"
    size-label: string,   // "1.2 KB"
}

// One workspace image in the chat-composer attach picker (🖼). /api/workspace/images.
// `path` is workspace-relative (sent as user_prompt images:[{path}]); `name` shows.
export struct ImageItem {
    path: string,
    name: string,
}

// One entry in the Explorer (📁) — a dir or file under the workspace.
// /api/workspace/list. `path` is workspace-relative (navigate dirs / preview
// files); `abs` is the absolute path (co-located UI loads image previews from it).
export struct ExplorerEntry {
    name:       string,
    kind:       string,   // "dir" | "file"
    size-label: string,   // "1.2 KB" (files) / "" (dirs)
    ext:        string,   // lowercased, no dot ("png", "md", …)
    path:       string,
    abs:        string,
    glyph:      string,   // icon (Rust maps dir/ext → emoji)
}

// One drawn stroke in the Sketchpad (🎨). Rust owns the points; `commands` is
// an SVG path string in canvas-pixel coords (rendered by a Path with a viewbox
// matching the canvas). The same strokes are posted to /api/sketch for APEX.
export struct SketchStroke {
    commands: string,
    color:    color,
    width:    float,    // logical px; bound as stroke-width: width * 1px
}

// ── Occipital follow-along reader (Phase 9) ──────────────────────────────
// The agent's "reading cortex" window. Rust parses each web_fetch/web_search/
// web_recall tool result (flat, `kind`-discriminated — see Occipital's
// docs/follow-along.md) into these and the window mirrors what the agent reads.

// One rendered block of a reader-mode page. Rust parses the page markdown into
// a flat list; the view styles by `kind`.
export struct ReaderBlock {
    kind:  string,   // "h1"|"h2"|"h3"|"p"|"code"|"bullet"|"quote"|"rule"
    text:  string,
    depth: int,      // bullet nesting (0-based)
}

// One interactive row: a page link, a search result, or a recall hit. Clicking
// it steers the agent ("go here" — 9c). Rust fills per mode; the view shows
// whatever is non-empty.
export struct ReaderLink {
    label:  string,   // link text / result title / hit title (fallback: url)
    url:    string,
    detail: string,   // snippet (results/recall) — "" for page links
    badge:  string,   // "#1" (search rank) / "0.82" (recall score) / ""
}

export struct MessageItem {
    role: string,             // "user" | "agent" | "tool"
    text: string,
    streaming: bool,

    // Tool-card fields (only used when role == "tool")
    call-id: string,          // matches tool_requested / tool_result call_id
    tool-name: string,        // e.g. "read_file", "run_command"
    tool-args: string,        // JSON args, shown collapsed
    tool-output: string,      // populated on tool_result
    tool-status: string,      // "running" | "done" | "error"
    awaiting-approval: bool,  // true while approval_pending, false after
}
