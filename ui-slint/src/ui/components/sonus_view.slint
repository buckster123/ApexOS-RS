import { Palette } from "../palette.slint";
import { SonusFileItem } from "../types.slint";

// ── SonusView (🎵) ─────────────────────────────────────────────────────────────
//
// The music library: tracks generated by the Sonus MCP land in
// /var/lib/agentd/workspace/sonus. List them (/api/sonus/files), and play on
// the device's own speakers via agentd→ffplay (/api/sonus/play, /api/sonus/stop).
// The "now playing" row is highlighted; a footer bar shows transport + stop.
//
// preferred/min height 0 so the parent VerticalLayout sizes us via stretch.

export component SonusView {
    preferred-height: 0px;
    min-height: 0px;

    in property <[SonusFileItem]> files;
    in property <string>         now-playing;   // name of the track currently playing ("" = none)

    callback refresh();
    callback play(string);   // name
    callback stop();

    VerticalLayout {
        // ── Header ────────────────────────────────────────────────────────
        Rectangle {
            height: 48px;
            background: Palette.surface;

            HorizontalLayout {
                padding-left: 20px;
                padding-right: 14px;

                Text {
                    text: "SONUS";
                    color: Palette.text-dim;
                    font-size: 9px;
                    letter-spacing: 2px;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                Rectangle {
                    width: 72px;
                    height: 28px;
                    border-radius: Palette.radius;
                    background: Palette.surface-hi;
                    border-width: 1px;
                    border-color: Palette.border;
                    y: (parent.height - self.height) / 2;

                    TouchArea { clicked => { root.refresh(); } }

                    Text {
                        text: "REFRESH";
                        color: Palette.text-dim;
                        font-size: 9px;
                        letter-spacing: 1px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        Rectangle { height: 1px; background: Palette.border; }

        // ── Track list ──────────────────────────────────────────────────────
        Flickable {
            vertical-stretch: 1;
            interactive: true;
            viewport-height: track-col.preferred-height;

            track-col := VerticalLayout {
                padding: 12px;
                spacing: 6px;
                alignment: start;

                if root.files.length == 0: Text {
                    text: "No tracks yet. Generate music with APEX, then REFRESH.";
                    color: Palette.text-dim;
                    font-size: 13px;
                    horizontal-alignment: center;
                }

                for f in root.files: Rectangle {
                    height: 48px;
                    border-radius: Palette.radius;
                    background: f.name == root.now-playing ? Palette.surface-hi : Palette.surface;
                    border-width: 1px;
                    border-color: f.name == root.now-playing ? Palette.primary : Palette.border;
                    animate border-color { duration: 200ms; }

                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 10px;
                        spacing: 12px;

                        // Play / playing indicator
                        Rectangle {
                            width: 34px;
                            height: 34px;
                            border-radius: 17px;
                            background: play-ta.has-hover ? Palette.primary-dim : transparent;
                            border-width: 1px;
                            border-color: f.name == root.now-playing ? Palette.primary : Palette.border;
                            y: (parent.height - self.height) / 2;
                            animate background { duration: 150ms; }

                            play-ta := TouchArea { clicked => { root.play(f.name); } }

                            Text {
                                text: f.name == root.now-playing ? "♪" : "▶";
                                color: Palette.primary;
                                font-size: 13px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        VerticalLayout {
                            spacing: 3px;
                            alignment: center;
                            horizontal-stretch: 1;

                            Text {
                                text: f.name;
                                color: f.name == root.now-playing ? Palette.text-bright : Palette.text;
                                font-size: 12px;
                                font-weight: f.name == root.now-playing ? 700 : 400;
                                overflow: elide;
                            }
                            Text {
                                text: f.size-label;
                                color: Palette.text-dim;
                                font-size: 10px;
                            }
                        }
                    }
                }
            }
        }

        // ── Transport footer ──────────────────────────────────────────────────
        Rectangle {
            height: 44px;
            background: Palette.surface;
            Rectangle { y: 0px; height: 1px; background: Palette.border; }

            HorizontalLayout {
                padding-left: 16px;
                padding-right: 12px;
                spacing: 12px;

                Text {
                    text: root.now-playing == "" ? "— idle —" : "♪ " + root.now-playing;
                    color: root.now-playing == "" ? Palette.text-dim : Palette.primary;
                    font-size: 11px;
                    overflow: elide;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                Rectangle {
                    width: 64px;
                    height: 28px;
                    border-radius: Palette.radius;
                    background: stop-ta.has-hover ? rgba(239,68,68,0.2) : Palette.surface-hi;
                    border-width: 1px;
                    border-color: rgba(239,68,68,0.5);
                    y: (parent.height - self.height) / 2;
                    animate background { duration: 150ms; }

                    stop-ta := TouchArea { clicked => { root.stop(); } }

                    Text {
                        text: "■ STOP";
                        color: #ef4444;
                        font-size: 10px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}
