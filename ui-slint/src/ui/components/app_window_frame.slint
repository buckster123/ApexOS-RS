// AppWindowFrame (glowup G2) — a draggable / resizable / focusable window
// frame that hosts any app by `kind`. Chrome = caption bar (title + minimise /
// maximise / close) over a clipped content area.
//
// Geometry model: Rust owns base x/y/w/h (the WindowDesc row); the frame keeps
// LOCAL drag/resize deltas for smooth pointer tracking and commits them to Rust
// on release. Focus (raise-to-front) also fires on release — deliberately, not
// on press: raising reorders the Rust model, and a `for` repeater keys by index,
// so reordering mid-drag would reassign this instance to another window's data.
// Releasing first means no pointer capture is active when the reorder happens.

import { Palette } from "../palette.slint";
import { Personas } from "../personas.slint";
import { Win98, BevelEdges, Win98Button } from "win98.slint";
import { MessageItem, SysStats, SessionItem, ModelItem, AppKind, CouncilAgent, ChromeKind, EventLogItem, MeshNode, AudioFileItem, SonusFileItem, NoteItem, SketchStroke } from "../types.slint";
import { ChatView } from "chat_view.slint";
import { InputBar } from "input_bar.slint";
import { Dashboard } from "dashboard.slint";
import { SensorView } from "sensor_view.slint";
import { SessionView } from "session_view.slint";
import { SettingsView } from "settings_view.slint";
import { TerminalView } from "terminal_view.slint";
import { CouncilView } from "council_view.slint";
import { EventLogView } from "event_log_view.slint";
import { MeshView } from "mesh_view.slint";
import { InferenceView } from "inference_view.slint";
import { AudioEditorView } from "audio_editor_view.slint";
import { SonusView } from "sonus_view.slint";
import { NotesView } from "notes_view.slint";
import { FaceView } from "face_view.slint";
import { SketchpadView } from "sketchpad_view.slint";

component CaptionButton inherits Rectangle {
    in property <string> glyph;
    in property <color> hover-bg: Palette.surface-hi;
    in property <color> glyph-color: Palette.text-dim;
    callback clicked;
    width: 26px;
    height: 22px;
    border-radius: Palette.radius-sm;
    background: touch.has-hover ? root.hover-bg : transparent;
    animate background { duration: 120ms; }
    touch := TouchArea { clicked => { root.clicked(); } }
    Text {
        text: root.glyph;
        color: root.glyph-color;
        font-size: 13px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

// macOS traffic-light dot (close / minimise / maximise). Coloured circle that
// reveals its glyph on hover of the cluster.
component MacDot inherits Rectangle {
    in property <color> dot;
    in property <string> glyph;
    callback clicked;
    width: 12px;
    height: 12px;
    border-radius: 6px;
    background: root.dot;
    dot-ta := TouchArea { clicked => { root.clicked(); } }
    Text {
        text: dot-ta.has-hover ? root.glyph : "";
        color: #00000099;
        font-size: 9px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

export component AppWindowFrame inherits Rectangle {
    // ── Window identity / geometry (from the Rust WindowDesc) ────────────
    in property <int>     win-id;
    in property <AppKind> kind;
    in property <string>  title;
    in property <length>  base-x;
    in property <length>  base-y;
    in property <length>  base-w;
    in property <length>  base-h;
    in property <bool>    maximized;
    in property <bool>    focused;
    in property <length>  area-w;      // desktop area, for maximise + clamping
    in property <length>  area-h;

    // ── App data (pass-through; only the active kind reads its slice) ────
    in property <[MessageItem]>  messages;
    in property <bool>           agent-busy;
    in property <float>          glow-alpha;
    in property <bool>           recording;
    in property <int>            scroll-tick;
    in property <SysStats>       stats;
    in property <[SessionItem]>  sessions;
    in property <int>            active-session-id;
    in property <string>         soul-text;
    in property <string>         policy-mode;
    in property <string>         current-model;
    in property <bool>           api-key-set;
    in property <[ModelItem]>    models;
    in property <string>         terminal-text;
    in property <int>            terminal-scroll-tick;
    in property <[CouncilAgent]> council-agents;
    in property <string>         council-topic;
    in property <int>            council-round;
    in property <float>          council-convergence;
    in property <bool>           council-active;
    in property <string>         council-status;
    in property <string>         council-synthesis;
    in property <int>            council-scroll-tick;
    // Tier-A parity apps (Event Log / Mesh / Inference).
    in property <[EventLogItem]> event-log;
    in property <[MeshNode]>     mesh-nodes;
    in property <string>         inference-backend;
    in property <string>         inference-base-url;
    in property <[ModelItem]>    inference-models;
    in property <[AudioFileItem]> audio-files;
    in property <string>         audio-selected-path;
    in property <string>         audio-selected-name;
    in property <[float]>        audio-waveform;
    in property <string>         audio-stats;
    in property <string>         audio-duration;
    in property <bool>           audio-busy;
    in property <[SonusFileItem]> sonus-files;
    in property <string>         sonus-now-playing;
    in property <[NoteItem]>     notes;
    in-out property <string>     notes-current-name;
    in-out property <string>     notes-current-text;
    in property <string>         face-state;
    in property <int>            face-tick;
    in property <[SketchStroke]> sketch-strokes;
    in property <int>            sketch-color;
    in property <int>            sketch-width;

    // ── App callbacks (forwarded to root AppWindow) ─────────────────────
    callback send-message(string);
    callback toggle-recording();
    callback stop-turn();
    callback restore-session(int);
    callback refresh-sessions();
    callback save-soul(string);
    callback set-policy(string);
    callback set-model(string);
    callback refresh-settings();
    callback terminal-send(string);
    // Tier-A parity apps.
    callback refresh-events();
    callback refresh-mesh();
    callback add-peer(string, string);   // node_id, ws_url
    callback remove-peer(string);        // node_id
    callback refresh-inference();
    callback refresh-audio();
    callback select-audio(string, string);   // path, name
    callback process-audio(string, string);  // path, op
    callback refresh-sonus();
    callback play-sonus(string);              // name
    callback stop-sonus();
    callback refresh-notes();
    callback open-note(string);               // name
    callback save-note(string, string);       // name, text
    callback create-note(string);             // new note name
    callback sketch-down(float, float);
    callback sketch-move(float, float);
    callback sketch-up();
    callback sketch-clear();
    callback sketch-send(float, float);       // canvas px w, h
    callback sketch-set-color(int);
    callback sketch-set-width(int);
    // set-model is shared with Settings (declared above).

    // ── Window-management callbacks ─────────────────────────────────────
    callback req-focus();
    callback req-close();
    callback req-minimize();
    callback req-maximize();
    callback commit-move(length, length);     // new x, y
    callback commit-resize(length, length);   // new w, h

    // ── Local drag / resize deltas ──────────────────────────────────────
    property <length> dx: 0;
    property <length> dy: 0;
    property <length> dw: 0;
    property <length> dh: 0;
    property <length> press-ax;
    property <length> press-ay;
    property <length> orig-a;
    property <length> orig-b;

    property <length> min-w: 220px;
    property <length> min-h: 140px;

    // Win-98 chrome: grey beveled frame instead of the rounded dark card.
    property <bool> win98: Personas.chrome == ChromeKind.win;

    x:      root.maximized ? 0px       : root.base-x + root.dx;
    y:      root.maximized ? 0px       : root.base-y + root.dy;
    width:  root.maximized ? root.area-w : root.base-w + root.dw;
    height: root.maximized ? root.area-h : root.base-h + root.dh;

    background: root.win98 ? Win98.face : Palette.bg;
    border-radius: root.win98 ? 0px : (root.maximized ? 0px : Palette.radius-lg);
    border-width: root.win98 ? 0px : 1px;
    border-color: root.focused ? Palette.border-hi : Palette.border;
    clip: true;
    drop-shadow-blur: root.win98 ? 8px : (root.focused ? 36px : 18px);
    drop-shadow-color: root.win98 ? #00000066 : (root.focused ? #000000aa : #00000066);
    drop-shadow-offset-y: root.win98 ? 3px : 8px;

    VerticalLayout {
        padding: root.win98 ? 3px : 0px;

        // ── Caption bar (drag handle) ───────────────────────────────────
        Rectangle {
            height: root.win98 ? 22px : 30px;
            background: root.win98
                ? (root.focused
                    ? @linear-gradient(90deg, Win98.title-1 0%, Win98.title-2 100%)
                    : @linear-gradient(90deg, Win98.title-off-1 0%, Win98.title-off-2 100%))
                : (root.focused ? Palette.surface-hi : Palette.surface);
            animate background { duration: 150ms; }

            // Modern chrome under-line; the Win-98 navy bar runs edge-to-edge.
            if !root.win98: Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: Palette.border;
            }

            caption-ta := TouchArea {
                mouse-cursor: move;
                pointer-event(ev) => {
                    if (ev.kind == PointerEventKind.down && !root.maximized) {
                        root.orig-a = root.dx;
                        root.orig-b = root.dy;
                        root.press-ax = self.absolute-position.x + self.mouse-x;
                        root.press-ay = self.absolute-position.y + self.mouse-y;
                    }
                    if (ev.kind == PointerEventKind.up) {
                        if (!root.maximized) {
                            root.commit-move(root.base-x + root.dx, root.base-y + root.dy);
                            root.dx = 0;
                            root.dy = 0;
                        }
                        root.req-focus();   // raise on release (see header note)
                    }
                }
                moved => {
                    if (!root.maximized) {
                        root.dx = root.orig-a + (self.absolute-position.x + self.mouse-x - root.press-ax);
                        root.dy = root.orig-b + (self.absolute-position.y + self.mouse-y - root.press-ay);
                    }
                }
            }

            // ── macOS chrome: traffic-lights left, title centred ─────────
            if Personas.chrome == ChromeKind.mac: Rectangle {
                // Centred title (pointer events pass through to the drag area).
                Text {
                    text: root.title;
                    color: Palette.text-bright;
                    font-size: 11px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                // Traffic-lights left; each dot reveals its glyph on its own
                // hover. Dragging works from anywhere on the bar but the dots.
                HorizontalLayout {
                    padding-left: 12px;
                    spacing: 8px;
                    alignment: start;
                    MacDot {
                        dot: #ff5f57; glyph: "✕";
                        clicked => { root.req-close(); }
                    }
                    MacDot {
                        dot: #febc2e; glyph: "—";
                        clicked => { root.req-minimize(); }
                    }
                    MacDot {
                        dot: #28c840; glyph: "+";
                        clicked => { root.req-maximize(); }
                    }
                    Rectangle { horizontal-stretch: 1; }
                }
            }

            // ── Right-buttons family (apex / adwaita / hud) ──────────────
            if Personas.chrome != ChromeKind.mac && Personas.chrome != ChromeKind.win: HorizontalLayout {
                padding-left: 12px;
                padding-right: 6px;
                spacing: 6px;

                Text {
                    text: root.title;
                    color: Palette.text-bright;
                    font-size: 11px;
                    font-weight: 700;
                    letter-spacing: Personas.chrome == ChromeKind.hud ? 1.5px : 0.5px;
                    vertical-alignment: center;
                }

                Rectangle { horizontal-stretch: 1; }

                CaptionButton {
                    glyph: Personas.chrome == ChromeKind.hud ? "⎯" : "—";
                    clicked => { root.req-minimize(); }
                }
                CaptionButton {
                    glyph: root.maximized ? "❐" : "▢";
                    clicked => { root.req-maximize(); }
                }
                CaptionButton {
                    glyph: "✕";
                    hover-bg: rgba(239, 68, 68, 0.25);
                    glyph-color: Palette.text-dim;
                    clicked => { root.req-close(); }
                }
            }

            // ── Win-98 caption: icon + white bold title + 3 beveled buttons.
            if Personas.chrome == ChromeKind.win: HorizontalLayout {
                padding-left: 3px;
                padding-right: 2px;
                padding-top: 2px;
                padding-bottom: 2px;
                spacing: 4px;

                // Window icon (persona glyph) on a tiny plate.
                Text {
                    text: Personas.glyph;
                    color: Win98.title-text;
                    font-size: 11px;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                    width: 16px;
                }
                Text {
                    text: root.title;
                    color: Win98.title-text;
                    font-size: 11px;
                    font-weight: 700;
                    vertical-alignment: center;
                    overflow: elide;
                }

                Rectangle { horizontal-stretch: 1; }

                Win98Button {
                    width: 18px;
                    glyph: "▁";
                    bold: true;
                    clicked => { root.req-minimize(); }
                }
                Win98Button {
                    width: 18px;
                    glyph: root.maximized ? "❐" : "❒";
                    clicked => { root.req-maximize(); }
                }
                Win98Button {
                    width: 18px;
                    glyph: "✕";
                    bold: true;
                    clicked => { root.req-close(); }
                }
            }
        }

        // ── Content area: app by kind ───────────────────────────────────
        if root.kind == AppKind.chat: VerticalLayout {
            ChatView {
                vertical-stretch: 1;
                messages: root.messages;
                glow-alpha: root.glow-alpha;
                scroll-tick: root.scroll-tick;
            }
            Rectangle {
                background: Palette.bg;
                HorizontalLayout {
                    padding: 12px;
                    InputBar {
                        busy: root.agent-busy;
                        glow-alpha: root.glow-alpha;
                        recording: root.recording;
                        toggle-recording => { root.toggle-recording(); }
                        send(text) => { root.send-message(text); }
                        stop => { root.stop-turn(); }
                    }
                }
            }
        }

        if root.kind == AppKind.system: Dashboard {
            vertical-stretch: 1;
            stats: root.stats;
            glow-alpha: root.glow-alpha;
        }

        if root.kind == AppKind.sensor: SensorView {
            vertical-stretch: 1;
            stats: root.stats;
        }

        if root.kind == AppKind.sessions: SessionView {
            vertical-stretch: 1;
            sessions: root.sessions;
            active-session-id: root.active-session-id;
            restore-session(id) => { root.restore-session(id); }
            refresh => { root.refresh-sessions(); }
        }

        if root.kind == AppKind.settings: SettingsView {
            vertical-stretch: 1;
            soul-text: root.soul-text;
            policy-mode: root.policy-mode;
            current-model: root.current-model;
            api-key-set: root.api-key-set;
            models: root.models;
            save-soul(text) => { root.save-soul(text); }
            set-policy(mode) => { root.set-policy(mode); }
            set-model(id) => { root.set-model(id); }
            refresh => { root.refresh-settings(); }
        }

        if root.kind == AppKind.terminal: TerminalView {
            vertical-stretch: 1;
            output: root.terminal-text;
            scroll-tick: root.terminal-scroll-tick;
            send(line) => { root.terminal-send(line); }
        }

        if root.kind == AppKind.council: CouncilView {
            vertical-stretch: 1;
            agents: root.council-agents;
            topic: root.council-topic;
            round: root.council-round;
            convergence: root.council-convergence;
            active: root.council-active;
            status: root.council-status;
            synthesis: root.council-synthesis;
            scroll-tick: root.council-scroll-tick;
        }

        if root.kind == AppKind.event-log: EventLogView {
            vertical-stretch: 1;
            events: root.event-log;
            refresh => { root.refresh-events(); }
        }

        if root.kind == AppKind.mesh: MeshView {
            vertical-stretch: 1;
            nodes: root.mesh-nodes;
            refresh => { root.refresh-mesh(); }
            add-peer(id, url) => { root.add-peer(id, url); }
            remove-peer(id) => { root.remove-peer(id); }
        }

        if root.kind == AppKind.inference: InferenceView {
            vertical-stretch: 1;
            backend: root.inference-backend;
            base-url: root.inference-base-url;
            models: root.inference-models;
            current-model: root.current-model;
            refresh => { root.refresh-inference(); }
            set-model(id) => { root.set-model(id); }
        }

        if root.kind == AppKind.audio-editor: AudioEditorView {
            vertical-stretch: 1;
            files: root.audio-files;
            selected-path: root.audio-selected-path;
            selected-name: root.audio-selected-name;
            waveform: root.audio-waveform;
            stats: root.audio-stats;
            duration: root.audio-duration;
            busy: root.audio-busy;
            refresh => { root.refresh-audio(); }
            select(p, n) => { root.select-audio(p, n); }
            process(p, op) => { root.process-audio(p, op); }
        }

        if root.kind == AppKind.sonus: SonusView {
            vertical-stretch: 1;
            files: root.sonus-files;
            now-playing: root.sonus-now-playing;
            refresh => { root.refresh-sonus(); }
            play(name) => { root.play-sonus(name); }
            stop => { root.stop-sonus(); }
        }

        if root.kind == AppKind.notes: NotesView {
            vertical-stretch: 1;
            notes: root.notes;
            current-name <=> root.notes-current-name;
            current-text <=> root.notes-current-text;
            refresh => { root.refresh-notes(); }
            open(name) => { root.open-note(name); }
            save(name, text) => { root.save-note(name, text); }
            create(name) => { root.create-note(name); }
        }

        if root.kind == AppKind.face: FaceView {
            vertical-stretch: 1;
            state: root.face-state;
            tick: root.face-tick;
        }

        if root.kind == AppKind.sketchpad: SketchpadView {
            vertical-stretch: 1;
            strokes: root.sketch-strokes;
            active-color: root.sketch-color;
            active-width: root.sketch-width;
            down(x, y) => { root.sketch-down(x, y); }
            move(x, y) => { root.sketch-move(x, y); }
            up => { root.sketch-up(); }
            clear => { root.sketch-clear(); }
            send(w, h) => { root.sketch-send(w, h); }
            set-color(i) => { root.sketch-set-color(i); }
            set-width(i) => { root.sketch-set-width(i); }
        }
    }

    // ── Win-98 raised frame bevel (overlays the whole window edge) ───────
    if root.win98 && !root.maximized: BevelEdges { }

    // ── Resize grip (bottom-right) ──────────────────────────────────────
    if !root.maximized: Rectangle {
        width: 16px;
        height: 16px;
        x: parent.width - self.width;
        y: parent.height - self.height;

        resize-ta := TouchArea {
            mouse-cursor: nwse-resize;
            pointer-event(ev) => {
                if (ev.kind == PointerEventKind.down) {
                    root.orig-a = root.dw;
                    root.orig-b = root.dh;
                    root.press-ax = self.absolute-position.x + self.mouse-x;
                    root.press-ay = self.absolute-position.y + self.mouse-y;
                }
                if (ev.kind == PointerEventKind.up) {
                    root.commit-resize(root.base-w + root.dw, root.base-h + root.dh);
                    root.dw = 0;
                    root.dh = 0;
                    root.req-focus();
                }
            }
            moved => {
                root.dw = max(root.min-w - root.base-w,
                              root.orig-a + (self.absolute-position.x + self.mouse-x - root.press-ax));
                root.dh = max(root.min-h - root.base-h,
                              root.orig-b + (self.absolute-position.y + self.mouse-y - root.press-ay));
            }
        }

        // little corner hatch (two dots)
        Rectangle {
            x: 10px; y: 10px; width: 2px; height: 2px;
            background: Palette.text-dim;
        }
        Rectangle {
            x: 10px; y: 6px; width: 2px; height: 2px;
            background: Palette.text-dim;
        }
        Rectangle {
            x: 6px; y: 10px; width: 2px; height: 2px;
            background: Palette.text-dim;
        }
    }
}
