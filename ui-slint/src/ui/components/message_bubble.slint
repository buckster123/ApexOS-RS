import { Palette, Theme } from "../palette.slint";
import { Personas } from "../personas.slint";

// Single chat message bubble.
// User messages: right-aligned, primary-tinted.
// Agent messages: left-aligned, surface-tinted.
// Streaming: shows a blinking block cursor.
// Jarvis: agent bubble border glows with pulse passed from AppWindow.

export component MessageBubble {
    in property <string> role;
    in property <string> text;
    in property <bool>   streaming: false;
    in property <float>  glow-alpha: 0.0;   // 0–1, driven by AppWindow Timer
    // Max bubble width, passed down from ChatView (which knows the row width
    // top-down). Driving it from root.width here would form a binding loop.
    in property <length> max-bubble-width: 600px;

    property <bool> is-user: root.role == "user";

    // Pack the bubble to its side and let it hug its content (capped at ~78% of
    // the row), instead of stretching full width — the classic user-right /
    // agent-left chat layout. `alignment` makes the child take its preferred
    // width; `max-width` bounds long messages so the Text wraps.
    HorizontalLayout {
        alignment: root.is-user ? end : start;
        padding-top:   3px;
        padding-bottom: 3px;

        Rectangle {
            max-width: root.max-bubble-width;
            background: root.is-user ? Palette.user-bubble : Palette.agent-bubble;
            border-radius: Palette.radius-lg;
            border-width: 1px;
            border-color: root.is-user
                ? Palette.border
                : (Palette.scanlines && root.streaming
                    ? rgba(0, 212, 255, root.glow-alpha * 0.7 + 0.15)
                    : Palette.border);
            drop-shadow-blur:   Palette.scanlines && root.streaming ? 8px : 0px;
            drop-shadow-color:  rgba(0, 212, 255, root.glow-alpha * 0.5);
            drop-shadow-offset-y: 0px;

            VerticalLayout {
                padding-top:    10px;
                padding-bottom: 10px;
                padding-left:   14px;
                padding-right:  14px;

                Text {
                    text: root.text + (root.streaming ? "▊" : "");
                    color: root.is-user
                        ? Palette.user-bubble-text
                        : Palette.agent-bubble-text;
                    // G5: persona base-size scaling (mom reads larger).
                    font-size: 13px * Personas.font-scale;
                    wrap: word-wrap;
                }
            }
        }
    }
}
