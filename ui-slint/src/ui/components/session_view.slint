import { ScrollView } from "std-widgets.slint";
import { Palette } from "../palette.slint";
import { SessionItem } from "../types.slint";

// ── SessionView ────────────────────────────────────────────────────────────────
//
// Scrollable list of past sessions. Tapping a row restores it (replays history
// via the hello/resume_session WS frame). Active session highlighted in primary.
//
// preferred-height / min-height declared at 0 so parent VerticalLayout does not
// derive its layoutinfo from our content — we fill via vertical-stretch.

export component SessionView {
    preferred-height: 0px;
    min-height: 0px;

    in property <[SessionItem]> sessions;
    in property <int>           active-session-id: 0;

    callback restore-session(int);
    callback refresh();

    VerticalLayout {
        // ── Header ────────────────────────────────────────────────────────
        Rectangle {
            height: 48px;
            background: Palette.surface;

            HorizontalLayout {
                padding-left: 20px;
                padding-right: 14px;

                Text {
                    text: "SESSIONS";
                    color: Palette.text-dim;
                    font-size: 9px;
                    letter-spacing: 2px;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                // Refresh button
                Rectangle {
                    width: 72px;
                    height: 28px;
                    border-radius: Palette.radius;
                    background: Palette.surface-hi;
                    border-width: 1px;
                    border-color: Palette.border;
                    y: (parent.height - self.height) / 2;

                    TouchArea { clicked => { root.refresh(); } }

                    Text {
                        text: "REFRESH";
                        color: Palette.text-dim;
                        font-size: 9px;
                        letter-spacing: 1px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        Rectangle { height: 1px; background: Palette.border; }

        // ── Scrollable list ───────────────────────────────────────────────
        // ScrollView (not Flickable): drag-able scrollbar — linuxkms has no
        // scroll-wheel events on the kiosk.
        ScrollView {
            vertical-stretch: 1;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
            viewport-width: self.visible-width;
            viewport-height: sess-col.preferred-height;

            sess-col := VerticalLayout {
                padding: 12px;
                spacing: 8px;
                alignment: start;

                // Empty-state
                if root.sessions.length == 0: Text {
                    text: "Tap REFRESH to load sessions…";
                    color: Palette.text-dim;
                    font-size: 13px;
                    horizontal-alignment: center;
                }

                for item in root.sessions: Rectangle {
                    height: 66px;
                    border-radius: Palette.radius;
                    background: item.session-id == root.active-session-id
                        ? Palette.surface-hi
                        : Palette.surface;
                    border-width: 1px;
                    border-color: item.session-id == root.active-session-id
                        ? Palette.primary
                        : Palette.border;
                    animate border-color { duration: 200ms; }

                    TouchArea {
                        clicked => {
                            if item.session-id != root.active-session-id {
                                root.restore-session(item.session-id);
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: 0px;

                        // Active indicator bar
                        Rectangle {
                            width: 3px;
                            border-radius: 2px;
                            background: item.session-id == root.active-session-id
                                ? Palette.primary
                                : transparent;
                            animate background { duration: 200ms; }
                        }

                        VerticalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            spacing: 6px;
                            alignment: center;

                            HorizontalLayout {
                                spacing: 10px;

                                Text {
                                    text: "Session " + item.session-id;
                                    color: item.session-id == root.active-session-id
                                        ? Palette.text-bright
                                        : Palette.text;
                                    font-size: 12px;
                                    font-weight: item.session-id == root.active-session-id
                                        ? 700 : 400;
                                }

                                Text {
                                    text: item.message-count + " msg";
                                    color: Palette.text-dim;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }

                                Text {
                                    text: item.time-ago;
                                    color: Palette.text-dim;
                                    font-size: 10px;
                                    vertical-alignment: center;
                                }
                            }

                            Text {
                                text: item.preview;
                                color: Palette.text-dim;
                                font-size: 11px;
                                overflow: elide;
                            }
                        }
                    }
                }
            }
        }
    }
}
