import { Palette } from "../palette.slint";
import { MessageItem } from "../types.slint";
import { MessageBubble } from "message_bubble.slint";
import { ToolCard } from "tool_card.slint";

// Scrollable message list.
// Auto-scroll is triggered by AppWindow calling scroll-to-bottom().

export component ChatView {
    preferred-height: 0px;
    min-height: 0px;

    in property <[MessageItem]> messages;
    in property <float>         glow-alpha: 0.0;

    callback scroll-to-bottom();
    callback approve-tool(string);   // call_id
    callback reject-tool(string);    // call_id

    // Expose the flickable for scroll control
    property <length> flick-height: flick.viewport-height;

    scroll-to-bottom => {
        flick.viewport-y = min(0px, -(flick.viewport-height - flick.height));
    }

    flick := Flickable {
        interactive: true;

        VerticalLayout {
            padding:  12px;
            spacing:  6px;
            alignment: start;

            // Empty-state hint
            if root.messages.length == 0: Text {
                text: "Say 'apex' or type below…";
                color: Palette.text-dim;
                font-size: 13px;
                horizontal-alignment: center;
            }

            for item in root.messages: Rectangle {
                // Route to tool card or chat bubble based on role
                if item.role == "tool": ToolCard {
                    tool-name:          item.tool-name;
                    tool-args:          item.tool-args;
                    tool-output:        item.tool-output;
                    tool-status:        item.tool-status;
                    awaiting-approval:  item.awaiting-approval;
                    glow-alpha:         root.glow-alpha;
                    approve => { root.approve-tool(item.call-id); }
                    reject  => { root.reject-tool(item.call-id); }
                }
                if item.role != "tool": MessageBubble {
                    role:       item.role;
                    text:       item.text;
                    streaming:  item.streaming;
                    glow-alpha: root.glow-alpha;
                }
            }
        }
    }
}
