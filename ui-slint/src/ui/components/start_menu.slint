// Desktop-mode start menu (glowup G3b) — the app catalog that opens from the
// taskbar's Start button. An in-canvas overlay panel (not a native
// PopupWindow): linuxkms gives us a single fullscreen surface, so every
// "popup" is just a layered element, dismissed by a backdrop click. Launching
// an entry emits `launch(ordinal)` (AppKind) and the parent closes the menu.
// Council / Terminal entries slot in here when those apps land (G3d+).

import { Palette } from "../palette.slint";
import { Personas } from "../personas.slint";
import { Win98, BevelEdges } from "win98.slint";

component MenuRow inherits Rectangle {
    in property <string> glyph;
    in property <string> label;
    callback clicked;

    height: 44px;
    border-radius: Palette.radius;
    background: touch.has-hover ? Palette.surface-hi : transparent;
    animate background { duration: 120ms; }

    touch := TouchArea { clicked => { root.clicked(); } }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 16px;
        spacing: 12px;
        alignment: start;

        Text {
            text: root.glyph;
            font-size: 18px;
            width: 24px;
            color: touch.has-hover ? Palette.primary : Palette.text;
            vertical-alignment: center;
            horizontal-alignment: center;
        }
        Text {
            text: root.label;
            font-size: 13px;
            font-weight: 600;
            letter-spacing: 0.4px;
            color: touch.has-hover ? Palette.primary : Palette.text;
            vertical-alignment: center;
        }
    }
}

export component StartMenu inherits Rectangle {
    callback launch(int);     // AppKind ordinal: 0=chat 1=system 2=sensor 3=sessions 4=settings 5=terminal 6=council

    width: 240px;
    height: layout.preferred-height;
    background: Palette.surface;
    border-radius: Palette.radius-lg;
    border-width: 1px;
    border-color: Palette.border-hi;
    drop-shadow-blur: 32px;
    drop-shadow-color: #000000aa;
    drop-shadow-offset-y: 8px;

    layout := VerticalLayout {
        padding: 8px;
        spacing: 2px;

        Text {
            text: "APPS";
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1.6px;
            color: Palette.text-dim;
            height: 28px;
            horizontal-alignment: left;
            vertical-alignment: center;
            // align label with the rows below it
            x: 12px;
        }

        // Core apps — always shown.
        MenuRow { glyph: "💬"; label: "Chat";     clicked => { root.launch(0); } }
        MenuRow { glyph: "🖥"; label: "System";   clicked => { root.launch(1); } }
        MenuRow { glyph: "🎵"; label: "Sonus";    clicked => { root.launch(11); } }
        MenuRow { glyph: "📝"; label: "Notes";    clicked => { root.launch(12); } }
        MenuRow { glyph: "😊"; label: "APEX";     clicked => { root.launch(13); } }
        MenuRow { glyph: "🎨"; label: "Sketchpad"; clicked => { root.launch(14); } }
        MenuRow { glyph: "🕘"; label: "Sessions"; clicked => { root.launch(3); } }
        MenuRow { glyph: "⚙"; label: "Settings"; clicked => { root.launch(4); } }

        // Deep-tech apps — hidden by the simple/warm persona (G5 surface gating).
        if Personas.show-tech-apps: MenuRow { glyph: "🌡"; label: "Sensors";  clicked => { root.launch(2); } }
        if Personas.show-tech-apps: MenuRow { glyph: "⌨"; label: "Terminal"; clicked => { root.launch(5); } }
        if Personas.show-tech-apps: MenuRow { glyph: "⚖"; label: "Council";  clicked => { root.launch(6); } }
        if Personas.show-tech-apps: MenuRow { glyph: "📜"; label: "Event Log"; clicked => { root.launch(7); } }
        if Personas.show-tech-apps: MenuRow { glyph: "🕸"; label: "Mesh";      clicked => { root.launch(8); } }
        if Personas.show-tech-apps: MenuRow { glyph: "⚡"; label: "Inference"; clicked => { root.launch(9); } }
        if Personas.show-tech-apps: MenuRow { glyph: "🎛"; label: "Audio Editor"; clicked => { root.launch(10); } }
        if Personas.show-tech-apps: MenuRow { glyph: "🌐"; label: "Web";          clicked => { root.launch(15); } }
    }
}

// ── Win-98 start menu (glowup G6) ────────────────────────────────────────
// The iconic look: a grey beveled panel with a dark vertical banner running up
// the left (rotated "ApexOS" wordmark) and classic menu rows that highlight
// navy-on-white on hover. Same launch(ordinal) contract as StartMenu.
component WinMenuRow inherits Rectangle {
    in property <string> glyph;
    in property <string> label;
    callback clicked;

    height: 26px;
    background: touch.has-hover ? Win98.sel-bg : transparent;

    touch := TouchArea { clicked => { root.clicked(); } }

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 16px;
        spacing: 10px;
        alignment: start;

        Text {
            text: root.glyph;
            font-size: 15px;
            width: 22px;
            color: touch.has-hover ? Win98.sel-text : Win98.text;
            vertical-alignment: center;
            horizontal-alignment: center;
        }
        Text {
            text: root.label;
            font-size: 12px;
            font-weight: 400;
            color: touch.has-hover ? Win98.sel-text : Win98.text;
            vertical-alignment: center;
        }
    }
}

export component Win98StartMenu inherits Rectangle {
    callback launch(int);     // AppKind ordinal — same contract as StartMenu

    width: 200px;
    // 8 core rows + (optional separator + 8 tech rows), all 26px; + 4px pads.
    height: (Personas.show-tech-apps ? 8 * 26px + 9px + 8 * 26px : 8 * 26px) + 8px;
    background: Win98.face;
    drop-shadow-blur: 6px;
    drop-shadow-color: #00000088;
    drop-shadow-offset-y: 3px;

    HorizontalLayout {
        padding: 3px;
        spacing: 3px;

        // Left banner — navy gradient with the rotated wordmark.
        Rectangle {
            width: 26px;
            background: @linear-gradient(180deg, #1084d0 0%, #000080 45%, #000040 100%);

            Text {
                text: "ApexOS";
                color: #ffffff;
                font-size: 15px;
                font-weight: 700;
                letter-spacing: 1px;
                transform-rotation: -90deg;
                width: parent.height;
                height: parent.width;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        VerticalLayout {
            padding: 0px;
            spacing: 0px;

            WinMenuRow { glyph: "💬"; label: "Chat";     clicked => { root.launch(0); } }
            WinMenuRow { glyph: "🖥"; label: "System";   clicked => { root.launch(1); } }
            WinMenuRow { glyph: "🎵"; label: "Sonus";    clicked => { root.launch(11); } }
            WinMenuRow { glyph: "📝"; label: "Notes";    clicked => { root.launch(12); } }
            WinMenuRow { glyph: "😊"; label: "APEX";     clicked => { root.launch(13); } }
            WinMenuRow { glyph: "🎨"; label: "Sketchpad"; clicked => { root.launch(14); } }
            WinMenuRow { glyph: "🕘"; label: "Sessions"; clicked => { root.launch(3); } }
            WinMenuRow { glyph: "⚙"; label: "Settings"; clicked => { root.launch(4); } }

            // Etched separator before the deep-tech group.
            if Personas.show-tech-apps: Rectangle {
                height: 9px;
                Rectangle { x: 4px; y: 4px; width: parent.width - 8px; height: 1px; background: Win98.shadow; }
                Rectangle { x: 4px; y: 5px; width: parent.width - 8px; height: 1px; background: Win98.hilite; }
            }
            if Personas.show-tech-apps: WinMenuRow { glyph: "🌡"; label: "Sensors";  clicked => { root.launch(2); } }
            if Personas.show-tech-apps: WinMenuRow { glyph: "⌨"; label: "Terminal"; clicked => { root.launch(5); } }
            if Personas.show-tech-apps: WinMenuRow { glyph: "⚖"; label: "Council";  clicked => { root.launch(6); } }
            if Personas.show-tech-apps: WinMenuRow { glyph: "📜"; label: "Event Log"; clicked => { root.launch(7); } }
            if Personas.show-tech-apps: WinMenuRow { glyph: "🕸"; label: "Mesh";      clicked => { root.launch(8); } }
            if Personas.show-tech-apps: WinMenuRow { glyph: "⚡"; label: "Inference"; clicked => { root.launch(9); } }
            if Personas.show-tech-apps: WinMenuRow { glyph: "🎛"; label: "Audio Editor"; clicked => { root.launch(10); } }
            if Personas.show-tech-apps: WinMenuRow { glyph: "🌐"; label: "Web";          clicked => { root.launch(15); } }
        }
    }

    BevelEdges { }
}
