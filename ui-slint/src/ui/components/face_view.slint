import { Palette } from "../palette.slint";
import { FaceGl } from "../types.slint";

// ── FaceView (😊) ───────────────────────────────────────────────────────────
//
// APEX's face. Two layers feed it:
//   • ACTIVITY states (idle/thinking/speaking/listening/alert/sleeping) — set
//     automatically by Rust from the agentd event stream.
//   • EMOTIVE states (neutral/happy/curious/amused/confused/sad/surprised/wink/
//     skeptical/proud/love/focused) — set deliberately by APEX via the
//     `display_face` tool, which the UI consumes from the tool_requested event.
//     `gaze` (center|left|right|up|down) and `intensity` (0..1) refine it; an
//     emote lingers past turn-end (Rust holds it) so the expression feels alive.
//
// Built from rounded rectangles + eyebrows + a single Path mouth (the one curve
// where a stroke beats a rect — proven on femtovg via the sketchpad) + a radial
// gradient head, so it renders on every backend incl. femtovg software (Nano).
// The shader/3D face is the Phase-2 upgrade for GL tiers; this is the universal
// fallback and the control surface it will plug into.
//
// preferred/min height 0 so the parent VerticalLayout sizes us via stretch.

export component FaceView {
    preferred-height: 0px;
    min-height: 0px;

    in property <string> state: "idle";
    in property <int>    tick: 0;
    in property <string> gaze: "center";
    in property <float>  intensity: 0.7;

    // Per-state accent — carries most of the emotional read.
    property <color> accent:
        root.state == "thinking"   ? #eab308
        : root.state == "speaking" ? Palette.primary
        : root.state == "listening" ? #00d4ff
        : root.state == "alert"    ? #ef4444
        : root.state == "sleeping" ? Palette.text-dim
        : root.state == "happy"    ? #39ff14
        : root.state == "amused"   ? #39ff14
        : root.state == "proud"    ? #39ff14
        : root.state == "curious"  ? #00d4ff
        : root.state == "focused"  ? #00d4ff
        : root.state == "confused" ? #eab308
        : root.state == "surprised" ? #eab308
        : root.state == "skeptical" ? #eab308
        : root.state == "wink"     ? #39ff14
        : root.state == "sad"      ? #6b8cff
        : root.state == "love"     ? #ff6ad5
        : Palette.primary;

    // Symmetric base eye openness (0 closed … 1 wide).
    property <float> eye-base:
        root.state == "sleeping"  ? 0.10
        : root.state == "thinking" ? 0.55
        : root.state == "focused"  ? 0.58
        : root.state == "sad"      ? 0.60
        : root.state == "skeptical" ? 0.72
        : root.state == "confused" ? 0.78
        : (root.state == "listening" || root.state == "alert" || root.state == "surprised") ? 1.0
        : 0.85;

    // Blink every 7 ticks (never while asleep or mid-wink).
    property <bool> blink: root.state != "sleeping" && root.state != "wink" && Math.mod(root.tick, 7) == 0;
    property <float> l-eye:
        root.state == "wink" ? 0.08
        : root.blink ? 0.10
        : root.eye-base;
    property <float> r-eye:
        root.state == "skeptical" ? root.eye-base * 0.5
        : root.blink ? 0.10
        : root.eye-base;

    // Eyebrow vertical bias: + raised, − lowered (px applied in head space).
    // skew tilts left vs right (confused / skeptical). Both scaled by intensity.
    property <float> brow-raise:
        root.state == "surprised" ? 1.0
        : root.state == "curious"  ? 0.7
        : root.state == "proud"    ? 0.5
        : root.state == "amused"   ? 0.45
        : root.state == "listening" ? 0.4
        : root.state == "confused" ? 0.4
        : root.state == "sad"      ? 0.35
        : root.state == "love"     ? 0.3
        : root.state == "happy"    ? 0.25
        : root.state == "thinking" ? -0.3
        : root.state == "skeptical" ? -0.4
        : root.state == "alert"    ? -0.5
        : root.state == "focused"  ? -0.6
        : 0.0;
    property <float> brow-skew:
        root.state == "confused"  ? 0.6
        : root.state == "skeptical" ? 0.5
        : 0.0;

    // Inner-end brow tilt (consumed by the GL face): +up = worried/sad,
    // −down = angry/focused. The 2D face doesn't render this; it's the extra
    // shape dimension the shader can express. Scaled by intensity in the shader.
    property <float> brow-angle:
        root.state == "alert"     ? -1.0
        : root.state == "focused"  ? -0.8
        : root.state == "thinking" ? -0.4
        : root.state == "skeptical" ? -0.3
        : root.state == "sad"      ? 1.0
        : root.state == "confused" ? 0.6
        : root.state == "curious"  ? 0.4
        : root.state == "surprised" ? 0.2
        : 0.0;

    // Warm-cheek blush (GL face): affection / pride / delight.
    property <float> blush:
        root.state == "love"   ? 1.0
        : root.state == "proud" ? 0.6
        : root.state == "happy" ? 0.5
        : root.state == "amused" ? 0.5
        : 0.0;

    // Motion / life (GL face only). The 2D fallback ignores these.
    property <float> talk: root.state == "speaking" ? 1.0 : 0.0;
    property <float> head-roll:                 // tilt/cock the head
        root.state == "curious"   ? 0.55
        : root.state == "confused" ? 0.40
        : root.state == "amused"   ? 0.28
        : root.state == "skeptical" ? -0.18
        : 0.0;
    property <float> head-pitch:                // chin up (+) / down (−)
        root.state == "proud"     ? 0.35
        : root.state == "surprised" ? 0.15
        : root.state == "sad"      ? -0.18
        : root.state == "sleeping" ? -0.28
        : 0.0;
    property <float> tear: root.state == "sad" ? 1.0 : 0.0;

    // Mouth curve for the Path: +1 full smile … 0 flat … −1 full frown.
    property <float> mouth-curve:
        (root.state == "happy" || root.state == "amused" || root.state == "proud"
            || root.state == "love" || root.state == "wink") ? 1.0
        : root.state == "curious"  ? 0.4
        : root.state == "sad"      ? -1.0
        : root.state == "confused" ? -0.4
        : root.state == "skeptical" ? -0.3
        : 0.0;
    // Open-mouth states draw a filled maw instead of a stroked curve.
    property <bool> mouth-is-open:
        root.state == "speaking" || root.state == "surprised" || root.state == "alert";
    property <float> mouth-open:
        root.state == "speaking" ? (Math.mod(root.tick, 2) == 0 ? 0.9 : 0.3)
        : root.state == "surprised" ? 0.9
        : root.state == "alert"  ? 0.6
        : 0.0;
    // Quadratic control-Y in the mouth viewbox (baseline 30 of 60). Larger Y dips
    // DOWN → smile; smaller Y arcs up → frown. Scaled by intensity.
    property <float> mouth-cy: 30 + root.mouth-curve * 22 * root.intensity;

    // Gaze as a fraction of head size (applied inside the head).
    property <float> gaze-fx:
        root.gaze == "left" ? -0.06 : root.gaze == "right" ? 0.06 : 0.0;
    property <float> gaze-fy:
        root.gaze == "up" ? -0.05 : root.gaze == "down" ? 0.05 : 0.0;

    property <string> label:
        root.state == "thinking"   ? "THINKING…"
        : root.state == "speaking" ? "SPEAKING"
        : root.state == "listening" ? "LISTENING"
        : root.state == "alert"    ? "NEEDS YOU"
        : root.state == "sleeping" ? "ASLEEP"
        : root.state == "happy"    ? "☺"
        : root.state == "amused"   ? "HEH"
        : root.state == "curious"  ? "HM?"
        : root.state == "confused" ? "???"
        : root.state == "sad"      ? "…"
        : root.state == "surprised" ? "OH!"
        : root.state == "wink"     ? ";)"
        : root.state == "skeptical" ? "HMM"
        : root.state == "proud"    ? "✓"
        : root.state == "love"     ? "♥"
        : root.state == "focused"  ? "FOCUS"
        : "READY";

    VerticalLayout {
        // ── Face stage ────────────────────────────────────────────────────
        stage := Rectangle {
            vertical-stretch: 1;
            background: Palette.bg;
            clip: true;

            // Phase-2 GL face: publish our live on-window rect so Rust's
            // rendering-notifier GL pass can scissor the shader to exactly this
            // stage (the window moves/resizes; the GL face tracks it). Sampled
            // from a Timer rather than `changed` handlers: reading the
            // layout-coupled absolute-position inside a property-change callback
            // re-enters the layout pass ("Recursion detected"); a Timer fires in
            // event-loop context, between frames, where the read is safe. Gated
            // on FaceGl.active (Rust sets it only on the GL path) so the 2D
            // fallback face on Nano pays nothing.
            Timer {
                interval: 32ms;          // ~30fps, in step with the GL redraw
                running: FaceGl.active;
                triggered => {
                    FaceGl.x = stage.absolute-position.x;
                    FaceGl.y = stage.absolute-position.y;
                    FaceGl.w = stage.width;
                    FaceGl.h = stage.height;
                    // Expression — the same derivations the 2D face renders, so
                    // the GL shader tracks it exactly (incl. tick-driven blink).
                    FaceGl.accent = root.accent;
                    FaceGl.eye-l = root.l-eye;
                    FaceGl.eye-r = root.r-eye;
                    FaceGl.brow = root.brow-raise;
                    FaceGl.brow-skew = root.brow-skew;
                    FaceGl.brow-angle = root.brow-angle;
                    FaceGl.blush = root.blush;
                    FaceGl.talk = root.talk;
                    FaceGl.head-roll = root.head-roll;
                    FaceGl.head-pitch = root.head-pitch;
                    FaceGl.tear = root.tear;
                    FaceGl.mouth = root.mouth-curve;
                    FaceGl.mouth-open = root.mouth-is-open ? root.mouth-open : 0;
                    FaceGl.gaze-x = root.gaze-fx;
                    FaceGl.gaze-y = root.gaze-fy;
                    FaceGl.intensity = root.intensity;
                }
            }

            // Head diameter from the smaller stage axis.
            property <length> hd: min(self.width, self.height) - 56px;

            // Aura ring — pulses when listening / speaking.
            Rectangle {
                width: stage.hd + 30px;
                height: self.width;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                border-radius: self.width / 2;
                border-width: 3px;
                border-color: root.accent;
                opacity: (root.state == "listening" || root.state == "speaking")
                    ? (Math.mod(root.tick, 2) == 0 ? 0.55 : 0.12)
                    : 0.0;
                animate opacity { duration: 420ms; }
            }

            // Head.
            head := Rectangle {
                width: stage.hd;
                height: stage.hd;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                border-radius: self.width / 2;
                background: @radial-gradient(circle, Palette.surface-hi 0%, Palette.surface 68%, Palette.bg 100%);
                border-width: 2px;
                border-color: root.accent;
                animate border-color { duration: 300ms; }

                property <length> eye-w: self.width * 0.15;
                property <length> eye-y: self.height * 0.42;
                property <length> gx: self.width * root.gaze-fx;
                property <length> gy: self.height * root.gaze-fy;
                // Brow vertical travel; up is negative y.
                property <length> brow-y0: self.height * 0.24;
                property <length> brow-l-dy: -(root.brow-raise + root.brow-skew) * root.intensity * self.height * 0.07;
                property <length> brow-r-dy: -(root.brow-raise - root.brow-skew) * root.intensity * self.height * 0.07;

                // Left eyebrow.
                Rectangle {
                    width: head.eye-w * 1.25;
                    height: 4px;
                    x: head.width * 0.35 - self.width / 2 + head.gx;
                    y: head.brow-y0 + head.brow-l-dy + head.gy;
                    border-radius: 2px;
                    background: root.accent;
                    opacity: root.state == "sleeping" ? 0.25 : 0.9;
                    animate y { duration: 160ms; }
                }
                // Right eyebrow.
                Rectangle {
                    width: head.eye-w * 1.25;
                    height: 4px;
                    x: head.width * 0.65 - self.width / 2 + head.gx;
                    y: head.brow-y0 + head.brow-r-dy + head.gy;
                    border-radius: 2px;
                    background: root.accent;
                    opacity: root.state == "sleeping" ? 0.25 : 0.9;
                    animate y { duration: 160ms; }
                }

                // Left eye.
                Rectangle {
                    width: head.eye-w;
                    height: max(2px, head.eye-w * root.l-eye);
                    x: head.width * 0.35 - self.width / 2 + head.gx;
                    y: head.eye-y - self.height / 2 + head.gy;
                    border-radius: self.height / 2;
                    background: root.accent;
                    animate height { duration: 120ms; }
                }
                // Right eye.
                Rectangle {
                    width: head.eye-w;
                    height: max(2px, head.eye-w * root.r-eye);
                    x: head.width * 0.65 - self.width / 2 + head.gx;
                    y: head.eye-y - self.height / 2 + head.gy;
                    border-radius: self.height / 2;
                    background: root.accent;
                    animate height { duration: 120ms; }
                }

                // Mouth — open states draw a filled maw; everything else a
                // stroked quadratic curve (smile ↔ frown ↔ flat).
                if root.mouth-is-open: Rectangle {
                    width: head.width * 0.28;
                    height: max(5px, head.width * 0.20 * root.mouth-open);
                    x: (head.width - self.width) / 2 + head.gx * 0.5;
                    y: head.height * 0.66 - self.height / 2;
                    border-radius: min(self.width, self.height) / 2;
                    background: root.accent;
                    animate width, height { duration: 130ms; }
                }
                if !root.mouth-is-open: Path {
                    width: head.width * 0.50;
                    height: head.height * 0.24;
                    x: (head.width - self.width) / 2 + head.gx * 0.5;
                    y: head.height * 0.56;
                    viewbox-x: 0;
                    viewbox-y: 0;
                    viewbox-width: 100;
                    viewbox-height: 60;
                    commands: "M 12 30 Q 50 \{root.mouth-cy} 88 30";
                    stroke: root.accent;
                    stroke-width: 5px;
                    fill: transparent;
                }
            }
        }

        // ── Status footer ─────────────────────────────────────────────────
        Rectangle {
            height: 48px;
            background: Palette.surface;
            Rectangle { y: 0px; height: 1px; background: Palette.border; }
            HorizontalLayout {
                alignment: center;
                spacing: 10px;
                Rectangle {
                    width: 10px;
                    height: 10px;
                    border-radius: 5px;
                    background: root.accent;
                    y: (parent.height - self.height) / 2;
                }
                Text {
                    text: root.label;
                    color: Palette.text-bright;
                    font-size: 12px;
                    font-weight: 700;
                    letter-spacing: 2px;
                    vertical-alignment: center;
                }
            }
        }
    }
}
