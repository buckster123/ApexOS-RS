// Desktop-mode taskbar (glowup G3) — the unified bottom bar that retires the
// G1/G2 floating dock. Three regions, left→right:
//   [⊞ Start]  →  one button per OPEN window  →  [🔔 tray]
// Start opens the app catalog (start menu, G3b); the running-window buttons
// focus / restore / minimize-toggle their window; the tray opens the
// notification center (G3c). Persona chrome (mac dock, win98 start bar) reads
// its tokens into this same skeleton in later phases.

import { Palette } from "../palette.slint";
import { Personas } from "../personas.slint";
import { Win98, BevelEdges, Win98Button } from "win98.slint";
import { WindowDesc, ChromeKind } from "../types.slint";

// A single running-window button. Active = focused & visible; a minimized
// window shows dimmed so it's still discoverable (the G2 bug was that it
// vanished entirely with no way back).
component TaskButton inherits Rectangle {
    in property <string> label;
    in property <bool> active;
    in property <bool> minimized;
    callback clicked;

    height: 40px;
    min-width: 96px;
    horizontal-stretch: 0;
    border-radius: Palette.radius;
    background: active ? Palette.primary-dim
                       : (touch.has-hover ? Palette.surface-hi : transparent);
    border-width: 1px;
    border-color: active ? Palette.primary : transparent;
    opacity: minimized ? 0.55 : 1.0;
    animate background, border-color, opacity { duration: 150ms; }

    touch := TouchArea { clicked => { root.clicked(); } }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 6px;
        alignment: start;

        // Minimized marker — a small underscore-style bar, like a taskbar tab.
        Rectangle {
            width: 6px;
            y: parent.height - 10px;
            height: 3px;
            border-radius: 1.5px;
            background: root.minimized ? Palette.text-dim : Palette.primary;
            vertical-stretch: 0;
        }

        Text {
            text: root.label;
            color: active ? Palette.primary : Palette.text-dim;
            font-size: 11px;
            font-weight: active ? 700 : 500;
            letter-spacing: 0.6px;
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

// A flat icon-ish button for the Start and tray ends of the bar.
component EndButton inherits Rectangle {
    in property <string> glyph;
    in property <string> label;
    in property <bool> active;
    in property <int> badge: 0;     // >0 shows a count pip (tray unread)
    callback clicked;

    height: 40px;
    min-width: 56px;
    border-radius: Palette.radius;
    background: active ? Palette.primary-dim
                       : (touch.has-hover ? Palette.surface-hi : transparent);
    border-width: 1px;
    border-color: active ? Palette.primary : transparent;
    animate background, border-color { duration: 150ms; }

    touch := TouchArea { clicked => { root.clicked(); } }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 6px;
        alignment: center;

        Text {
            text: root.glyph;
            color: active ? Palette.primary : Palette.text;
            font-size: 15px;
            vertical-alignment: center;
        }
        if root.label != "": Text {
            text: root.label;
            color: active ? Palette.primary : Palette.text-dim;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 1px;
            vertical-alignment: center;
        }
    }

    // Unread badge pip (tray).
    if root.badge > 0: Rectangle {
        x: parent.width - self.width - 4px;
        y: 4px;
        width: 16px;
        height: 16px;
        border-radius: 8px;
        background: Palette.primary;
        Text {
            text: root.badge > 9 ? "9+" : root.badge;
            color: Palette.bg;
            font-size: 9px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

export component Taskbar inherits Rectangle {
    in property <[WindowDesc]> windows;
    in property <int> focused-id;
    in property <bool> start-open;       // start menu currently shown
    in property <bool> tray-open;        // notification center currently shown
    in property <int> notif-count;       // unread badge on the tray
    in property <int> council-count;     // sub-agents currently running
    in property <bool> council-active;   // a council deliberation is in session

    callback start-clicked();
    callback task-activate(int);         // window id
    callback tray-clicked();
    callback council-clicked();          // open the Council window

    // Win-98 taskbar: flush grey beveled bar (shorter, no rounding/float).
    property <bool> win98: Personas.chrome == ChromeKind.win;

    height: root.win98 ? 34px : 56px;
    background: root.win98 ? Win98.face : Palette.surface;
    border-radius: root.win98 ? 0px : Palette.radius-lg;
    border-width: root.win98 ? 0px : 1px;
    border-color: Palette.border-hi;
    drop-shadow-blur: root.win98 ? 0px : 24px;
    drop-shadow-color: #00000066;
    drop-shadow-offset-y: root.win98 ? 0px : 6px;

    // ════ MODERN BAR (apex / mac / adwaita / hud) ════════════════════════
    if !root.win98: HorizontalLayout {
        padding: 8px;
        spacing: 6px;

        EndButton {
            glyph: "⊞";
            label: "START";
            active: root.start-open;
            clicked => { root.start-clicked(); }
        }

        // Divider between Start and the running tasks.
        Rectangle { width: 1px; background: Palette.border-hi; }

        // Running-window buttons — one per window in z-order.
        for w in root.windows: TaskButton {
            label: w.title;
            active: w.id == root.focused-id && !w.minimized;
            minimized: w.minimized;
            clicked => { root.task-activate(w.id); }
        }

        // Push the tray to the far right.
        Rectangle { horizontal-stretch: 1; }

        // Council indicator — only present while a council is in session or
        // sub-agents are running; the badge counts running sub-agents.
        if root.council-active || root.council-count > 0: EndButton {
            glyph: "⚖";
            active: root.council-active;
            badge: root.council-count;
            clicked => { root.council-clicked(); }
        }

        EndButton {
            glyph: "🔔";
            active: root.tray-open;
            badge: root.notif-count;
            clicked => { root.tray-clicked(); }
        }
    }

    // ════ WIN-98 BAR ═════════════════════════════════════════════════════
    if root.win98: HorizontalLayout {
        padding: 2px;
        spacing: 4px;

        // ── Start button: beveled, 4-pane flag + bold "Start" ───────────
        Rectangle {
            width: 60px;
            background: Win98.face;

            HorizontalLayout {
                padding-left: (start-ta.pressed || root.start-open) ? 7px : 6px;
                padding-top: (start-ta.pressed || root.start-open) ? 1px : 0px;
                spacing: 4px;
                alignment: start;

                // Waving 4-pane window flag (red/green/blue/yellow quadrants).
                Rectangle {
                    width: 15px; height: 14px;
                    y: (parent.height - self.height) / 2;
                    Rectangle { x: 0px;   y: 1px; width: 6px; height: 6px; background: #ff0000; }
                    Rectangle { x: 7px;   y: 0px; width: 6px; height: 6px; background: #00a800; }
                    Rectangle { x: 0px;   y: 8px; width: 6px; height: 6px; background: #0000ff; }
                    Rectangle { x: 7px;   y: 7px; width: 6px; height: 6px; background: #ffff00; }
                }
                Text {
                    text: "Start";
                    color: Win98.text;
                    font-size: 12px;
                    font-weight: 700;
                    vertical-alignment: center;
                }
            }
            BevelEdges { sunken: start-ta.pressed || root.start-open; }
            start-ta := TouchArea { clicked => { root.start-clicked(); } }
        }

        // Sunken seam after Start (classic quick-launch separator).
        Rectangle { width: 4px; }

        // Running-window buttons — beveled tabs, sunken when active.
        for w in root.windows: Win98Button {
            width: 150px;
            label: w.title;
            active: w.id == root.focused-id && !w.minimized;
            clicked => { root.task-activate(w.id); }
        }

        Rectangle { horizontal-stretch: 1; }

        // ── Sunken system tray (council + notifications) ────────────────
        Rectangle {
            width: tray.preferred-width + 12px;
            background: Win98.face;

            tray := HorizontalLayout {
                padding-left: 6px;
                padding-right: 6px;
                spacing: 8px;
                alignment: center;

                if root.council-active || root.council-count > 0: Rectangle {
                    width: 18px;
                    Text {
                        text: "⚖";
                        color: root.council-active ? Win98.sel-bg : Win98.text;
                        font-size: 13px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    if root.council-count > 0: Text {
                        text: root.council-count;
                        x: parent.width - self.width;
                        y: 0px;
                        color: #aa0000;
                        font-size: 8px;
                        font-weight: 700;
                    }
                    council-ta := TouchArea { clicked => { root.council-clicked(); } }
                }

                Rectangle {
                    width: 18px;
                    Text {
                        text: "🔔";
                        font-size: 12px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    if root.notif-count > 0: Rectangle {
                        x: parent.width - self.width;
                        y: 0px;
                        width: 12px; height: 12px;
                        background: #aa0000;
                        Text {
                            text: root.notif-count > 9 ? "9+" : root.notif-count;
                            color: #ffffff;
                            font-size: 7px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                    tray-ta := TouchArea { clicked => { root.tray-clicked(); } }
                }
            }
            BevelEdges { sunken: true; }
        }
    }

    // Win-98 bar's raised top edge (drawn over the flush bar).
    if root.win98: BevelEdges { }
}
