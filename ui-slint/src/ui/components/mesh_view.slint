import { Palette } from "../palette.slint";
import { MeshNode } from "../types.slint";

// ── MeshView (🕸) ─────────────────────────────────────────────────────────────
//
// The cluster: saved peers (peers.toml, /api/mesh/peers) + mDNS-discovered
// nodes not yet added (/api/mesh/nodes). A discovered node offers "+ ADD"
// (POST /api/mesh/peers); a saved peer offers "✕" (DELETE /api/mesh/peers/:id).
//
// "+ ADD" opens a token-capture dialog: cross-node a2a needs the peer's
// AGENTD_TOKEN (the peer's /api/sessions/{id}/message is token-gated). The token
// is optional — leave blank for an auth-disabled node. The status dot shows a2a
// readiness: green = peer with token, amber = peer without, dim = discovered.
//
// preferred/min height 0 so the parent VerticalLayout sizes us via stretch.

export component MeshView {
    preferred-height: 0px;
    min-height: 0px;

    in property <[MeshNode]> nodes;

    // Token-capture dialog state. pending-node != "" ⇒ dialog open.
    in-out property <string> pending-node;
    in-out property <string> pending-url;

    callback refresh();
    callback add-peer(string, string, string);   // node_id, ws_url, token
    callback remove-peer(string);                 // node_id

    VerticalLayout {
        width: 100%;
        height: 100%;

        // ── Header ────────────────────────────────────────────────────────
        Rectangle {
            height: 48px;
            background: Palette.surface;

            HorizontalLayout {
                padding-left: 20px;
                padding-right: 14px;

                Text {
                    text: "MESH";
                    color: Palette.text-dim;
                    font-size: 9px;
                    letter-spacing: 2px;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                Rectangle {
                    width: 72px;
                    height: 28px;
                    border-radius: Palette.radius;
                    background: ref_ta.pressed ? Palette.primary-dim
                              : ref_ta.has-hover ? Palette.surface
                              : Palette.surface-hi;
                    border-width: 1px;
                    border-color: ref_ta.has-hover ? Palette.primary : Palette.border;
                    y: (parent.height - self.height) / 2;
                    animate background, border-color { duration: 150ms; }

                    ref_ta := TouchArea { clicked => { root.refresh(); } }

                    Text {
                        text: "REFRESH";
                        color: ref_ta.has-hover ? Palette.primary : Palette.text-dim;
                        font-size: 9px;
                        letter-spacing: 1px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        Rectangle { height: 1px; background: Palette.border; }

        // ── Node list ───────────────────────────────────────────────────────
        Flickable {
            vertical-stretch: 1;
            interactive: true;
            viewport-height: mesh-col.preferred-height;

            mesh-col := VerticalLayout {
                padding: 12px;
                spacing: 8px;
                alignment: start;

                if root.nodes.length == 0: Text {
                    text: "Tap REFRESH to scan the mesh…";
                    color: Palette.text-dim;
                    font-size: 13px;
                    horizontal-alignment: center;
                }

                for item in root.nodes: Rectangle {
                    height: 60px;
                    border-radius: Palette.radius;
                    background: Palette.surface;
                    border-width: 1px;
                    border-color: item.is-peer ? Palette.primary.with-alpha(0.4) : Palette.border;

                    HorizontalLayout {
                        padding-left: 14px;
                        padding-right: 12px;
                        spacing: 12px;

                        // a2a-readiness dot: green = peer w/ token, amber = peer w/o, dim = discovered
                        Rectangle {
                            width: 8px; height: 8px;
                            border-radius: 4px;
                            y: (parent.height - self.height) / 2;
                            background: !item.is-peer ? Palette.text-dim
                                      : item.has-token ? Palette.primary
                                      : #f59e0b;
                        }

                        VerticalLayout {
                            spacing: 4px;
                            alignment: center;
                            horizontal-stretch: 1;

                            Text {
                                text: item.node-id;
                                color: Palette.text-bright;
                                font-size: 12px;
                                font-weight: 600;
                                overflow: elide;
                            }
                            Text {
                                text: item.is-peer && !item.has-token ? item.detail + "  ·  no token (a2a off)"
                                                                       : item.detail;
                                color: Palette.text-dim;
                                font-size: 10px;
                                overflow: elide;
                            }
                        }

                        // Role / status badge
                        Rectangle {
                            width: rbadge.preferred-width + 14px;
                            height: 20px;
                            border-radius: Palette.radius-sm;
                            background: Palette.surface-hi;
                            y: (parent.height - self.height) / 2;
                            rbadge := Text {
                                text: item.is-peer ? item.role : item.status;
                                color: Palette.text-dim;
                                font-size: 9px;
                                letter-spacing: 0.5px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        // Action: ADD (discovered → opens token dialog) / ✕ (saved peer)
                        Rectangle {
                            width: 56px;
                            height: 28px;
                            border-radius: Palette.radius;
                            background: act.has-hover
                                ? (item.is-peer ? rgba(239,68,68,0.2) : Palette.primary-dim)
                                : Palette.surface-hi;
                            border-width: 1px;
                            border-color: item.is-peer ? rgba(239,68,68,0.5) : Palette.primary;
                            y: (parent.height - self.height) / 2;
                            animate background { duration: 150ms; }

                            act := TouchArea {
                                clicked => {
                                    if item.is-peer {
                                        root.remove-peer(item.node-id);
                                    } else {
                                        root.pending-node = item.node-id;
                                        root.pending-url  = item.detail;
                                    }
                                }
                            }
                            Text {
                                text: item.is-peer ? "✕" : "+ ADD";
                                color: item.is-peer ? #ef4444 : Palette.primary;
                                font-size: 10px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }

    // ── Token-capture dialog (overlays the whole view when adding a peer) ───────
    if root.pending-node != "": Rectangle {
        width: 100%;
        height: 100%;
        background: #000000.with-alpha(0.55);

        // Backdrop click dismisses.
        TouchArea { clicked => { root.pending-node = ""; } }

        Rectangle {
            width: min(parent.width - 32px, 360px);
            height: 200px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: Palette.surface;
            border-radius: Palette.radius;
            border-width: 1px;
            border-color: Palette.border;

            // Swallow clicks inside the card so they don't hit the backdrop.
            TouchArea { }
            init => { tok-field.focus(); }

            VerticalLayout {
                padding: 16px;
                spacing: 10px;

                Text {
                    text: "Add peer  " + root.pending-node;
                    color: Palette.text-bright;
                    font-size: 13px;
                    font-weight: 600;
                }
                Text {
                    text: "Paste this node's AGENTD_TOKEN for cross-node a2a. Leave blank if it has no token.";
                    color: Palette.text-dim;
                    font-size: 10px;
                    wrap: word-wrap;
                }

                // Token field
                Rectangle {
                    height: 34px;
                    border-radius: Palette.radius;
                    background: Palette.bg;
                    border-width: 1px;
                    border-color: tok-field.has-focus ? Palette.primary : Palette.border;
                    clip: true;
                    tok-field := TextInput {
                        x: 10px;
                        width: parent.width - 20px;
                        height: parent.height;
                        vertical-alignment: center;
                        single-line: true;
                        font-size: 12px;
                        color: Palette.text;
                        selection-background-color: Palette.primary-dim;
                        accepted => {
                            root.add-peer(root.pending-node, root.pending-url, self.text);
                            root.pending-node = "";
                        }
                    }
                    if tok-field.text == "": Text {
                        x: 10px;
                        text: "AGENTD_TOKEN (optional)";
                        color: Palette.text-dim;
                        font-size: 12px;
                        vertical-alignment: center;
                    }
                }

                // Actions
                HorizontalLayout {
                    spacing: 8px;
                    alignment: end;

                    Rectangle {
                        width: 84px; height: 30px;
                        border-radius: Palette.radius;
                        background: cancel-ta.has-hover ? Palette.surface : Palette.surface-hi;
                        border-width: 1px;
                        border-color: Palette.border;
                        cancel-ta := TouchArea { clicked => { root.pending-node = ""; } }
                        Text {
                            text: "CANCEL"; color: Palette.text-dim;
                            font-size: 9px; letter-spacing: 1px;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                    }
                    Rectangle {
                        width: 84px; height: 30px;
                        border-radius: Palette.radius;
                        background: add-ta.has-hover ? Palette.primary : Palette.primary-dim;
                        border-width: 1px;
                        border-color: Palette.primary;
                        add-ta := TouchArea {
                            clicked => {
                                root.add-peer(root.pending-node, root.pending-url, tok-field.text);
                                root.pending-node = "";
                            }
                        }
                        Text {
                            text: "ADD"; color: Palette.text-bright;
                            font-size: 9px; letter-spacing: 1px; font-weight: 700;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}
