import { ScrollView } from "std-widgets.slint";
import { Palette } from "../palette.slint";
import { MeshNode, InboxThread } from "../types.slint";

// ── MeshView (🕸) ─────────────────────────────────────────────────────────────
//
// The cluster: saved peers (peers.toml, /api/mesh/peers) + mDNS-discovered
// nodes not yet added (/api/mesh/nodes). A discovered node offers "+ ADD"
// (POST /api/mesh/peers); a saved peer offers "✕" (DELETE /api/mesh/peers/:id).
//
// Cross-node a2a needs the peer's AGENTD_TOKEN. Two ways to supply it from the
// ADD dialog: paste the token, OR enter a 6-digit PAIRING CODE shown on the
// other node (PAIR button → /api/mesh/pair/start). Pairing exchanges tokens both
// ways with no hand-typing. The status dot shows a2a readiness: green = peer with
// token, amber = peer without, dim = discovered.
//
// preferred/min height 0 so the parent VerticalLayout sizes us via stretch.

export component MeshView {
    preferred-height: 0px;
    min-height: 0px;

    in property <[MeshNode]> nodes;

    // INBOX: per-peer a2a threads (event-driven, separate from the HTTP roster).
    in property <[InboxThread]> threads;
    in property <int> unread;            // total unread across threads (header pill)
    callback open-thread(int);           // peer thread SessionId → restore it

    // Token-capture / pairing dialog state. pending-node != "" ⇒ ADD dialog open.
    in-out property <string> pending-node;
    in-out property <string> pending-url;
    // Host-side pairing offer. pair-code != "" ⇒ "show this code" overlay open.
    in-out property <string> pair-code;
    in-out property <int>    pair-remaining;

    callback refresh();
    callback add-peer(string, string, string);   // node_id, ws_url, token
    callback remove-peer(string);                 // node_id
    callback start-pairing();                     // this node: generate + show a code
    callback redeem-pairing(string, string);      // peer ws_url, code

    VerticalLayout {
        width: 100%;
        height: 100%;

        // ── Header ────────────────────────────────────────────────────────
        Rectangle {
            height: 48px;
            background: Palette.surface;

            HorizontalLayout {
                padding-left: 20px;
                padding-right: 14px;
                spacing: 8px;

                Text {
                    text: "MESH";
                    color: Palette.text-dim;
                    font-size: 9px;
                    letter-spacing: 2px;
                    vertical-alignment: center;
                }

                // Unread-mail pill (total across all peer threads).
                if root.unread > 0: Rectangle {
                    width: pill.preferred-width + 14px;
                    height: 18px;
                    border-radius: 9px;
                    background: Palette.primary;
                    y: (parent.height - self.height) / 2;
                    pill := Text {
                        text: "✉ \{root.unread}";
                        color: Palette.text-bright;
                        font-size: 9px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                // Spacer pushes PAIR / REFRESH to the right edge.
                Rectangle { horizontal-stretch: 1; }

                // PAIR — show this node's code for another node to enter.
                Rectangle {
                    width: 56px;
                    height: 28px;
                    border-radius: Palette.radius;
                    background: pair_ta.pressed ? Palette.primary-dim
                              : pair_ta.has-hover ? Palette.surface
                              : Palette.surface-hi;
                    border-width: 1px;
                    border-color: pair_ta.has-hover ? Palette.primary : Palette.border;
                    y: (parent.height - self.height) / 2;
                    animate background, border-color { duration: 150ms; }
                    pair_ta := TouchArea { clicked => { root.start-pairing(); } }
                    Text {
                        text: "PAIR";
                        color: pair_ta.has-hover ? Palette.primary : Palette.text-dim;
                        font-size: 9px;
                        letter-spacing: 1px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    width: 72px;
                    height: 28px;
                    border-radius: Palette.radius;
                    background: ref_ta.pressed ? Palette.primary-dim
                              : ref_ta.has-hover ? Palette.surface
                              : Palette.surface-hi;
                    border-width: 1px;
                    border-color: ref_ta.has-hover ? Palette.primary : Palette.border;
                    y: (parent.height - self.height) / 2;
                    animate background, border-color { duration: 150ms; }

                    ref_ta := TouchArea { clicked => { root.refresh(); } }

                    Text {
                        text: "REFRESH";
                        color: ref_ta.has-hover ? Palette.primary : Palette.text-dim;
                        font-size: 9px;
                        letter-spacing: 1px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        Rectangle { height: 1px; background: Palette.border; }

        // ── Node list ───────────────────────────────────────────────────────
        // ScrollView (not Flickable): draws a drag-able scrollbar. The linuxkms
        // backend drops scroll-wheel events, so the bar is the only way to scroll
        // on the kiosk. See the "No mouse-wheel scroll on linuxkms" gotcha.
        ScrollView {
            vertical-stretch: 1;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
            viewport-width: self.visible-width;
            viewport-height: mesh-col.preferred-height;

            mesh-col := VerticalLayout {
                padding: 12px;
                spacing: 8px;
                alignment: start;

                // ── INBOX: a2a threads (peer → this node) ───────────────────
                if root.threads.length > 0: Text {
                    text: "✉ MESSAGES";
                    color: Palette.text-dim;
                    font-size: 9px;
                    letter-spacing: 2px;
                }

                for t in root.threads: Rectangle {
                    height: 54px;
                    border-radius: Palette.radius;
                    background: th-ta.has-hover ? Palette.surface-hi : Palette.surface;
                    border-width: 1px;
                    border-color: t.unread > 0 ? Palette.primary.with-alpha(0.5) : Palette.border;
                    animate background { duration: 120ms; }

                    th-ta := TouchArea { clicked => { root.open-thread(t.session); } }

                    HorizontalLayout {
                        padding-left: 14px;
                        padding-right: 12px;
                        spacing: 12px;

                        // unread dot: bright when unread, dim when read
                        Rectangle {
                            width: 8px; height: 8px;
                            border-radius: 4px;
                            y: (parent.height - self.height) / 2;
                            background: t.unread > 0 ? Palette.primary : Palette.text-dim;
                        }

                        VerticalLayout {
                            spacing: 3px;
                            alignment: center;
                            horizontal-stretch: 1;

                            HorizontalLayout {
                                spacing: 6px;
                                Text {
                                    text: t.node-id;
                                    color: Palette.text-bright;
                                    font-size: 12px;
                                    font-weight: 600;
                                    overflow: elide;
                                    horizontal-stretch: 1;
                                }
                                Text {
                                    text: t.last-seen;
                                    color: Palette.text-dim;
                                    font-size: 9px;
                                    vertical-alignment: center;
                                }
                            }
                            Text {
                                text: t.preview;
                                color: t.unread > 0 ? Palette.text : Palette.text-dim;
                                font-size: 10px;
                                overflow: elide;
                            }
                        }

                        // unread-count badge
                        if t.unread > 0: Rectangle {
                            width: 20px; height: 20px;
                            border-radius: 10px;
                            background: Palette.primary;
                            y: (parent.height - self.height) / 2;
                            Text {
                                text: t.unread > 9 ? "9+" : "\{t.unread}";
                                color: Palette.text-bright;
                                font-size: 9px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // Separator label before the node roster.
                if root.threads.length > 0: Text {
                    text: "NODES";
                    color: Palette.text-dim;
                    font-size: 9px;
                    letter-spacing: 2px;
                }

                if root.nodes.length == 0: Text {
                    text: "Tap REFRESH to scan the mesh…";
                    color: Palette.text-dim;
                    font-size: 13px;
                    horizontal-alignment: center;
                }

                for item in root.nodes: Rectangle {
                    height: 60px;
                    border-radius: Palette.radius;
                    background: Palette.surface;
                    border-width: 1px;
                    border-color: item.is-peer ? Palette.primary.with-alpha(0.4) : Palette.border;

                    HorizontalLayout {
                        padding-left: 14px;
                        padding-right: 12px;
                        spacing: 12px;

                        // a2a-readiness dot: green = peer w/ token, amber = peer w/o, dim = discovered
                        Rectangle {
                            width: 8px; height: 8px;
                            border-radius: 4px;
                            y: (parent.height - self.height) / 2;
                            background: !item.is-peer ? Palette.text-dim
                                      : item.has-token ? Palette.primary
                                      : #f59e0b;
                        }

                        VerticalLayout {
                            spacing: 4px;
                            alignment: center;
                            horizontal-stretch: 1;

                            Text {
                                text: item.node-id;
                                color: Palette.text-bright;
                                font-size: 12px;
                                font-weight: 600;
                                overflow: elide;
                            }
                            Text {
                                text: item.is-peer && !item.has-token ? item.detail + "  ·  no token (a2a off)"
                                                                       : item.detail;
                                color: Palette.text-dim;
                                font-size: 10px;
                                overflow: elide;
                            }
                            // Federation flow (receiver-side counters); hidden
                            // until this peer has sent/queried something.
                            if item.fed-line != "": Text {
                                text: item.fed-line;
                                color: Palette.primary-dim;
                                font-size: 10px;
                                overflow: elide;
                            }
                        }

                        // Role / status badge
                        Rectangle {
                            width: rbadge.preferred-width + 14px;
                            height: 20px;
                            border-radius: Palette.radius-sm;
                            background: Palette.surface-hi;
                            y: (parent.height - self.height) / 2;
                            rbadge := Text {
                                text: item.is-peer ? item.role : item.status;
                                color: Palette.text-dim;
                                font-size: 9px;
                                letter-spacing: 0.5px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        // Action: ADD (discovered → opens token/pair dialog) / ✕ (saved peer)
                        Rectangle {
                            width: 56px;
                            height: 28px;
                            border-radius: Palette.radius;
                            background: act.has-hover
                                ? (item.is-peer ? rgba(239,68,68,0.2) : Palette.primary-dim)
                                : Palette.surface-hi;
                            border-width: 1px;
                            border-color: item.is-peer ? rgba(239,68,68,0.5) : Palette.primary;
                            y: (parent.height - self.height) / 2;
                            animate background { duration: 150ms; }

                            act := TouchArea {
                                clicked => {
                                    if item.is-peer {
                                        root.remove-peer(item.node-id);
                                    } else {
                                        root.pending-node = item.node-id;
                                        root.pending-url  = item.detail;
                                    }
                                }
                            }
                            Text {
                                text: item.is-peer ? "✕" : "+ ADD";
                                color: item.is-peer ? #ef4444 : Palette.primary;
                                font-size: 10px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }

    // ── ADD dialog: paste a token OR enter a pairing code ───────────────────────
    if root.pending-node != "": Rectangle {
        width: 100%;
        height: 100%;
        background: #000000.with-alpha(0.55);
        TouchArea { clicked => { root.pending-node = ""; } }

        Rectangle {
            width: min(parent.width - 32px, 380px);
            height: 288px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: Palette.surface;
            border-radius: Palette.radius;
            border-width: 1px;
            border-color: Palette.border;
            TouchArea { }
            init => { tok-field.focus(); }

            VerticalLayout {
                padding: 16px;
                spacing: 9px;

                Text {
                    text: "Add peer  " + root.pending-node;
                    color: Palette.text-bright;
                    font-size: 13px;
                    font-weight: 600;
                }

                // Method 1 — paste the token.
                Text {
                    text: "Paste its AGENTD_TOKEN (blank if the node has no token):";
                    color: Palette.text-dim;
                    font-size: 10px;
                    wrap: word-wrap;
                }
                HorizontalLayout {
                    spacing: 8px;
                    Rectangle {
                        horizontal-stretch: 1;
                        height: 32px;
                        border-radius: Palette.radius;
                        background: Palette.bg;
                        border-width: 1px;
                        border-color: tok-field.has-focus ? Palette.primary : Palette.border;
                        clip: true;
                        tok-field := TextInput {
                            x: 10px; width: parent.width - 20px; height: parent.height;
                            vertical-alignment: center; single-line: true;
                            font-size: 12px; color: Palette.text;
                            selection-background-color: Palette.primary-dim;
                            accepted => { root.add-peer(root.pending-node, root.pending-url, self.text); root.pending-node = ""; }
                        }
                        if tok-field.text == "": Text {
                            x: 10px; text: "AGENTD_TOKEN (optional)";
                            color: Palette.text-dim; font-size: 12px; vertical-alignment: center;
                        }
                    }
                    Rectangle {
                        width: 64px; height: 32px;
                        border-radius: Palette.radius;
                        background: add-ta.has-hover ? Palette.primary : Palette.primary-dim;
                        border-width: 1px; border-color: Palette.primary;
                        add-ta := TouchArea {
                            clicked => { root.add-peer(root.pending-node, root.pending-url, tok-field.text); root.pending-node = ""; }
                        }
                        Text { text: "ADD"; color: Palette.text-bright; font-size: 9px; letter-spacing: 1px; font-weight: 700;
                               horizontal-alignment: center; vertical-alignment: center; }
                    }
                }

                // Divider
                HorizontalLayout {
                    spacing: 8px;
                    Rectangle { vertical-stretch: 1; height: 1px; background: Palette.border; y: 8px; }
                    Text { text: "or pair with a code"; color: Palette.text-dim; font-size: 9px; letter-spacing: 1px; }
                    Rectangle { vertical-stretch: 1; height: 1px; background: Palette.border; y: 8px; }
                }

                // Method 2 — enter the 6-digit code shown on the other node (PAIR there).
                HorizontalLayout {
                    spacing: 8px;
                    Rectangle {
                        horizontal-stretch: 1;
                        height: 32px;
                        border-radius: Palette.radius;
                        background: Palette.bg;
                        border-width: 1px;
                        border-color: code-field.has-focus ? Palette.primary : Palette.border;
                        clip: true;
                        code-field := TextInput {
                            x: 10px; width: parent.width - 20px; height: parent.height;
                            vertical-alignment: center; single-line: true;
                            font-size: 14px; letter-spacing: 2px; color: Palette.text;
                            selection-background-color: Palette.primary-dim;
                            accepted => { if (self.text != "") { root.redeem-pairing(root.pending-url, self.text); root.pending-node = ""; } }
                        }
                        if code-field.text == "": Text {
                            x: 10px; text: "6-digit pairing code";
                            color: Palette.text-dim; font-size: 12px; vertical-alignment: center;
                        }
                    }
                    Rectangle {
                        width: 64px; height: 32px;
                        border-radius: Palette.radius;
                        background: pairgo-ta.has-hover ? Palette.primary : Palette.primary-dim;
                        border-width: 1px; border-color: Palette.primary;
                        pairgo-ta := TouchArea {
                            clicked => { if (code-field.text != "") { root.redeem-pairing(root.pending-url, code-field.text); root.pending-node = ""; } }
                        }
                        Text { text: "PAIR"; color: Palette.text-bright; font-size: 9px; letter-spacing: 1px; font-weight: 700;
                               horizontal-alignment: center; vertical-alignment: center; }
                    }
                }

                Rectangle { vertical-stretch: 1; }

                // Cancel
                Rectangle {
                    width: 96px; height: 30px;
                    x: (parent.width - 32px - self.width) / 2;
                    border-radius: Palette.radius;
                    background: cancel-ta.has-hover ? Palette.surface : Palette.surface-hi;
                    border-width: 1px; border-color: Palette.border;
                    cancel-ta := TouchArea { clicked => { root.pending-node = ""; } }
                    Text { text: "CANCEL"; color: Palette.text-dim; font-size: 9px; letter-spacing: 1px;
                           horizontal-alignment: center; vertical-alignment: center; }
                }
            }
        }
    }

    // ── PAIR (host): show this node's code for another node to enter ────────────
    if root.pair-code != "": Rectangle {
        width: 100%;
        height: 100%;
        background: #000000.with-alpha(0.6);
        TouchArea { clicked => { root.pair-code = ""; } }

        // 1-second countdown; clears the offer when it expires.
        Timer {
            interval: 1s;
            running: root.pair-code != "";
            triggered => {
                if (root.pair-remaining > 1) { root.pair-remaining -= 1; }
                else { root.pair-remaining = 0; root.pair-code = ""; }
            }
        }

        Rectangle {
            width: min(parent.width - 32px, 320px);
            height: 196px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: Palette.surface;
            border-radius: Palette.radius;
            border-width: 1px;
            border-color: Palette.primary;
            TouchArea { }

            VerticalLayout {
                padding: 18px;
                spacing: 8px;
                alignment: center;

                Text {
                    text: "MESH PAIRING CODE";
                    color: Palette.text-dim;
                    font-size: 9px;
                    letter-spacing: 2px;
                    horizontal-alignment: center;
                }
                Text {
                    text: root.pair-code;
                    color: Palette.primary;
                    font-size: 40px;
                    font-weight: 800;
                    letter-spacing: 6px;
                    horizontal-alignment: center;
                }
                Text {
                    text: "Enter this on the other node — expires in \{root.pair-remaining}s";
                    color: Palette.text-dim;
                    font-size: 10px;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
                Rectangle {
                    width: 96px; height: 30px;
                    x: (parent.width - 36px - self.width) / 2;
                    border-radius: Palette.radius;
                    background: done-ta.has-hover ? Palette.surface : Palette.surface-hi;
                    border-width: 1px; border-color: Palette.border;
                    done-ta := TouchArea { clicked => { root.pair-code = ""; } }
                    Text { text: "DONE"; color: Palette.text-dim; font-size: 9px; letter-spacing: 1px;
                           horizontal-alignment: center; vertical-alignment: center; }
                }
            }
        }
    }
}
