import { ScrollView } from "std-widgets.slint";
import { Palette } from "../palette.slint";
import { ModelItem, Usage } from "../types.slint";

// ── InferenceView (⚡) ─────────────────────────────────────────────────────────
//
// The inference backend at a glance: which backend serves the agent + its base
// URL (/api/backend), plus a quick model switcher (/api/models + the shared
// set-model callback). A focused fast-swap panel — the full editor lives in
// Settings; this is the "what's running right now" view for the mesh.
//
// preferred/min height 0 so the parent VerticalLayout sizes us via stretch.

export component InferenceView {
    preferred-height: 0px;
    min-height: 0px;

    in property <string>      backend: "—";
    in property <string>      base-url: "";
    in property <[ModelItem]> models;
    in property <string>      current-model;
    in property <Usage>       usage;

    callback refresh();
    callback set-model(string);

    VerticalLayout {
        // ── Header ────────────────────────────────────────────────────────
        Rectangle {
            height: 48px;
            background: Palette.surface;

            HorizontalLayout {
                padding-left: 20px;
                padding-right: 14px;

                Text {
                    text: "INFERENCE";
                    color: Palette.text-dim;
                    font-size: 9px;
                    letter-spacing: 2px;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                Rectangle {
                    width: 72px;
                    height: 28px;
                    border-radius: Palette.radius;
                    background: Palette.surface-hi;
                    border-width: 1px;
                    border-color: Palette.border;
                    y: (parent.height - self.height) / 2;

                    TouchArea { clicked => { root.refresh(); } }

                    Text {
                        text: "REFRESH";
                        color: Palette.text-dim;
                        font-size: 9px;
                        letter-spacing: 1px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        Rectangle { height: 1px; background: Palette.border; }

        // ── Backend info card ────────────────────────────────────────────────
        Rectangle {
            height: card.preferred-height + 24px;
            background: Palette.bg;

            card := HorizontalLayout {
                padding: 16px;
                spacing: 24px;

                VerticalLayout {
                    spacing: 4px;
                    Text {
                        text: "BACKEND";
                        color: Palette.text-dim;
                        font-size: 8px;
                        letter-spacing: 1.5px;
                    }
                    Text {
                        text: root.backend;
                        color: Palette.primary;
                        font-size: 16px;
                        font-weight: 700;
                    }
                }

                VerticalLayout {
                    spacing: 4px;
                    horizontal-stretch: 1;
                    Text {
                        text: "BASE URL";
                        color: Palette.text-dim;
                        font-size: 8px;
                        letter-spacing: 1.5px;
                    }
                    // The stored OAI base URL rides along in the persisted config even
                    // while the anthropic backend is active — showing it there reads as
                    // "anthropic via localhost:11434". Anthropic always talks to its own
                    // API host, so say that instead.
                    Text {
                        text: root.backend == "anthropic" ? "api.anthropic.com"
                            : root.base-url == "" ? "(default)" : root.base-url;
                        color: Palette.text;
                        font-size: 12px;
                        overflow: elide;
                        vertical-alignment: center;
                    }
                }
            }
        }

        Rectangle { height: 1px; background: Palette.border; }

        // ── Cache bank / tokenomics ──────────────────────────────────────────
        // Fed by GET /api/usage (cumulative since daemon boot). The headline is the
        // hit rate + dollars the prompt cache has banked vs re-sending every prefix.
        Rectangle {
            height: bank.preferred-height + 24px;
            background: Palette.bg;

            bank := VerticalLayout {
                padding: 16px;
                spacing: 12px;

                HorizontalLayout {
                    Text {
                        text: "CACHE BANK";
                        color: Palette.text-dim;
                        font-size: 8px;
                        letter-spacing: 1.5px;
                        horizontal-stretch: 1;
                        vertical-alignment: center;
                    }
                    Text {
                        text: root.usage.turns == "" ? "—" : root.usage.turns + " turns";
                        color: Palette.text-dim;
                        font-size: 10px;
                        vertical-alignment: center;
                    }
                }

                // Three headline tiles: hit rate · saved · spent.
                HorizontalLayout {
                    spacing: 10px;

                    Rectangle {
                        horizontal-stretch: 1;
                        height: 58px;
                        border-radius: Palette.radius;
                        background: Palette.surface;
                        border-width: 1px;
                        border-color: Palette.border;
                        VerticalLayout {
                            padding: 8px; spacing: 2px; alignment: center;
                            Text { text: root.usage.hit-rate == "" ? "—" : root.usage.hit-rate; color: Palette.primary; font-size: 18px; font-weight: 700; horizontal-alignment: center; }
                            Text { text: "from cache"; color: Palette.text-dim; font-size: 8px; horizontal-alignment: center; }
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        height: 58px;
                        border-radius: Palette.radius;
                        background: Palette.surface;
                        border-width: 1px;
                        border-color: Palette.border;
                        VerticalLayout {
                            padding: 8px; spacing: 2px; alignment: center;
                            Text { text: root.usage.saved == "" ? "—" : root.usage.saved; color: #34d399; font-size: 18px; font-weight: 700; horizontal-alignment: center; }
                            Text { text: "saved"; color: Palette.text-dim; font-size: 8px; horizontal-alignment: center; }
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        height: 58px;
                        border-radius: Palette.radius;
                        background: Palette.surface;
                        border-width: 1px;
                        border-color: Palette.border;
                        VerticalLayout {
                            padding: 8px; spacing: 2px; alignment: center;
                            Text { text: root.usage.spent == "" ? "—" : root.usage.spent; color: Palette.text; font-size: 18px; font-weight: 700; horizontal-alignment: center; }
                            Text { text: "spent"; color: Palette.text-dim; font-size: 8px; horizontal-alignment: center; }
                        }
                    }
                }

                Text {
                    text: root.usage.banked == "" ? "Tokenomics populate after the first turn." : root.usage.banked + " tokens banked  ·  " + root.usage.detail;
                    color: Palette.text-dim;
                    font-size: 10px;
                    wrap: word-wrap;
                }
            }
        }

        Rectangle { height: 1px; background: Palette.border; }

        // ── Model switcher ───────────────────────────────────────────────────
        // ScrollView (not Flickable): drag-able scrollbar — linuxkms has no
        // scroll-wheel events on the kiosk.
        ScrollView {
            vertical-stretch: 1;
            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
            viewport-width: self.visible-width;
            viewport-height: model-col.preferred-height;

            model-col := VerticalLayout {
                padding: 12px;
                spacing: 6px;
                alignment: start;

                if root.models.length == 0: Text {
                    text: "Tap REFRESH to load models…";
                    color: Palette.text-dim;
                    font-size: 13px;
                    horizontal-alignment: center;
                }

                for m in root.models: Rectangle {
                    height: 44px;
                    border-radius: Palette.radius;
                    background: m.model-id == root.current-model ? Palette.surface-hi : Palette.surface;
                    border-width: 1px;
                    border-color: m.model-id == root.current-model ? Palette.primary : Palette.border;
                    animate border-color { duration: 200ms; }

                    TouchArea {
                        clicked => {
                            if m.model-id != root.current-model { root.set-model(m.model-id); }
                        }
                    }

                    HorizontalLayout {
                        padding-left: 14px;
                        padding-right: 14px;
                        spacing: 10px;

                        Rectangle {
                            width: 3px;
                            border-radius: 2px;
                            background: m.model-id == root.current-model ? Palette.primary : transparent;
                        }

                        Text {
                            text: m.model-name == "" ? m.model-id : m.model-name;
                            color: m.model-id == root.current-model ? Palette.text-bright : Palette.text;
                            font-size: 12px;
                            font-weight: m.model-id == root.current-model ? 700 : 400;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }

                        if m.model-id == root.current-model: Text {
                            text: "ACTIVE";
                            color: Palette.primary;
                            font-size: 9px;
                            font-weight: 700;
                            letter-spacing: 1px;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}
