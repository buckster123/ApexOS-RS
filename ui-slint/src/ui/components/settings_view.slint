import { Palette } from "../palette.slint";
import { Personas } from "../personas.slint";
import { ModelItem } from "../types.slint";
import { PersonaTile } from "persona_picker.slint";

// ── SettingsView ───────────────────────────────────────────────────────────────
//
// Three sections: soul.md editor, policy mode picker, status readout.
// preferred-height / min-height: 0 so parent VerticalLayout doesn't derive
// its layoutinfo from our content — we fill via vertical-stretch.

export component SettingsView {
    preferred-height: 0px;
    min-height: 0px;

    in-out property <string>     soul-text: "";
    in property <string>         policy-mode: "suggest";
    in property <string>         current-model: "";
    in property <bool>           api-key-set: false;
    in property <[ModelItem]>    models;

    callback save-soul(string);
    callback set-policy(string);
    callback set-model(string);
    callback refresh();

    VerticalLayout {
        // ── Header ────────────────────────────────────────────────────────
        Rectangle {
            height: 48px;
            background: Palette.surface;

            HorizontalLayout {
                padding-left: 20px;
                padding-right: 14px;

                Text {
                    text: "SETTINGS";
                    color: Palette.text-dim;
                    font-size: 9px;
                    letter-spacing: 2px;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
            }
        }

        Rectangle { height: 1px; background: Palette.border; }

        // ── Scrollable content ─────────────────────────────────────────────
        // viewport-height MUST be set to the content's preferred height — without
        // it a Flickable sizes its child layout to the visible area, so nothing
        // overflows and nothing scrolls (the soul sub-Flickable below does the same).
        Flickable {
            vertical-stretch: 1;
            interactive: true;
            viewport-height: settings-content.preferred-height;

            settings-content := VerticalLayout {
                padding: 20px;
                spacing: 24px;
                alignment: start;

                // ── Appearance / persona (G5) ──────────────────────────────
                VerticalLayout {
                    spacing: 8px;
                    alignment: start;

                    Text {
                        text: "PERSONA";
                        color: Palette.text-dim;
                        font-size: 9px;
                        letter-spacing: 2px;
                    }

                    for d in Personas.defs: PersonaTile {
                        def: d;
                        selected: d.id == Personas.current-id;
                        clicked => { Personas.pick(d.id); }
                    }
                }

                // ── Soul.md editor ─────────────────────────────────────────
                VerticalLayout {
                    spacing: 8px;
                    alignment: start;

                    Text {
                        text: "SOUL.MD";
                        color: Palette.text-dim;
                        font-size: 9px;
                        letter-spacing: 2px;
                    }

                    Rectangle {
                        height: 240px;
                        border-radius: Palette.radius;
                        background: Palette.surface;
                        border-width: 1px;
                        border-color: Palette.border-hi;
                        clip: true;

                        Flickable {
                            x: 10px; y: 10px;
                            width: parent.width - 20px;
                            height: parent.height - 20px;
                            interactive: true;
                            viewport-height: soul-field.preferred-height + 20px;

                            soul-field := TextInput {
                                width: parent.width;
                                height: self.preferred-height;
                                single-line: false;
                                wrap: TextWrap.word-wrap;
                                font-size: 12px;
                                color: Palette.text;
                                selection-background-color: Palette.primary-dim;
                                selection-foreground-color: Palette.text-bright;
                                text <=> root.soul-text;
                            }
                        }
                    }

                    Rectangle {
                        width: 72px;
                        height: 30px;
                        border-radius: Palette.radius;
                        background: save-area.has-hover ? Palette.primary : Palette.primary-dim;
                        animate background { duration: 150ms; }

                        save-area := TouchArea {
                            clicked => { root.save-soul(root.soul-text); }
                        }

                        Text {
                            text: "SAVE";
                            color: Palette.bg;
                            font-size: 10px;
                            font-weight: 700;
                            letter-spacing: 1px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                // ── Policy mode ────────────────────────────────────────────
                VerticalLayout {
                    spacing: 8px;
                    alignment: start;

                    Text {
                        text: "POLICY MODE";
                        color: Palette.text-dim;
                        font-size: 9px;
                        letter-spacing: 2px;
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        alignment: start;

                        for mode in ["suggest", "auto-edit", "yolo"]: Rectangle {
                            width: 90px;
                            height: 34px;
                            border-radius: Palette.radius;
                            background: root.policy-mode == mode
                                ? Palette.primary-dim
                                : Palette.surface;
                            border-width: 1px;
                            border-color: root.policy-mode == mode
                                ? Palette.primary
                                : Palette.border;
                            animate background   { duration: 150ms; }
                            animate border-color { duration: 150ms; }

                            TouchArea {
                                clicked => { root.set-policy(mode); }
                            }

                            Text {
                                text: mode;
                                color: root.policy-mode == mode
                                    ? Palette.primary
                                    : Palette.text-dim;
                                font-size: 10px;
                                letter-spacing: 0.5px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                animate color { duration: 150ms; }
                            }
                        }
                    }
                }

                // ── Model picker ──────────────────────────────────────────
                VerticalLayout {
                    spacing: 8px;
                    alignment: start;

                    Text {
                        text: "MODEL";
                        color: Palette.text-dim;
                        font-size: 9px;
                        letter-spacing: 2px;
                    }

                    if root.models.length == 0: Text {
                        text: "Loading models…";
                        color: Palette.text-dim;
                        font-size: 12px;
                    }

                    for m in root.models: Rectangle {
                        height: 38px;
                        border-radius: Palette.radius;
                        background: m.model-id == root.current-model
                            ? Palette.primary-dim
                            : Palette.surface;
                        border-width: 1px;
                        border-color: m.model-id == root.current-model
                            ? Palette.primary
                            : Palette.border;
                        animate background   { duration: 150ms; }
                        animate border-color { duration: 150ms; }

                        TouchArea {
                            clicked => { root.set-model(m.model-id); }
                        }

                        HorizontalLayout {
                            padding-left: 14px;
                            padding-right: 14px;
                            spacing: 8px;

                            Text {
                                text: m.model-name;
                                color: m.model-id == root.current-model
                                    ? Palette.text-bright
                                    : Palette.text;
                                font-size: 12px;
                                font-weight: m.model-id == root.current-model ? 700 : 400;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }

                            if m.model-id == root.current-model: Text {
                                text: "active";
                                color: Palette.primary;
                                font-size: 10px;
                                letter-spacing: 0.5px;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // ── Status readout ─────────────────────────────────────────
                VerticalLayout {
                    spacing: 8px;
                    alignment: start;

                    Text {
                        text: "STATUS";
                        color: Palette.text-dim;
                        font-size: 9px;
                        letter-spacing: 2px;
                    }

                    Rectangle {
                        height: 56px;
                        border-radius: Palette.radius;
                        background: Palette.surface;
                        border-width: 1px;
                        border-color: Palette.border;

                        VerticalLayout {
                            padding: 12px;
                            spacing: 6px;
                            alignment: center;

                            Text {
                                text: "Model: " + (root.current-model == "" ? "unknown" : root.current-model);
                                color: Palette.text;
                                font-size: 12px;
                            }

                            Text {
                                text: root.api-key-set
                                    ? "Anthropic API key: set"
                                    : "Anthropic API key: not set";
                                color: root.api-key-set ? Palette.primary : Palette.warning;
                                font-size: 11px;
                            }
                        }
                    }
                }
            }
        }
    }
}
