import { ScrollView } from "std-widgets.slint";
import { Palette } from "../palette.slint";
import { Personas } from "../personas.slint";
import { ModelItem, EndpointItem } from "../types.slint";
import { PersonaTile } from "persona_picker.slint";

// ── SettingsView ───────────────────────────────────────────────────────────────
//
// Three sections: soul.md editor, policy mode picker, status readout.
// preferred-height / min-height: 0 so parent VerticalLayout doesn't derive
// its layoutinfo from our content — we fill via vertical-stretch.

export component SettingsView {
    preferred-height: 0px;
    min-height: 0px;

    // Persona section drawer — collapsed by default so six full tiles don't
    // dominate the settings column; the collapsed face shows the active persona.
    property <bool>              persona-open: false;

    in-out property <string>     soul-text: "";
    in property <string>         policy-mode: "suggest";
    in property <string>         current-model: "";
    in property <bool>           api-key-set: false;
    in property <[ModelItem]>    models;
    // Inference backend (anthropic / openrouter / ollama / custom OAI endpoint),
    // live-swapped + persisted via /api/backend; endpoints from /api/compute/discover.
    in property <string>         backend: "anthropic";
    in property <string>         oai-base-url: "";
    in property <bool>           oai-key-set: false;
    in property <[EndpointItem]> endpoints;
    in property <bool>           scan-busy: false;
    // Prompt-cache policy (Anthropic), live-tuned via /api/cache.
    in property <bool>           cache-enabled: true;
    in property <bool>           cache-conversation: true;
    in property <string>         cache-ttl: "5m";
    // Sensor-alert sensitivity profile (standard / smoker / kitchen / workshop).
    in property <string>         sensor-profile: "standard";
    // Voice backend (auto / local / api / off), live-tuned via /api/voice.
    in property <string>         voice-backend: "auto";
    in property <bool>           voice-api-available: false;
    // Login default-profile (slice 3e): the logged-in human's name ("" for the
    // device-token / admin path) and whether they're this device's auto-login default.
    in property <string>         login-user-name: "";
    in property <bool>           login-is-default: false;

    callback save-soul(string);
    callback set-policy(string);
    callback set-model(string);
    callback set-backend(string);
    // (url, backend-kind) — adopt an endpoint (typed or discovered).
    callback apply-endpoint(string, string);
    callback save-oai-key(string);
    callback scan-compute();
    callback filter-models(string);
    callback set-default-login(bool);
    // (enabled, cache_conversation, ttl) — full desired state each tap.
    callback set-cache(bool, bool, string);
    callback set-sensor-profile(string);
    callback set-voice-backend(string);
    callback refresh();

    VerticalLayout {
        // ── Header ────────────────────────────────────────────────────────
        Rectangle {
            height: 48px;
            background: Palette.surface;

            HorizontalLayout {
                padding-left: 20px;
                padding-right: 14px;

                Text {
                    text: "SETTINGS";
                    color: Palette.text-dim;
                    font-size: 9px;
                    letter-spacing: 2px;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
            }
        }

        Rectangle { height: 1px; background: Palette.border; }

        // ── Scrollable content ─────────────────────────────────────────────
        // ScrollView (std-widgets) auto-manages the viewport from its child layout
        // AND draws a click-draggable scrollbar — more robust than a bare Flickable
        // on a kiosk where wheel/drag events may be flaky.
        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding: 20px;
                spacing: 24px;
                alignment: start;

                // ── Appearance / persona (G5) — collapsed dropdown ─────────
                VerticalLayout {
                    spacing: 8px;
                    alignment: start;

                    Text {
                        text: "PERSONA & UI STYLE";
                        color: Palette.text-dim;
                        font-size: 9px;
                        letter-spacing: 2px;
                    }

                    // Collapsed face: the active persona chip + chevron. The
                    // Personas global derives glyph/name from `current`, so no
                    // catalogue lookup is needed here.
                    Rectangle {
                        height: 48px;
                        border-radius: Palette.radius-lg;
                        background: pface.has-hover ? Palette.surface-hi : Palette.surface;
                        border-width: 1px;
                        border-color: root.persona-open ? Palette.primary : Palette.border;
                        animate background, border-color { duration: 150ms; }

                        pface := TouchArea {
                            clicked => { root.persona-open = !root.persona-open; }
                        }

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 14px;
                            spacing: 12px;

                            Text {
                                text: Personas.glyph;
                                font-size: 18px;
                                width: 24px;
                                color: Palette.primary;
                                vertical-alignment: center;
                                horizontal-alignment: center;
                            }
                            Text {
                                text: Personas.name;
                                font-size: 13px;
                                font-weight: 700;
                                color: Palette.text;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                            Text {
                                text: root.persona-open ? "▴" : "▾";
                                font-size: 12px;
                                color: Palette.text-dim;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Expanded: the full tile list; picking applies + collapses.
                    if root.persona-open: VerticalLayout {
                        spacing: 8px;

                        for d in Personas.defs: PersonaTile {
                            def: d;
                            selected: d.id == Personas.current-id;
                            clicked => {
                                Personas.pick(d.id);
                                root.persona-open = false;
                            }
                        }
                    }
                }

                // ── Soul.md editor ─────────────────────────────────────────
                VerticalLayout {
                    spacing: 8px;
                    alignment: start;

                    Text {
                        text: "SOUL.MD";
                        color: Palette.text-dim;
                        font-size: 9px;
                        letter-spacing: 2px;
                    }

                    Rectangle {
                        height: 240px;
                        border-radius: Palette.radius;
                        background: Palette.surface;
                        border-width: 1px;
                        border-color: Palette.border-hi;
                        clip: true;

                        // ScrollView (not Flickable): drag-able scrollbar for a
                        // long soul.md — linuxkms has no scroll-wheel on the kiosk.
                        ScrollView {
                            x: 10px; y: 10px;
                            width: parent.width - 20px;
                            height: parent.height - 20px;
                            horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                            viewport-width: self.visible-width;
                            viewport-height: soul-field.preferred-height + 20px;

                            soul-field := TextInput {
                                width: parent.width;
                                height: self.preferred-height;
                                single-line: false;
                                wrap: TextWrap.word-wrap;
                                font-size: 12px;
                                color: Palette.text;
                                selection-background-color: Palette.primary-dim;
                                selection-foreground-color: Palette.text-bright;
                                text <=> root.soul-text;
                            }
                        }
                    }

                    Rectangle {
                        width: 72px;
                        height: 30px;
                        border-radius: Palette.radius;
                        background: save-area.has-hover ? Palette.primary : Palette.primary-dim;
                        animate background { duration: 150ms; }

                        save-area := TouchArea {
                            clicked => { root.save-soul(root.soul-text); }
                        }

                        Text {
                            text: "SAVE";
                            color: Palette.bg;
                            font-size: 10px;
                            font-weight: 700;
                            letter-spacing: 1px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                // ── Policy mode ────────────────────────────────────────────
                VerticalLayout {
                    spacing: 8px;
                    alignment: start;

                    Text {
                        text: "POLICY MODE";
                        color: Palette.text-dim;
                        font-size: 9px;
                        letter-spacing: 2px;
                    }

                    HorizontalLayout {
                        spacing: 8px;
                        alignment: start;

                        for mode in ["suggest", "auto-edit", "yolo"]: Rectangle {
                            width: 90px;
                            height: 34px;
                            border-radius: Palette.radius;
                            background: root.policy-mode == mode
                                ? Palette.primary-dim
                                : Palette.surface;
                            border-width: 1px;
                            border-color: root.policy-mode == mode
                                ? Palette.primary
                                : Palette.border;
                            animate background   { duration: 150ms; }
                            animate border-color { duration: 150ms; }

                            TouchArea {
                                clicked => { root.set-policy(mode); }
                            }

                            Text {
                                text: mode;
                                color: root.policy-mode == mode
                                    ? Palette.primary
                                    : Palette.text-dim;
                                font-size: 10px;
                                letter-spacing: 0.5px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                animate color { duration: 150ms; }
                            }
                        }
                    }
                }

                // ── Inference backend ─────────────────────────────────────
                // Chips swap the provider live (persisted server-side); OLLAMA /
                // CUSTOM take an endpoint URL; SCAN sweeps the LAN for compute.
                VerticalLayout {
                    spacing: 8px;
                    alignment: start;

                    Text {
                        text: "INFERENCE BACKEND";
                        color: Palette.text-dim;
                        font-size: 9px;
                        letter-spacing: 2px;
                    }

                    HorizontalLayout {
                        spacing: 6px;
                        alignment: start;
                        for opt in ["anthropic", "openrouter", "ollama", "custom"]: Rectangle {
                            width: 92px;
                            height: 32px;
                            border-radius: Palette.radius;
                            background: (root.backend == opt || (opt == "custom" && (root.backend == "oai" || root.backend == "vllm")))
                                ? Palette.primary-dim : Palette.surface;
                            border-width: 1px;
                            border-color: (root.backend == opt || (opt == "custom" && (root.backend == "oai" || root.backend == "vllm")))
                                ? Palette.primary : Palette.border;
                            animate background   { duration: 150ms; }
                            animate border-color { duration: 150ms; }
                            TouchArea {
                                clicked => { root.set-backend(opt == "custom" ? "oai" : opt); }
                            }
                            Text {
                                text: opt;
                                color: (root.backend == opt || (opt == "custom" && (root.backend == "oai" || root.backend == "vllm")))
                                    ? Palette.primary : Palette.text-dim;
                                font-size: 9px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Endpoint URL — editable for local/custom backends; openrouter
                    // is canonical (server pins it), anthropic doesn't use one.
                    if root.backend == "openrouter": Text {
                        text: "endpoint: openrouter.ai/api/v1 · key " + (root.oai-key-set ? "set ✓" : "NOT SET — enter below");
                        color: root.oai-key-set ? Palette.text-dim : Palette.warning;
                        font-size: 10px;
                    }
                    if root.backend != "anthropic" && root.backend != "openrouter": HorizontalLayout {
                        spacing: 6px;
                        Rectangle {
                            height: 32px;
                            horizontal-stretch: 1;
                            border-radius: Palette.radius;
                            background: Palette.surface;
                            border-width: 1px;
                            border-color: Palette.border;
                            url-input := TextInput {
                                x: 10px;
                                width: parent.width - 20px;
                                height: parent.height;
                                vertical-alignment: center;
                                single-line: true;
                                font-size: 11px;
                                color: Palette.text;
                                selection-background-color: Palette.primary-dim;
                                accepted => { if (self.text != "") { root.apply-endpoint(self.text, root.backend); } }
                            }
                            if url-input.text == "": Text {
                                x: 10px;
                                text: root.oai-base-url == "" ? "http://host:11434/v1" : root.oai-base-url;
                                color: Palette.text-dim;
                                font-size: 11px;
                                vertical-alignment: center;
                            }
                        }
                        Rectangle {
                            width: 64px;
                            height: 32px;
                            border-radius: Palette.radius;
                            background: Palette.surface;
                            border-width: 1px;
                            border-color: Palette.border;
                            TouchArea {
                                clicked => { if (url-input.text != "") { root.apply-endpoint(url-input.text, root.backend); } }
                            }
                            Text {
                                text: "APPLY";
                                color: Palette.text-dim;
                                font-size: 9px;
                                letter-spacing: 1px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // OAI/OpenRouter key entry — POST /api/keys, masked, cleared on save.
                    if root.backend != "anthropic": HorizontalLayout {
                        spacing: 6px;
                        Rectangle {
                            height: 32px;
                            horizontal-stretch: 1;
                            border-radius: Palette.radius;
                            background: Palette.surface;
                            border-width: 1px;
                            border-color: Palette.border;
                            key-input := TextInput {
                                x: 10px;
                                width: parent.width - 20px;
                                height: parent.height;
                                vertical-alignment: center;
                                single-line: true;
                                input-type: password;
                                font-size: 11px;
                                color: Palette.text;
                                selection-background-color: Palette.primary-dim;
                                accepted => { if (self.text != "") { root.save-oai-key(self.text); self.text = ""; } }
                            }
                            if key-input.text == "": Text {
                                x: 10px;
                                text: root.oai-key-set ? "API key (set ✓ — paste to replace)" : "API key (sk-or-…)";
                                color: Palette.text-dim;
                                font-size: 11px;
                                vertical-alignment: center;
                            }
                        }
                        Rectangle {
                            width: 64px;
                            height: 32px;
                            border-radius: Palette.radius;
                            background: Palette.surface;
                            border-width: 1px;
                            border-color: Palette.border;
                            TouchArea {
                                clicked => { if (key-input.text != "") { root.save-oai-key(key-input.text); key-input.text = ""; } }
                            }
                            Text {
                                text: "SAVE";
                                color: Palette.text-dim;
                                font-size: 9px;
                                letter-spacing: 1px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // LAN compute discovery — operator-triggered sweep (a few seconds).
                    Rectangle {
                        height: 34px;
                        border-radius: Palette.radius;
                        background: root.scan-busy ? Palette.primary-dim : Palette.surface;
                        border-width: 1px;
                        border-color: root.scan-busy ? Palette.primary : Palette.border;
                        TouchArea {
                            clicked => { if (!root.scan-busy) { root.scan-compute(); } }
                        }
                        Text {
                            text: root.scan-busy ? "SCANNING LAN FOR COMPUTE…" : "⌖ SCAN NETWORK FOR COMPUTE";
                            color: root.scan-busy ? Palette.primary : Palette.text-dim;
                            font-size: 10px;
                            letter-spacing: 1px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    for e in root.endpoints: Rectangle {
                        height: 38px;
                        border-radius: Palette.radius;
                        background: root.oai-base-url == e.url ? Palette.primary-dim : Palette.surface;
                        border-width: 1px;
                        border-color: root.oai-base-url == e.url ? Palette.primary : Palette.border;
                        TouchArea {
                            clicked => { root.apply-endpoint(e.url, e.kind == "ollama" ? "ollama" : "oai"); }
                        }
                        HorizontalLayout {
                            padding-left: 14px;
                            padding-right: 14px;
                            spacing: 8px;
                            Text {
                                text: e.host + " · " + e.kind;
                                color: root.oai-base-url == e.url ? Palette.text-bright : Palette.text;
                                font-size: 12px;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                            Text {
                                text: e.model-count == 1 ? "1 model" : e.model-count + " models";
                                color: Palette.text-dim;
                                font-size: 10px;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // ── Model picker ──────────────────────────────────────────
                VerticalLayout {
                    spacing: 8px;
                    alignment: start;

                    Text {
                        text: "MODEL";
                        color: Palette.text-dim;
                        font-size: 9px;
                        letter-spacing: 2px;
                    }

                    // Filter — an OAI catalog (OpenRouter: hundreds) needs narrowing;
                    // Rust filters the cached full list and repopulates `models`.
                    if root.models.length >= 13 || root.backend == "openrouter": Rectangle {
                        height: 32px;
                        border-radius: Palette.radius;
                        background: Palette.surface;
                        border-width: 1px;
                        border-color: Palette.border;
                        filter-input := TextInput {
                            x: 10px;
                            width: parent.width - 20px;
                            height: parent.height;
                            vertical-alignment: center;
                            single-line: true;
                            font-size: 11px;
                            color: Palette.text;
                            selection-background-color: Palette.primary-dim;
                            edited => { root.filter-models(self.text); }
                        }
                        if filter-input.text == "": Text {
                            x: 10px;
                            text: "filter models… (e.g. qwen, gemma)";
                            color: Palette.text-dim;
                            font-size: 11px;
                            vertical-alignment: center;
                        }
                    }

                    if root.models.length == 0: Text {
                        text: "Loading models…";
                        color: Palette.text-dim;
                        font-size: 12px;
                    }

                    for m in root.models: Rectangle {
                        height: 38px;
                        border-radius: Palette.radius;
                        background: m.model-id == root.current-model
                            ? Palette.primary-dim
                            : Palette.surface;
                        border-width: 1px;
                        border-color: m.model-id == root.current-model
                            ? Palette.primary
                            : Palette.border;
                        animate background   { duration: 150ms; }
                        animate border-color { duration: 150ms; }

                        TouchArea {
                            clicked => { root.set-model(m.model-id); }
                        }

                        HorizontalLayout {
                            padding-left: 14px;
                            padding-right: 14px;
                            spacing: 8px;

                            Text {
                                text: m.model-name;
                                color: m.model-id == root.current-model
                                    ? Palette.text-bright
                                    : Palette.text;
                                font-size: 12px;
                                font-weight: m.model-id == root.current-model ? 700 : 400;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }

                            if m.model-id == root.current-model: Text {
                                text: "active";
                                color: Palette.primary;
                                font-size: 10px;
                                letter-spacing: 0.5px;
                                vertical-alignment: center;
                            }
                        }
                    }

                    // Exact model id escape hatch — anything the picker doesn't list.
                    HorizontalLayout {
                        spacing: 6px;
                        Rectangle {
                            height: 32px;
                            horizontal-stretch: 1;
                            border-radius: Palette.radius;
                            background: Palette.surface;
                            border-width: 1px;
                            border-color: Palette.border;
                            custom-model-input := TextInput {
                                x: 10px;
                                width: parent.width - 20px;
                                height: parent.height;
                                vertical-alignment: center;
                                single-line: true;
                                font-size: 11px;
                                color: Palette.text;
                                selection-background-color: Palette.primary-dim;
                                accepted => { if (self.text != "") { root.set-model(self.text); self.text = ""; } }
                            }
                            if custom-model-input.text == "": Text {
                                x: 10px;
                                text: "custom model id…";
                                color: Palette.text-dim;
                                font-size: 11px;
                                vertical-alignment: center;
                            }
                        }
                        Rectangle {
                            width: 64px;
                            height: 32px;
                            border-radius: Palette.radius;
                            background: Palette.surface;
                            border-width: 1px;
                            border-color: Palette.border;
                            TouchArea {
                                clicked => { if (custom-model-input.text != "") { root.set-model(custom-model-input.text); custom-model-input.text = ""; } }
                            }
                            Text {
                                text: "SET";
                                color: Palette.text-dim;
                                font-size: 9px;
                                letter-spacing: 1px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // ── Prompt cache (Anthropic) ───────────────────────────────
                VerticalLayout {
                    spacing: 12px;
                    alignment: start;

                    Text {
                        text: "PROMPT CACHE";
                        color: Palette.text-dim;
                        font-size: 9px;
                        letter-spacing: 2px;
                    }

                    // Master on/off.
                    VerticalLayout {
                        spacing: 6px;
                        Text { text: "Caching"; color: Palette.text-dim; font-size: 10px; }
                        HorizontalLayout {
                            spacing: 8px;
                            alignment: start;
                            for opt in ["on", "off"]: Rectangle {
                                width: 70px;
                                height: 32px;
                                border-radius: Palette.radius;
                                background: (root.cache-enabled ? "on" : "off") == opt ? Palette.primary-dim : Palette.surface;
                                border-width: 1px;
                                border-color: (root.cache-enabled ? "on" : "off") == opt ? Palette.primary : Palette.border;
                                animate background   { duration: 150ms; }
                                animate border-color { duration: 150ms; }
                                TouchArea {
                                    clicked => { root.set-cache(opt == "on", root.cache-conversation, root.cache-ttl); }
                                }
                                Text {
                                    text: opt;
                                    color: (root.cache-enabled ? "on" : "off") == opt ? Palette.primary : Palette.text-dim;
                                    font-size: 10px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    // Cache the growing conversation too (the long-session win).
                    VerticalLayout {
                        spacing: 6px;
                        opacity: root.cache-enabled ? 1.0 : 0.4;
                        Text { text: "Cache conversation"; color: Palette.text-dim; font-size: 10px; }
                        HorizontalLayout {
                            spacing: 8px;
                            alignment: start;
                            for opt in ["on", "off"]: Rectangle {
                                width: 70px;
                                height: 32px;
                                border-radius: Palette.radius;
                                background: (root.cache-conversation ? "on" : "off") == opt ? Palette.primary-dim : Palette.surface;
                                border-width: 1px;
                                border-color: (root.cache-conversation ? "on" : "off") == opt ? Palette.primary : Palette.border;
                                animate background   { duration: 150ms; }
                                animate border-color { duration: 150ms; }
                                TouchArea {
                                    clicked => { root.set-cache(root.cache-enabled, opt == "on", root.cache-ttl); }
                                }
                                Text {
                                    text: opt;
                                    color: (root.cache-conversation ? "on" : "off") == opt ? Palette.primary : Palette.text-dim;
                                    font-size: 10px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    // TTL — 1h survives >5min pauses without re-writing the prefix.
                    VerticalLayout {
                        spacing: 6px;
                        opacity: root.cache-enabled ? 1.0 : 0.4;
                        Text { text: "TTL"; color: Palette.text-dim; font-size: 10px; }
                        HorizontalLayout {
                            spacing: 8px;
                            alignment: start;
                            for opt in ["5m", "1h"]: Rectangle {
                                width: 70px;
                                height: 32px;
                                border-radius: Palette.radius;
                                background: root.cache-ttl == opt ? Palette.primary-dim : Palette.surface;
                                border-width: 1px;
                                border-color: root.cache-ttl == opt ? Palette.primary : Palette.border;
                                animate background   { duration: 150ms; }
                                animate border-color { duration: 150ms; }
                                TouchArea {
                                    clicked => { root.set-cache(root.cache-enabled, root.cache-conversation, opt); }
                                }
                                Text {
                                    text: opt;
                                    color: root.cache-ttl == opt ? Palette.primary : Palette.text-dim;
                                    font-size: 10px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    Text {
                        text: "Caches the soul + tools + conversation prefix (Anthropic only). Conversation caching is the big win on long sessions; 1h TTL survives pauses without re-writing.";
                        color: Palette.text-dim;
                        font-size: 10px;
                        wrap: word-wrap;
                    }
                }

                // ── Sensor alerts ──────────────────────────────────────────
                VerticalLayout {
                    spacing: 8px;
                    alignment: start;

                    Text {
                        text: "SENSOR ALERTS";
                        color: Palette.text-dim;
                        font-size: 9px;
                        letter-spacing: 2px;
                    }

                    VerticalLayout {
                        spacing: 6px;
                        Text { text: "Sensitivity profile"; color: Palette.text-dim; font-size: 10px; }
                        HorizontalLayout {
                            spacing: 6px;
                            alignment: start;
                            for opt in ["standard", "smoker", "kitchen", "workshop"]: Rectangle {
                                width: 84px;
                                height: 32px;
                                border-radius: Palette.radius;
                                background: root.sensor-profile == opt ? Palette.primary-dim : Palette.surface;
                                border-width: 1px;
                                border-color: root.sensor-profile == opt ? Palette.primary : Palette.border;
                                animate background   { duration: 150ms; }
                                animate border-color { duration: 150ms; }
                                TouchArea {
                                    clicked => { root.set-sensor-profile(opt); }
                                }
                                Text {
                                    text: opt;
                                    color: root.sensor-profile == opt ? Palette.primary : Palette.text-dim;
                                    font-size: 9px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    Text {
                        text: "Raises the air-quality + thermal alert floor for a noisy environment so routine activity (a cigarette, cooking, soldering) doesn't trigger an autonomous alert — a sustained, hotter real event still does.";
                        color: Palette.text-dim;
                        font-size: 10px;
                        wrap: word-wrap;
                    }
                }

                // ── Voice backend ──────────────────────────────────────────
                VerticalLayout {
                    spacing: 8px;
                    alignment: start;

                    Text {
                        text: "VOICE";
                        color: Palette.text-dim;
                        font-size: 9px;
                        letter-spacing: 2px;
                    }

                    VerticalLayout {
                        spacing: 6px;
                        Text { text: "Speech backend (TTS + STT)"; color: Palette.text-dim; font-size: 10px; }
                        HorizontalLayout {
                            spacing: 6px;
                            alignment: start;
                            for opt in ["auto", "local", "api", "off"]: Rectangle {
                                width: 84px;
                                height: 32px;
                                border-radius: Palette.radius;
                                background: root.voice-backend == opt ? Palette.primary-dim : Palette.surface;
                                border-width: 1px;
                                border-color: root.voice-backend == opt ? Palette.primary : Palette.border;
                                animate background   { duration: 150ms; }
                                animate border-color { duration: 150ms; }
                                TouchArea {
                                    clicked => { root.set-voice-backend(opt); }
                                }
                                Text {
                                    text: opt;
                                    color: root.voice-backend == opt ? Palette.primary : Palette.text-dim;
                                    font-size: 9px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }

                    Text {
                        text: root.voice-api-available
                            ? "local = on-device Kokoro/Whisper (offline, free). api = cloud (ElevenLabs/OpenAI) for more natural voice on light devices. auto = local first, then api. A cloud API key is configured."
                            : "local = on-device Kokoro/Whisper (offline, free). api = cloud (needs an ElevenLabs/OpenAI key in /etc/agentd/env — none set yet). auto = local first, then api. off = silent.";
                        color: Palette.text-dim;
                        font-size: 10px;
                        wrap: word-wrap;
                    }
                }

                // ── Login (default profile / auto-skip) ────────────────────
                VerticalLayout {
                    spacing: 8px;
                    alignment: start;

                    Text {
                        text: "LOGIN";
                        color: Palette.text-dim;
                        font-size: 9px;
                        letter-spacing: 2px;
                    }

                    if root.login-user-name != "": VerticalLayout {
                        spacing: 6px;
                        Text {
                            text: "Auto-login as " + root.login-user-name + " on launch";
                            color: Palette.text-dim;
                            font-size: 10px;
                        }
                        HorizontalLayout {
                            spacing: 8px;
                            alignment: start;
                            for opt in ["on", "off"]: Rectangle {
                                width: 70px;
                                height: 32px;
                                border-radius: Palette.radius;
                                background: (root.login-is-default ? "on" : "off") == opt ? Palette.primary-dim : Palette.surface;
                                border-width: 1px;
                                border-color: (root.login-is-default ? "on" : "off") == opt ? Palette.primary : Palette.border;
                                animate background   { duration: 150ms; }
                                animate border-color { duration: 150ms; }
                                TouchArea {
                                    clicked => { root.set-default-login(opt == "on"); }
                                }
                                Text {
                                    text: opt;
                                    color: (root.login-is-default ? "on" : "off") == opt ? Palette.primary : Palette.text-dim;
                                    font-size: 10px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        Text {
                            text: "Skip the profile picker on this device. An open profile logs in with zero taps; a PIN profile jumps straight to the keypad (‹ Back still reaches the picker).";
                            color: Palette.text-dim;
                            font-size: 10px;
                            wrap: word-wrap;
                        }
                    }

                    if root.login-user-name == "": Text {
                        text: "Signed in with the device token — per-profile auto-login applies to human (session-token) logins.";
                        color: Palette.text-dim;
                        font-size: 10px;
                        wrap: word-wrap;
                    }
                }

                // ── Status readout ─────────────────────────────────────────
                VerticalLayout {
                    spacing: 8px;
                    alignment: start;

                    Text {
                        text: "STATUS";
                        color: Palette.text-dim;
                        font-size: 9px;
                        letter-spacing: 2px;
                    }

                    Rectangle {
                        height: 56px;
                        border-radius: Palette.radius;
                        background: Palette.surface;
                        border-width: 1px;
                        border-color: Palette.border;

                        VerticalLayout {
                            padding: 12px;
                            spacing: 6px;
                            alignment: center;

                            Text {
                                text: "Model: " + (root.current-model == "" ? "unknown" : root.current-model);
                                color: Palette.text;
                                font-size: 12px;
                            }

                            Text {
                                text: root.api-key-set
                                    ? "Anthropic API key: set"
                                    : "Anthropic API key: not set";
                                color: root.api-key-set ? Palette.primary : Palette.warning;
                                font-size: 11px;
                            }
                        }
                    }
                }
            }
        }
    }
}
