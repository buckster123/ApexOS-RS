import { ScrollView } from "std-widgets.slint";
import { Palette } from "../palette.slint";
import { ExplorerEntry, UsbCandidate } from "../types.slint";

// ── ExplorerView (📁 Files) ─────────────────────────────────────────────────
//
// A real workspace file explorer: navigate directories, preview files, AND the
// file verbs — new folder, rename, delete, and cut/copy → paste (move/copy,
// incl. drive⇄workspace across the mounted exo-workspace sticks under media/).
// Left pane = the entry list (dirs first) + an action row; right pane = a preview
// (image / text / info). Reads /api/workspace/{list,read}; writes go through the
// confined /api/workspace/{mkdir,rename,delete,move,copy} endpoints in Rust.
// The clipboard + the three overlays (entry menu, name prompt, delete confirm)
// are view-local; only the network verbs cross into Rust.
//
// preferred/min height 0 so the parent VerticalLayout sizes us via stretch.

// A small button used in the action row and the entry-action menu.
component ExpBtn inherits Rectangle {
    in property <string> label;
    in property <bool> danger: false;
    in property <bool> strong: false;
    callback clicked();
    height: 28px;
    border-radius: Palette.radius;
    background: ta.has-hover ? (root.danger ? #ef4444 : (root.strong ? Palette.primary : Palette.surface-hi))
              : (root.strong ? Palette.primary-dim : Palette.bg);
    border-width: 1px;
    border-color: root.danger ? #ef444477 : (root.strong ? Palette.primary : Palette.border);
    animate background { duration: 120ms; }
    ta := TouchArea { clicked => { root.clicked(); } }
    Text {
        text: root.label;
        color: (root.danger && ta.has-hover) || root.strong ? Palette.bg : Palette.text;
        font-size: 10px;
        font-weight: root.strong ? 700 : 400;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

export component ExplorerView {
    preferred-height: 0px;
    min-height: 0px;

    in property <[ExplorerEntry]> entries;
    in property <string> current-path;    // "" = workspace root
    in property <string> selected-path;   // selected file ("" = none)
    in property <string> selected-name;
    in property <string> selected-info;   // "PNG · 1.2 KB"
    in property <string> preview-kind;    // "image" | "text" | "binary" | "none"
    in property <image>  preview-image;
    in property <string> preview-text;
    in property <bool>   can-attach;      // selected is an image

    // Clipboard (view-local): the cut/copied entry, awaiting a paste.
    in-out property <string> clip-path: "";
    in-out property <string> clip-name: "";
    in-out property <string> clip-mode: "";   // "cut" | "copy" | ""

    // Per-entry action menu (view-local overlay).
    property <bool>   menu-open: false;
    property <string> menu-path: "";
    property <string> menu-name: "";

    // Name prompt — shared by New-folder + Rename (view-local overlay).
    property <bool>   name-open: false;
    property <string> name-mode: "";       // "mkdir" | "rename"
    property <string> name-title: "";
    in-out property <string> name-value: "";
    property <string> name-target: "";     // path being renamed

    // Delete confirm (view-local overlay).
    property <bool>   del-open: false;
    property <string> del-path: "";
    property <string> del-name: "";

    // "Use this drive" picker (adopt a USB stick as an exo-workspace). The candidate
    // list + busy/result are Rust-driven; the open/selection/name form is view-local.
    in property <[UsbCandidate]> drive-candidates;
    in property <bool>   drive-busy;       // true while the (≤25s) prep runs
    in property <string> drive-result;     // "" | "ok" | "err: …" (Rust sets; "ok" auto-closes)
    property <bool>   drive-open: false;
    property <string> drive-selected-dev: "";
    in-out property <string> drive-name: "";

    callback refresh();
    callback navigate(string);            // enter dir (rel path)
    callback up();                        // parent dir
    callback select(string, string, string);   // path, abs, ext
    callback attach();                    // attach selected image to chat
    callback eject(string);               // safe-eject an exo-workspace stick (label)
    callback mkdir(string);               // create a folder (name) in the current dir
    callback rename(string, string);      // path, new-name
    callback delete-entry(string);        // path
    callback paste(string, string);       // src-path, mode ("cut"|"copy") → into current dir
    callback drive-scan();                // (re)list adoptable USB sticks → drive-candidates
    callback drive-prep(string, string);  // dev, name → relabel + adopt as exo-workspace

    // Rust signals a finished prep via drive-result; "ok" closes the picker + resets it.
    changed drive-result => {
        if (root.drive-result == "ok") {
            root.drive-open = false;
            root.drive-name = "";
            root.drive-selected-dev = "";
        }
    }

    // Open the name prompt in "new folder" mode.
    function open-mkdir() {
        root.menu-open = false;
        root.name-mode = "mkdir";
        root.name-title = "New folder";
        root.name-value = "";
        root.name-target = "";
        root.name-open = true;
    }
    // Open the name prompt in "rename" mode for a given entry.
    function open-rename(p: string, n: string) {
        root.menu-open = false;
        root.name-mode = "rename";
        root.name-title = "Rename";
        root.name-value = n;
        root.name-target = p;
        root.name-open = true;
    }
    // Confirm the name prompt (Create / Rename).
    function commit-name() {
        if (root.name-value == "") { return; }
        if (root.name-mode == "mkdir") {
            root.mkdir(root.name-value);
        } else if (root.name-mode == "rename") {
            root.rename(root.name-target, root.name-value);
        }
        root.name-open = false;
        root.name-value = "";
    }

    HorizontalLayout {
        // ── Left: entry list ─────────────────────────────────────────────────
        Rectangle {
            width: 260px;
            background: Palette.surface;

            VerticalLayout {
                // Header: up · path · refresh
                Rectangle {
                    height: 48px;
                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 10px;
                        spacing: 6px;

                        Rectangle {
                            width: 28px;
                            height: 28px;
                            border-radius: Palette.radius;
                            background: up-ta.has-hover ? Palette.surface-hi : Palette.bg;
                            border-width: 1px;
                            border-color: Palette.border;
                            y: (parent.height - self.height) / 2;
                            Text {
                                text: "↑";
                                color: Palette.text-dim;
                                font-size: 14px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            up-ta := TouchArea { clicked => { root.up(); } }
                        }

                        Text {
                            text: root.current-path == "" ? "workspace" : root.current-path;
                            color: Palette.text-bright;
                            font-size: 11px;
                            font-weight: 700;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            overflow: elide;
                        }

                        Rectangle {
                            width: 28px;
                            height: 28px;
                            border-radius: Palette.radius;
                            background: rf-ta.has-hover ? Palette.surface-hi : Palette.bg;
                            border-width: 1px;
                            border-color: Palette.border;
                            y: (parent.height - self.height) / 2;
                            Text {
                                text: "⟳";
                                color: Palette.text-dim;
                                font-size: 13px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            rf-ta := TouchArea { clicked => { root.refresh(); } }
                        }
                    }
                }

                Rectangle { height: 1px; background: Palette.border; }

                // Action row: new folder + paste (paste shows only with a clipboard).
                Rectangle {
                    height: 40px;
                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 8px;
                        padding-top: 6px;
                        padding-bottom: 6px;
                        spacing: 6px;

                        ExpBtn {
                            label: "+ Folder";
                            horizontal-stretch: 1;
                            clicked => { root.open-mkdir(); }
                        }
                        if root.clip-path != "": ExpBtn {
                            label: (root.clip-mode == "cut" ? "Move ▸ " : "Paste ▸ ") + root.clip-name;
                            strong: true;
                            horizontal-stretch: 2;
                            clicked => {
                                root.paste(root.clip-path, root.clip-mode);
                                // Cut empties the clipboard; copy stays for paste-to-many.
                                if (root.clip-mode == "cut") {
                                    root.clip-path = ""; root.clip-name = ""; root.clip-mode = "";
                                }
                            }
                        }
                        if root.clip-path != "": ExpBtn {
                            label: "✕";
                            width: 28px;
                            clicked => { root.clip-path = ""; root.clip-name = ""; root.clip-mode = ""; }
                        }
                    }
                }

                // "Use this drive" — adopt a plugged USB stick as an exo-workspace,
                // no CLI. Full-width + plainly labelled for non-technical users.
                Rectangle {
                    height: 38px;
                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 8px;
                        padding-bottom: 6px;
                        ExpBtn {
                            label: "🔌  Use a USB drive";
                            horizontal-stretch: 1;
                            clicked => {
                                root.drive-selected-dev = "";
                                root.drive-name = "";
                                root.drive-open = true;
                                root.drive-scan();
                            }
                        }
                    }
                }

                Rectangle { height: 1px; background: Palette.border; }

                // ScrollView (not Flickable): drag-able scrollbar — linuxkms has
                // no scroll-wheel events on the kiosk.
                ScrollView {
                    vertical-stretch: 1;
                    horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                    viewport-width: self.visible-width;
                    viewport-height: list-col.preferred-height;

                    list-col := VerticalLayout {
                        padding: 6px;
                        spacing: 3px;
                        alignment: start;

                        if root.entries.length == 0: Text {
                            text: "Empty folder.";
                            color: Palette.text-dim;
                            font-size: 12px;
                            horizontal-alignment: center;
                        }

                        for e in root.entries: Rectangle {
                            height: 34px;
                            border-radius: Palette.radius;
                            background: e.path == root.selected-path ? Palette.surface-hi
                                      : (row-ta.has-hover ? Palette.surface-hi : transparent);
                            border-width: 1px;
                            border-color: e.path == root.selected-path ? Palette.primary
                                        : (e.path == root.clip-path ? Palette.primary-dim : transparent);
                            row-ta := TouchArea {
                                clicked => {
                                    if (e.kind == "dir") {
                                        root.navigate(e.path);
                                    } else {
                                        root.select(e.path, e.abs, e.ext);
                                    }
                                }
                            }
                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 6px;
                                spacing: 8px;
                                Text {
                                    text: e.glyph;
                                    font-size: 14px;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: e.name;
                                    color: e.path == root.clip-path && root.clip-mode == "cut"
                                         ? Palette.text-dim : Palette.text;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                    overflow: elide;
                                }
                                Text {
                                    text: e.size-label;
                                    color: Palette.text-dim;
                                    font-size: 9px;
                                    vertical-alignment: center;
                                }
                                // Trailing affordance. A mounted exo-workspace stick
                                // (a dir directly under media/) gets the eject ⏏; every
                                // other entry gets the ⋮ action menu (rename/cut/copy/
                                // delete). The row's own TouchArea handles nav/select;
                                // these nested ones intercept.
                                if root.current-path == "media" && e.kind == "dir": Rectangle {
                                    width: 24px;
                                    height: 24px;
                                    border-radius: Palette.radius;
                                    background: ej-ta.has-hover ? Palette.surface-hi : transparent;
                                    Text {
                                        text: "⏏";
                                        color: ej-ta.has-hover ? Palette.primary : Palette.text-dim;
                                        font-size: 13px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                    ej-ta := TouchArea { clicked => { root.eject(e.name); } }
                                }
                                if !(root.current-path == "media" && e.kind == "dir"): Rectangle {
                                    width: 24px;
                                    height: 24px;
                                    border-radius: Palette.radius;
                                    background: mn-ta.has-hover ? Palette.surface-hi : transparent;
                                    Text {
                                        text: "⋮";
                                        color: mn-ta.has-hover ? Palette.primary : Palette.text-dim;
                                        font-size: 15px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                    mn-ta := TouchArea {
                                        clicked => {
                                            root.menu-path = e.path;
                                            root.menu-name = e.name;
                                            root.menu-open = true;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }

        Rectangle { width: 1px; background: Palette.border; }

        // ── Right: preview ────────────────────────────────────────────────────
        Rectangle {
            horizontal-stretch: 1;
            background: Palette.bg;

            VerticalLayout {
                // Preview header: name/info + Attach (images only)
                Rectangle {
                    height: 48px;
                    background: Palette.surface;
                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 12px;
                        spacing: 8px;

                        VerticalLayout {
                            alignment: center;
                            horizontal-stretch: 1;
                            Text {
                                text: root.selected-name == "" ? "— no file selected —" : root.selected-name;
                                color: root.selected-name == "" ? Palette.text-dim : Palette.text-bright;
                                font-size: 12px;
                                font-weight: 700;
                                overflow: elide;
                            }
                            if root.selected-info != "": Text {
                                text: root.selected-info;
                                color: Palette.text-dim;
                                font-size: 9px;
                            }
                        }

                        if root.can-attach: Rectangle {
                            width: 104px;
                            height: 30px;
                            border-radius: Palette.radius;
                            background: at-ta.has-hover ? Palette.primary : Palette.primary-dim;
                            animate background { duration: 150ms; }
                            y: (parent.height - self.height) / 2;
                            Text {
                                text: "🖼 Attach";
                                color: Palette.bg;
                                font-size: 11px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                            at-ta := TouchArea { clicked => { root.attach(); } }
                        }
                    }
                }

                Rectangle { height: 1px; background: Palette.border; }

                // Preview body
                Rectangle {
                    vertical-stretch: 1;
                    background: Palette.bg;
                    clip: true;

                    if root.preview-kind == "none": Text {
                        text: "Select a file to preview it here.";
                        color: Palette.text-dim;
                        font-size: 13px;
                        width: parent.width;
                        height: parent.height;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    if root.preview-kind == "image": Image {
                        x: 12px;
                        y: 12px;
                        width: parent.width - 24px;
                        height: parent.height - 24px;
                        source: root.preview-image;
                        image-fit: contain;
                    }

                    if root.preview-kind == "binary": Text {
                        text: "Binary file — no text preview.";
                        color: Palette.text-dim;
                        font-size: 13px;
                        width: parent.width;
                        height: parent.height;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    // ScrollView (not Flickable): drag-able scrollbar for long
                    // text previews — linuxkms has no scroll-wheel on the kiosk.
                    if root.preview-kind == "text": ScrollView {
                        x: 12px;
                        y: 12px;
                        width: parent.width - 24px;
                        height: parent.height - 24px;
                        horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
                        viewport-width: self.visible-width;
                        viewport-height: txt.preferred-height;
                        txt := Text {
                            width: parent.width;
                            text: root.preview-text;
                            color: Palette.text;
                            font-size: 12px;
                            wrap: word-wrap;
                        }
                    }
                }
            }
        }
    }

    // ── Entry action menu overlay ───────────────────────────────────────────
    if root.menu-open: Rectangle {
        background: #000000bb;
        TouchArea { clicked => { root.menu-open = false; } }   // backdrop dismiss

        Rectangle {
            width: 240px;
            height: menu-col.preferred-height + 28px;
            background: Palette.surface;
            border-radius: Palette.radius-lg;
            border-width: 1px;
            border-color: Palette.border-hi;
            drop-shadow-blur: 32px;
            drop-shadow-color: #000000aa;

            menu-col := VerticalLayout {
                padding: 14px;
                spacing: 8px;
                Text {
                    text: root.menu-name;
                    color: Palette.text-bright;
                    font-size: 12px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    overflow: elide;
                }
                ExpBtn {
                    label: "Rename";
                    clicked => { root.open-rename(root.menu-path, root.menu-name); }
                }
                ExpBtn {
                    label: "Cut";
                    clicked => {
                        root.clip-path = root.menu-path; root.clip-name = root.menu-name; root.clip-mode = "cut";
                        root.menu-open = false;
                    }
                }
                ExpBtn {
                    label: "Copy";
                    clicked => {
                        root.clip-path = root.menu-path; root.clip-name = root.menu-name; root.clip-mode = "copy";
                        root.menu-open = false;
                    }
                }
                ExpBtn {
                    label: "Delete";
                    danger: true;
                    clicked => {
                        root.del-path = root.menu-path; root.del-name = root.menu-name;
                        root.menu-open = false;
                        root.del-open = true;
                    }
                }
                ExpBtn {
                    label: "Cancel";
                    clicked => { root.menu-open = false; }
                }
            }
        }
    }

    // ── Name prompt overlay (new folder / rename) ───────────────────────────
    if root.name-open: Rectangle {
        background: #000000bb;
        TouchArea { clicked => { root.name-open = false; } }   // backdrop dismiss

        Rectangle {
            width: 300px;
            height: name-col.preferred-height + 28px;
            background: Palette.surface;
            border-radius: Palette.radius-lg;
            border-width: 1px;
            border-color: Palette.border-hi;
            drop-shadow-blur: 32px;
            drop-shadow-color: #000000aa;

            name-col := VerticalLayout {
                padding: 16px;
                spacing: 14px;
                Text {
                    text: root.name-title;
                    color: Palette.text-bright;
                    font-size: 14px;
                    font-weight: 700;
                    horizontal-alignment: center;
                }
                Rectangle {
                    height: 30px;
                    border-radius: Palette.radius;
                    background: Palette.bg;
                    border-width: 1px;
                    border-color: nf.has-focus ? Palette.primary : Palette.border;
                    clip: true;
                    nf := TextInput {
                        x: 9px;
                        width: parent.width - 18px;
                        height: parent.height;
                        vertical-alignment: center;
                        single-line: true;
                        font-size: 12px;
                        color: Palette.text;
                        selection-background-color: Palette.primary-dim;
                        text <=> root.name-value;
                        init => { self.focus(); }
                        accepted => { root.commit-name(); }
                    }
                    if root.name-value == "": Text {
                        x: 9px;
                        text: root.name-mode == "mkdir" ? "folder name…" : "new name…";
                        color: Palette.text-dim;
                        font-size: 12px;
                        vertical-alignment: center;
                    }
                }
                HorizontalLayout {
                    spacing: 10px;
                    ExpBtn {
                        label: "CANCEL";
                        horizontal-stretch: 1;
                        clicked => { root.name-open = false; root.name-value = ""; }
                    }
                    ExpBtn {
                        label: root.name-mode == "mkdir" ? "CREATE" : "RENAME";
                        strong: root.name-value != "";
                        horizontal-stretch: 1;
                        clicked => { root.commit-name(); }
                    }
                }
            }
        }
    }

    // ── Delete confirm overlay ──────────────────────────────────────────────
    if root.del-open: Rectangle {
        background: #000000bb;
        TouchArea { clicked => { root.del-open = false; } }    // backdrop dismiss

        Rectangle {
            width: 300px;
            height: del-col.preferred-height + 28px;
            background: Palette.surface;
            border-radius: Palette.radius-lg;
            border-width: 1px;
            border-color: Palette.border-hi;
            drop-shadow-blur: 32px;
            drop-shadow-color: #000000aa;

            del-col := VerticalLayout {
                padding: 18px;
                spacing: 14px;
                Text {
                    text: "Delete \"" + root.del-name + "\"?";
                    color: Palette.text-bright;
                    font-size: 14px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    overflow: elide;
                }
                Text {
                    text: "This permanently removes it from the workspace. A folder is deleted with everything inside it.";
                    color: Palette.text-dim;
                    font-size: 11px;
                    wrap: word-wrap;
                    horizontal-alignment: center;
                }
                HorizontalLayout {
                    spacing: 10px;
                    ExpBtn {
                        label: "CANCEL";
                        horizontal-stretch: 1;
                        clicked => { root.del-open = false; }
                    }
                    ExpBtn {
                        label: "DELETE";
                        danger: true;
                        horizontal-stretch: 1;
                        clicked => {
                            root.del-open = false;
                            root.delete-entry(root.del-path);
                        }
                    }
                }
            }
        }
    }

    // ── "Use this drive" picker overlay ─────────────────────────────────────
    if root.drive-open: Rectangle {
        background: #000000bb;
        TouchArea { clicked => { if (!root.drive-busy) { root.drive-open = false; } } }  // backdrop dismiss

        Rectangle {
            width: 380px;
            height: dr-col.preferred-height + 28px;
            background: Palette.surface;
            border-radius: Palette.radius-lg;
            border-width: 1px;
            border-color: Palette.border-hi;
            drop-shadow-blur: 32px;
            drop-shadow-color: #000000aa;

            dr-col := VerticalLayout {
                padding: 18px;
                spacing: 12px;

                Text {
                    text: "Use a USB drive";
                    color: Palette.text-bright;
                    font-size: 15px;
                    font-weight: 700;
                    horizontal-alignment: center;
                }
                Text {
                    text: "Pick a plugged-in USB stick to set it up as an APEX drive — your existing files are kept.";
                    color: Palette.text-dim;
                    font-size: 11px;
                    wrap: word-wrap;
                    horizontal-alignment: center;
                }

                // Candidate list — or an empty/rescan state.
                if root.drive-candidates.length == 0: VerticalLayout {
                    spacing: 8px;
                    Text {
                        text: "No set-up-able USB drive found. Plug a FAT/exFAT stick, then Rescan.";
                        color: Palette.text-dim;
                        font-size: 11px;
                        wrap: word-wrap;
                        horizontal-alignment: center;
                    }
                    ExpBtn { label: "Rescan"; clicked => { root.drive-scan(); } }
                }
                if root.drive-candidates.length > 0: VerticalLayout {
                    spacing: 4px;
                    for c in root.drive-candidates: Rectangle {
                        height: 40px;
                        border-radius: Palette.radius;
                        background: c.dev == root.drive-selected-dev ? Palette.surface-hi : Palette.bg;
                        border-width: 1px;
                        border-color: c.dev == root.drive-selected-dev ? Palette.primary : Palette.border;
                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 8px;
                            Rectangle {                          // radio dot
                                width: 14px;
                                height: 14px;
                                border-radius: 7px;
                                border-width: 1.5px;
                                border-color: c.dev == root.drive-selected-dev ? Palette.primary : Palette.border-hi;
                                y: (parent.height - self.height) / 2;
                                Rectangle {
                                    width: 7px;
                                    height: 7px;
                                    border-radius: 4px;
                                    background: Palette.primary;
                                    visible: c.dev == root.drive-selected-dev;
                                }
                            }
                            Text {
                                text: c.display;
                                color: Palette.text;
                                font-size: 11px;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                                overflow: elide;
                            }
                        }
                        TouchArea { clicked => { root.drive-selected-dev = c.dev; } }
                    }
                }

                // Name field → becomes the APEX-<name> drive label.
                Rectangle {
                    height: 30px;
                    border-radius: Palette.radius;
                    background: Palette.bg;
                    border-width: 1px;
                    border-color: dn.has-focus ? Palette.primary : Palette.border;
                    clip: true;
                    dn := TextInput {
                        x: 9px;
                        width: parent.width - 18px;
                        height: parent.height;
                        vertical-alignment: center;
                        single-line: true;
                        enabled: !root.drive-busy;
                        font-size: 12px;
                        color: Palette.text;
                        selection-background-color: Palette.primary-dim;
                        text <=> root.drive-name;
                    }
                    if root.drive-name == "": Text {
                        x: 9px;
                        text: "name this drive (e.g. work) → APEX-work";
                        color: Palette.text-dim;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                }

                if root.drive-result != "" && root.drive-result != "ok": Text {
                    text: root.drive-result;
                    color: #ef6666;
                    font-size: 10px;
                    wrap: word-wrap;
                    horizontal-alignment: center;
                }

                HorizontalLayout {
                    spacing: 10px;
                    ExpBtn {
                        label: "CANCEL";
                        horizontal-stretch: 1;
                        clicked => { if (!root.drive-busy) { root.drive-open = false; } }
                    }
                    ExpBtn {
                        label: root.drive-busy ? "Setting up…" : "SET UP DRIVE";
                        strong: root.drive-selected-dev != "" && root.drive-name != "" && !root.drive-busy;
                        horizontal-stretch: 1;
                        clicked => {
                            if (root.drive-selected-dev != "" && root.drive-name != "" && !root.drive-busy) {
                                root.drive-prep(root.drive-selected-dev, root.drive-name);
                            }
                        }
                    }
                }
            }
        }
    }
}
