// ApexOS-RS — Palette global
//
// Single source of truth for all visual tokens. Every component reads
// from here; nothing hardcodes a color or radius directly.
//
// Hot-switch from Rust:
//   ui.global::<Palette>().set_theme(Theme::Jarvis);
//
// 6 themes:
//   ApexOS  — neon-green terminal  (production default)
//   Aurum   — alchemical gold      (cerebro-api dashboard)
//   MacOS   — soft light rounded   ("mom" persona)
//   Gnome   — Adwaita dark         ("ubuntu-dad" persona)
//   Windows — Win7 Aero glass      ("windows-dad" persona)
//   Jarvis  — HUD cyan holographic ("tech-kid" persona)

export enum Theme { ApexOS, Aurum, MacOS, Gnome, Windows, Jarvis }

export global Palette {
    // ── Active theme ──────────────────────────────────────────────────
    in-out property <Theme> theme: Theme.ApexOS;

    // ── Background layers ─────────────────────────────────────────────
    // bg: deepest background (window fill)
    out property <color> bg:
        theme == Theme.ApexOS  ? #0d0f18 :
        theme == Theme.Aurum   ? #0d0800 :
        theme == Theme.MacOS   ? #f5f5f7 :
        theme == Theme.Gnome   ? #1e1e1e :
        theme == Theme.Windows ? #0b1a2e :
        /*Jarvis*/               #000a14;

    // surface: card / panel fill
    out property <color> surface:
        theme == Theme.ApexOS  ? #131620 :
        theme == Theme.Aurum   ? #1a0f00 :
        theme == Theme.MacOS   ? #ffffff :
        theme == Theme.Gnome   ? #2a2a2a :
        theme == Theme.Windows ? #1a2a3e :
        /*Jarvis*/               #00162a;

    // surface-hi: elevated surface (hover states, modal backgrounds)
    out property <color> surface-hi:
        theme == Theme.ApexOS  ? #1a1e2e :
        theme == Theme.Aurum   ? #251600 :
        theme == Theme.MacOS   ? #f0f0f5 :
        theme == Theme.Gnome   ? #363636 :
        theme == Theme.Windows ? #243650 :
        /*Jarvis*/               #001e38;

    // ── Borders ───────────────────────────────────────────────────────
    out property <color> border:
        theme == Theme.ApexOS  ? #ffffff12 :
        theme == Theme.Aurum   ? #d4a01722 :
        theme == Theme.MacOS   ? #00000014 :
        theme == Theme.Gnome   ? #ffffff14 :
        theme == Theme.Windows ? #ffffff1a :
        /*Jarvis*/               #00d4ff33;

    out property <color> border-hi:
        theme == Theme.ApexOS  ? #ffffff24 :
        theme == Theme.Aurum   ? #d4a01744 :
        theme == Theme.MacOS   ? #00000026 :
        theme == Theme.Gnome   ? #ffffff26 :
        theme == Theme.Windows ? #64b4ff4c :
        /*Jarvis*/               #00d4ff66;

    // ── Accent colours ────────────────────────────────────────────────
    // primary: dominant accent (send button, active indicators, glows)
    out property <color> primary:
        theme == Theme.ApexOS  ? #39ff14 :
        theme == Theme.Aurum   ? #d4a017 :
        theme == Theme.MacOS   ? #007aff :
        theme == Theme.Gnome   ? #3584e4 :
        theme == Theme.Windows ? #0078d4 :
        /*Jarvis*/               #00d4ff;

    // primary-dim: low-opacity primary for backgrounds / fills
    out property <color> primary-dim:
        theme == Theme.ApexOS  ? #39ff1422 :
        theme == Theme.Aurum   ? #d4a01733 :
        theme == Theme.MacOS   ? #007aff22 :
        theme == Theme.Gnome   ? #3584e422 :
        theme == Theme.Windows ? #0078d422 :
        /*Jarvis*/               #00d4ff22;

    // secondary: supporting accent (links, badges, secondary buttons)
    out property <color> secondary:
        theme == Theme.ApexOS  ? #6c8aff :   // indigo (from desktop CSS --accent2)
        theme == Theme.Aurum   ? #c8961c :   // amber
        theme == Theme.MacOS   ? #5856d6 :   // Apple purple
        theme == Theme.Gnome   ? #813d9c :   // GNOME purple
        theme == Theme.Windows ? #00b4d8 :   // taskbar cyan
        /*Jarvis*/               #0080ff;    // electric blue

    // error / destructive
    out property <color> error:
        theme == Theme.ApexOS  ? #ff6b6b :
        theme == Theme.Aurum   ? #ff4444 :
        theme == Theme.MacOS   ? #ff3b30 :
        theme == Theme.Gnome   ? #e01b24 :
        theme == Theme.Windows ? #d13438 :
        /*Jarvis*/               #ff0044;

    // warning / caution (tool calls, policy indicators)
    out property <color> warning:
        theme == Theme.ApexOS  ? #ffb347 :   // amber — from kiosk --tool-fg
        theme == Theme.Aurum   ? #ffd700 :
        theme == Theme.MacOS   ? #ff9f0a :
        theme == Theme.Gnome   ? #e5a50a :
        theme == Theme.Windows ? #ffd700 :
        /*Jarvis*/               #ffa500;

    // ── Text ──────────────────────────────────────────────────────────
    out property <color> text:
        theme == Theme.ApexOS  ? #c8cdd8 :
        theme == Theme.Aurum   ? #f5d98b :   // warm cream
        theme == Theme.MacOS   ? #1c1c1e :
        theme == Theme.Gnome   ? #ffffff :
        theme == Theme.Windows ? #ffffff :
        /*Jarvis*/               #a0e8f0;

    out property <color> text-dim:
        theme == Theme.ApexOS  ? #606680 :
        theme == Theme.Aurum   ? #8a6a30 :
        theme == Theme.MacOS   ? #8e8e93 :
        theme == Theme.Gnome   ? #ffffff8c :
        theme == Theme.Windows ? #ffffff99 :
        /*Jarvis*/               #1a8090;

    out property <color> text-bright:
        theme == Theme.ApexOS  ? #eef0f5 :
        theme == Theme.Aurum   ? #ffeeba :
        theme == Theme.MacOS   ? #000000 :
        theme == Theme.Gnome   ? #ffffff :
        theme == Theme.Windows ? #ffffff :
        /*Jarvis*/               #00d4ff;

    // ── Chat bubbles ─────────────────────────────────────────────────
    // user message: right-aligned bubble fill
    out property <color> user-bubble:
        theme == Theme.ApexOS  ? #1a1e2e :   // surface-hi (understated)
        theme == Theme.Aurum   ? #251600 :
        theme == Theme.MacOS   ? #007aff :   // classic iMessage blue
        theme == Theme.Gnome   ? #3584e4 :
        theme == Theme.Windows ? #0078d4 :
        /*Jarvis*/               #001e38;

    // user text on the bubble
    out property <color> user-bubble-text:
        theme == Theme.ApexOS  ? #eef0f5 :
        theme == Theme.Aurum   ? #ffeeba :
        theme == Theme.MacOS   ? #ffffff :
        theme == Theme.Gnome   ? #ffffff :
        theme == Theme.Windows ? #ffffff :
        /*Jarvis*/               #00d4ff;

    // agent message: left-aligned bubble fill
    out property <color> agent-bubble:
        theme == Theme.ApexOS  ? #131620 :
        theme == Theme.Aurum   ? #1a0f00 :
        theme == Theme.MacOS   ? #e9e9eb :
        theme == Theme.Gnome   ? #363636 :
        theme == Theme.Windows ? #243650 :
        /*Jarvis*/               #000a14;

    out property <color> agent-bubble-text:
        theme == Theme.ApexOS  ? #c8cdd8 :
        theme == Theme.Aurum   ? #f5d98b :
        theme == Theme.MacOS   ? #1c1c1e :
        theme == Theme.Gnome   ? #ffffff :
        theme == Theme.Windows ? #ffffff :
        /*Jarvis*/               #a0e8f0;

    // ── Tool call cards ───────────────────────────────────────────────
    out property <color> tool-bg:
        theme == Theme.ApexOS  ? #1a1000 :   // from kiosk CSS --tool-bg
        theme == Theme.Aurum   ? #0f0800 :
        theme == Theme.MacOS   ? #f2f2f7 :
        theme == Theme.Gnome   ? #242424 :
        theme == Theme.Windows ? #1a2a3e :
        /*Jarvis*/               #001020;

    out property <color> tool-fg:
        theme == Theme.ApexOS  ? #ffb347 :   // amber — kiosk --tool-fg
        theme == Theme.Aurum   ? #d4a017 :
        theme == Theme.MacOS   ? #1c1c1e :
        theme == Theme.Gnome   ? #ffffff :
        theme == Theme.Windows ? #64b4ff :
        /*Jarvis*/               #00d4ff;

    out property <color> tool-border:
        theme == Theme.ApexOS  ? #4a3000 :   // kiosk --tool-border
        theme == Theme.Aurum   ? #d4a01744 :
        theme == Theme.MacOS   ? #00000014 :
        theme == Theme.Gnome   ? #ffffff14 :
        theme == Theme.Windows ? #64b4ff33 :
        /*Jarvis*/               #00d4ff44;

    // ── Shape ─────────────────────────────────────────────────────────
    out property <length> radius:
        theme == Theme.ApexOS  ? 3px  :
        theme == Theme.Aurum   ? 4px  :
        theme == Theme.MacOS   ? 12px :
        theme == Theme.Gnome   ? 6px  :
        theme == Theme.Windows ? 3px  :
        /*Jarvis*/               1px;

    out property <length> radius-sm:
        theme == Theme.ApexOS  ? 2px :
        theme == Theme.Aurum   ? 2px :
        theme == Theme.MacOS   ? 8px :
        theme == Theme.Gnome   ? 4px :
        theme == Theme.Windows ? 2px :
        /*Jarvis*/               0px;

    out property <length> radius-lg:
        theme == Theme.ApexOS  ? 4px  :
        theme == Theme.Aurum   ? 6px  :
        theme == Theme.MacOS   ? 18px :
        theme == Theme.Gnome   ? 10px :
        theme == Theme.Windows ? 4px  :
        /*Jarvis*/               2px;

    // ── Jarvis-specific animation tokens ─────────────────────────────
    // Used by animated glow borders and scanline overlay in Jarvis theme.
    // Ignored by all other themes.
    out property <duration> glow-speed: theme == Theme.Jarvis ? 2000ms : 0ms;
    out property <float>    glow-max-opacity: theme == Theme.Jarvis ? 0.8 : 0.0;
    out property <bool>     scanlines: theme == Theme.Jarvis;

    // ── Theme display name (for settings UI picker) ───────────────────
    out property <string> theme-name:
        theme == Theme.ApexOS  ? "ApexOS" :
        theme == Theme.Aurum   ? "Aurum" :
        theme == Theme.MacOS   ? "macOS" :
        theme == Theme.Gnome   ? "GNOME" :
        theme == Theme.Windows ? "Windows" :
        /*Jarvis*/               "Jarvis";
}
