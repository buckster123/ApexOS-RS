import { Palette, Theme } from "palette.slint";
import { Personas } from "personas.slint";
import { Win98 } from "components/win98.slint";
import { MessageItem, SysStats, SessionItem, ModelItem, ToastItem, ToastKind, ShellMode, AppKind, WindowDesc, AgentBridge, CouncilAgent, Persona, PersonaDef, ChromeKind, Clock, EventLogItem, MeshNode, AudioFileItem, SonusFileItem, NoteItem, SketchStroke, ImageItem, ExplorerEntry, FaceGl, UserDef, AgentDef } from "types.slint";
import { PersonaPicker, FirstBootWizard } from "components/persona_picker.slint";
import { IdentityWizard } from "components/identity_wizard.slint";
import { ImagePicker } from "components/image_picker.slint";
import { ChatView } from "components/chat_view.slint";
import { InputBar } from "components/input_bar.slint";
import { Dashboard } from "components/dashboard.slint";
import { SensorView } from "components/sensor_view.slint";
import { SessionView } from "components/session_view.slint";
import { SettingsView } from "components/settings_view.slint";
import { ToastHost, Notifications } from "components/toast.slint";
import { Taskbar } from "components/taskbar.slint";
import { StartMenu, Win98StartMenu } from "components/start_menu.slint";
import { NotifCenter } from "components/notif_center.slint";
import { AppWindowFrame } from "components/app_window_frame.slint";

export { Palette, Theme, Personas, MessageItem, SysStats, SessionItem, ModelItem, ToastItem, ToastKind, ShellMode, AppKind, WindowDesc, Notifications, AgentBridge, CouncilAgent, Persona, PersonaDef, ChromeKind, Clock, EventLogItem, MeshNode, AudioFileItem, SonusFileItem, NoteItem, SketchStroke, FaceGl }

export component AppWindow inherits Window {
    title: "ApexOS";
    background: Palette.bg;
    preferred-width: 1280px;
    preferred-height: 720px;

    // ── Properties bound from Rust ──────────────────────────────────────
    in-out property <[MessageItem]>  messages;
    in-out property <string>         status: "Connecting…";
    in-out property <bool>           agent-busy: false;
    in-out property <SysStats>       sys-stats;
    in-out property <[SessionItem]>  sessions;
    in-out property <int>            current-session-id: 0;
    in-out property <int>            current-view: 0;   // 0=chat 1=system 2=sensor 3=sessions 4=settings (Focus mode)
    in-out property <ShellMode>      shell-mode: ShellMode.desktop;  // Desktop (windowed) ⇄ Focus (full-screen app)
    in-out property <bool>           recording: false;
    in-out property <bool>           tts-enabled: false;
    in-out property <string>         soul-text: "";
    in-out property <string>         settings-policy: "suggest";
    in-out property <string>         settings-model: "";
    in-out property <bool>           settings-api-key-set: false;
    in-out property <[ModelItem]>    available-models;
    in-out property <bool>           power-modal-open: false;
    // Terminal app (G3d) — Rust owns the /terminal-ws PTY; output streams here.
    in-out property <string>         terminal-text: "";
    in-out property <int>            terminal-scroll-tick: 0;
    // Council app (G3d) — Rust owns the state, driven by Council* WS events.
    in-out property <[CouncilAgent]> council-agents;
    in-out property <string>         council-topic: "";
    in-out property <int>            council-round: 0;
    in-out property <float>          council-convergence: 0.0;
    in-out property <bool>           council-active: false;
    in-out property <string>         council-status: "idle";
    in-out property <string>         council-synthesis: "";
    in-out property <int>            council-scroll-tick: 0;
    // Sub-agents currently running (SubAgentStarted − child turn_complete) → taskbar badge.
    in-out property <int>            subagent-count: 0;

    // ── Tier-A parity apps (Event Log / Mesh / Inference) ───────────────
    in-out property <[EventLogItem]> event-log;
    in-out property <[MeshNode]>     mesh-nodes;
    in-out property <string>         mesh-pair-code;
    in-out property <int>            mesh-pair-remaining;
    in-out property <string>         inference-backend: "—";
    in-out property <string>         inference-base-url: "";
    in-out property <[ModelItem]>    inference-models;
    in-out property <[AudioFileItem]> audio-files;
    in-out property <string>         audio-selected-path: "";
    in-out property <string>         audio-selected-name: "";
    in-out property <[float]>        audio-waveform;
    in-out property <string>         audio-stats: "";
    in-out property <string>         audio-duration: "";
    in-out property <bool>           audio-busy: false;
    in-out property <[SonusFileItem]> sonus-files;
    in-out property <string>         sonus-now-playing: "";
    in-out property <[NoteItem]>     notes;
    in-out property <string>         notes-current-name: "";
    in-out property <string>         notes-current-text: "";
    in-out property <string>         face-state: "idle";
    in-out property <int>            face-tick: 0;
    in-out property <string>         face-gaze: "center";       // center|left|right|up|down (agent display_face)
    in-out property <float>          face-intensity: 0.7;       // 0..1 expression strength
    in-out property <[SketchStroke]> sketch-strokes;
    in-out property <int>            sketch-color: 0;
    in-out property <int>            sketch-width: 0;
    in-out property <int>            sketch-tool: 0;
    in-out property <string>         web-cerebro-url: "";
    in-out property <string>         web-sensorhead-url: "";
    in-out property <string>         web-custom-url: "";
    in-out property <string>         calc-display: "0";

    // ── Explorer (📁 Files) ─────────────────────────────────────────────
    in-out property <[ExplorerEntry]> explorer-entries;
    in-out property <string>         explorer-current-path: "";
    in-out property <string>         explorer-selected-path: "";
    in-out property <string>         explorer-selected-name: "";
    in-out property <string>         explorer-selected-info: "";
    in-out property <string>         explorer-preview-kind: "none";  // none|image|text|binary
    in-out property <image>          explorer-preview-image;
    in-out property <string>         explorer-preview-text: "";
    in-out property <bool>           explorer-can-attach: false;

    // ── Window manager (G2) ─────────────────────────────────────────────
    // Rust owns the set; model order = z-order (last on top). focused-id /
    // focused-kind are Rust-maintained for chrome highlight + dock state.
    in-out property <[WindowDesc]>   windows;
    in-out property <int>            focused-id: 0;
    in-out property <int>            focused-kind: -1;   // AppKind ordinal of focused window
    // Taskbar (G3) — bottom-bar state. start-menu / notif-center popups land in
    // G3b / G3c; the toggles already drive the Start/tray button highlight.
    in-out property <bool>           start-menu-open: false;
    in-out property <bool>           notif-center-open: false;
    in-out property <int>            notif-unread: 0;

    // ── Persona system (G4/G5) ──────────────────────────────────────────
    // The catalogue + switch callback live on the Personas global (Rust wires
    // Personas.pick → apply_persona, which sets current + theme + shell-mode +
    // persists). Only the transient UI state stays here. The first-boot wizard
    // shows when no persona is persisted yet.
    in-out property <bool>           persona-picker-open: false;
    in-out property <bool>           first-boot: false;

    // ── Identity boot wizard (agent-identity.md slice 3d) ──────────────────
    // Rust opens this when there's a real choice (multiple profiles/agents or a
    // PIN); the trivial single-owner+APEX case skips it entirely. Rust drives
    // step/models/pin and binds the chosen agent (WS hello) on completion.
    in-out property <bool>           identity-wizard-open: false;
    in property <[UserDef]>          identity-users;
    in property <[AgentDef]>         identity-agents;     // pre-filtered to the picked user
    in-out property <int>            identity-step: 0;    // 0 user · 1 pin · 2 agent
    in-out property <string>         identity-selected-name;
    in-out property <int>            identity-pin-filled: 0;
    in-out property <bool>           identity-pin-error: false;
    in-out property <string>         identity-pin-message: "";   // wrong-PIN / lockout / network
    callback identity-pick-user(string);
    callback identity-key(string);
    callback identity-pick-agent(string);
    callback identity-back();

    // ── Image attach (🖼) — workspace picker → staged image → user_prompt ──
    in property <[ImageItem]>        workspace-images;
    in-out property <bool>           image-picker-open: false;
    in-out property <string>         staged-image-path: "";   // workspace-relative; read by Rust on send
    in-out property <string>         staged-image-name: "";   // shown as the composer chip

    // ── Callbacks sent to Rust ──────────────────────────────────────────
    callback send-message(string);
    callback refresh-workspace-images();
    callback stop-turn();
    callback refresh-sessions();
    callback restore-session(int);
    callback toggle-recording();
    callback toggle-tts();
    callback refresh-settings();
    callback save-soul(string);
    callback set-policy(string);
    callback set-model(string);
    callback power-action(string);
    callback terminal-send(string);          // a submitted terminal command line
    // Tier-A parity apps
    callback refresh-events();
    callback refresh-mesh();
    callback add-peer(string, string, string);   // node_id, ws_url, token
    callback remove-peer(string);            // node_id
    callback start-pairing();
    callback redeem-pairing(string, string);     // peer ws_url, code
    callback refresh-inference();
    callback refresh-audio();
    callback select-audio(string, string);   // path, name
    callback process-audio(string, string);  // path, op
    callback refresh-sonus();
    callback play-sonus(string);              // name
    callback stop-sonus();
    callback refresh-notes();
    callback open-note(string);               // name
    callback save-note(string, string);       // name, text
    callback create-note(string);             // new note name
    // Explorer (📁 Files)
    callback refresh-explorer();
    callback explorer-navigate(string);       // dir rel path
    callback explorer-up();
    callback explorer-select(string, string, string);  // path, abs, ext
    callback explorer-attach();
    callback sketch-down(float, float);
    callback sketch-move(float, float);
    callback sketch-up();
    callback sketch-clear();
    callback sketch-send(float, float);       // canvas px w, h
    callback sketch-set-color(int);
    callback sketch-set-width(int);
    callback sketch-set-tool(int);
    callback open-url(string);
    callback calc-key(string);
    // Window management (Desktop mode)
    callback launch-app(int);                 // AppKind ordinal: 0=chat 1=system 2=sensor 3=sessions 4=settings
    callback focus-window(int);               // id
    callback close-window(int);               // id
    callback minimize-window(int);            // id
    callback maximize-window(int);            // id
    callback task-activate(int);              // id — taskbar click: restore/focus/minimize-toggle
    callback move-window(int, length, length);     // id, x, y
    callback resize-window(int, length, length);   // id, w, h

    // Switch app + run any per-app refresh (Focus-mode tab strip).
    function open-view(v: int) {
        root.current-view = v;
        if (v == 3) { root.refresh-sessions(); }
        if (v == 4) { root.refresh-settings(); }
    }

    // ── Jarvis pulse animation ──────────────────────────────────────────
    property <float> jarvis-pulse: 0.0;
    property <bool>  jarvis-phase: false;

    animate jarvis-pulse { duration: 1000ms; easing: ease-in-out; }

    Timer {
        interval: 1000ms;
        running: Palette.scanlines;
        triggered => {
            root.jarvis-phase = !root.jarvis-phase;
            root.jarvis-pulse = root.jarvis-phase ? Palette.glow-max-opacity : 0.0;
        }
    }

    // ── Root layout ────────────────────────────────────────────────────
    VerticalLayout {

        // ── Title bar (42 px) ─────────────────────────────────────────
        Rectangle {
            height: 42px;
            background: Palette.surface;

            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: Palette.border-hi;
            }

            if Palette.scanlines: Rectangle {
                y: 0px;
                height: 2px;
                background: rgba(0, 212, 255, root.jarvis-pulse * 0.8 + 0.2);
            }

            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;
                spacing: 8px;

                Rectangle {
                    width: 8px;
                    height: 8px;
                    border-radius: 4px;
                    y: (parent.height - self.height) / 2;
                    background: root.agent-busy ? Palette.primary : Palette.text-dim;
                    animate background { duration: 300ms; }
                }

                Text {
                    text: "ApexOS";
                    color: Palette.text-bright;
                    font-size: 13px;
                    font-weight: 700;
                    vertical-alignment: center;
                }

                Rectangle { horizontal-stretch: 1; }

                // Shell-mode toggle (⊞ = desktop / ▢ = focus)
                Rectangle {
                    width: 28px;
                    height: 28px;
                    border-radius: Palette.radius;
                    background: shell-area.has-hover ? Palette.surface-hi : transparent;
                    y: (parent.height - self.height) / 2;
                    animate background { duration: 150ms; }

                    shell-area := TouchArea {
                        clicked => {
                            root.shell-mode = root.shell-mode == ShellMode.desktop
                                ? ShellMode.focus : ShellMode.desktop;
                        }
                    }

                    Text {
                        text: root.shell-mode == ShellMode.desktop ? "⊞" : "▢";
                        color: root.shell-mode == ShellMode.desktop ? Palette.primary : Palette.text-dim;
                        font-size: 14px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        animate color { duration: 150ms; }
                    }
                }

                // Power button (⏻ = open power modal)
                Rectangle {
                    width: 28px;
                    height: 28px;
                    border-radius: Palette.radius;
                    background: root.power-modal-open ? rgba(239, 68, 68, 0.15) : transparent;
                    y: (parent.height - self.height) / 2;
                    animate background { duration: 150ms; }

                    TouchArea { clicked => { root.power-modal-open = !root.power-modal-open; } }

                    Text {
                        text: "⏻";
                        color: root.power-modal-open ? #ef4444 : Palette.text-dim;
                        font-size: 13px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        animate color { duration: 150ms; }
                    }
                }

                // TTS toggle (♪ = speak agent responses aloud)
                Rectangle {
                    width: 28px;
                    height: 28px;
                    border-radius: Palette.radius;
                    background: root.tts-enabled ? Palette.primary-dim : transparent;
                    y: (parent.height - self.height) / 2;
                    animate background { duration: 150ms; }

                    TouchArea { clicked => { root.toggle-tts(); } }

                    Text {
                        text: "♪";
                        color: root.tts-enabled ? Palette.primary : Palette.text-dim;
                        font-size: 13px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        animate color { duration: 150ms; }
                    }
                }

                // Persona chip — click to open the live persona picker.
                Rectangle {
                    height: 24px;
                    width: persona-row.preferred-width + 20px;
                    y: (parent.height - self.height) / 2;
                    border-radius: Palette.radius;
                    background: root.persona-picker-open ? Palette.primary-dim
                              : persona-area.has-hover ? Palette.surface-hi : transparent;
                    border-width: 1px;
                    border-color: root.persona-picker-open ? Palette.primary : Palette.border;
                    animate background, border-color { duration: 150ms; }

                    persona-area := TouchArea {
                        clicked => { root.persona-picker-open = !root.persona-picker-open; }
                    }

                    persona-row := HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 10px;
                        spacing: 6px;
                        alignment: center;
                        Text {
                            text: Personas.glyph;
                            color: Palette.primary;
                            font-size: 11px;
                            vertical-alignment: center;
                        }
                        Text {
                            text: Personas.name;
                            color: Palette.secondary;
                            font-size: 10px;
                            letter-spacing: 1.5px;
                            vertical-alignment: center;
                        }
                    }
                }

                Text {
                    text: root.status;
                    color: root.agent-busy ? Palette.warning : Palette.text-dim;
                    font-size: 11px;
                    vertical-alignment: center;
                    animate color { duration: 300ms; }
                }
            }
        }

        // ── Body ────────────────────────────────────────────────────────
        Rectangle {
            vertical-stretch: 1;

            // ════ FOCUS MODE: legacy full-screen tabbed surface ══════════
            if root.shell-mode == ShellMode.focus: Rectangle {
                x: 0; y: 0; width: parent.width; height: parent.height;

                VerticalLayout {
                    // Tab strip (36 px)
                    Rectangle {
                        height: 36px;
                        background: Palette.surface;
                        Rectangle {
                            y: parent.height - 1px;
                            height: 1px;
                            background: Palette.border;
                        }
                        HorizontalLayout {
                            padding-left: 8px;
                            spacing: 0px;

                            Rectangle {
                                width: 80px;
                                if root.current-view == 0: Rectangle {
                                    y: parent.height - 2px; height: 2px;
                                    background: Palette.primary; border-radius: 1px;
                                }
                                TouchArea { clicked => { root.open-view(0); } }
                                Text {
                                    text: "CHAT";
                                    y: (parent.height - self.height) / 2;
                                    color: root.current-view == 0 ? Palette.primary : Palette.text-dim;
                                    font-size: 10px;
                                    font-weight: root.current-view == 0 ? 700 : 400;
                                    horizontal-alignment: center;
                                    letter-spacing: 1.2px;
                                    animate color { duration: 200ms; }
                                }
                            }
                            Rectangle {
                                width: 80px;
                                if root.current-view == 1: Rectangle {
                                    y: parent.height - 2px; height: 2px;
                                    background: Palette.primary; border-radius: 1px;
                                }
                                TouchArea { clicked => { root.open-view(1); } }
                                Text {
                                    text: "SYSTEM";
                                    y: (parent.height - self.height) / 2;
                                    color: root.current-view == 1 ? Palette.primary : Palette.text-dim;
                                    font-size: 10px;
                                    font-weight: root.current-view == 1 ? 700 : 400;
                                    horizontal-alignment: center;
                                    letter-spacing: 1.2px;
                                    animate color { duration: 200ms; }
                                }
                            }
                            Rectangle {
                                width: 80px;
                                if root.current-view == 2: Rectangle {
                                    y: parent.height - 2px; height: 2px;
                                    background: Palette.primary; border-radius: 1px;
                                }
                                TouchArea { clicked => { root.open-view(2); } }
                                Text {
                                    text: "SENSOR";
                                    y: (parent.height - self.height) / 2;
                                    color: root.current-view == 2 ? Palette.primary : Palette.text-dim;
                                    font-size: 10px;
                                    font-weight: root.current-view == 2 ? 700 : 400;
                                    horizontal-alignment: center;
                                    letter-spacing: 1.2px;
                                    animate color { duration: 200ms; }
                                }
                            }
                            Rectangle {
                                width: 80px;
                                if root.current-view == 3: Rectangle {
                                    y: parent.height - 2px; height: 2px;
                                    background: Palette.primary; border-radius: 1px;
                                }
                                TouchArea { clicked => { root.open-view(3); } }
                                Text {
                                    text: "SESSIONS";
                                    y: (parent.height - self.height) / 2;
                                    color: root.current-view == 3 ? Palette.primary : Palette.text-dim;
                                    font-size: 10px;
                                    font-weight: root.current-view == 3 ? 700 : 400;
                                    horizontal-alignment: center;
                                    letter-spacing: 1.2px;
                                    animate color { duration: 200ms; }
                                }
                            }
                            Rectangle {
                                width: 88px;
                                if root.current-view == 4: Rectangle {
                                    y: parent.height - 2px; height: 2px;
                                    background: Palette.primary; border-radius: 1px;
                                }
                                TouchArea { clicked => { root.open-view(4); } }
                                Text {
                                    text: "SETTINGS";
                                    y: (parent.height - self.height) / 2;
                                    color: root.current-view == 4 ? Palette.primary : Palette.text-dim;
                                    font-size: 10px;
                                    font-weight: root.current-view == 4 ? 700 : 400;
                                    horizontal-alignment: center;
                                    letter-spacing: 1.2px;
                                    animate color { duration: 200ms; }
                                }
                            }
                            Rectangle { horizontal-stretch: 1; }
                        }
                    }

                    // Chat (always) + conditional router views
                    ChatView {
                        vertical-stretch: root.current-view == 0 ? 1 : 0;
                        max-height: root.current-view == 0 ? 999999px : 0px;
                        messages: root.messages;
                        glow-alpha: root.jarvis-pulse;
                        scroll-tick: AgentBridge.chat-scroll-tick;
                    }

                    if root.current-view == 1: Dashboard {
                        vertical-stretch: 1;
                        stats: root.sys-stats;
                        glow-alpha: root.jarvis-pulse;
                    }
                    if root.current-view == 2: SensorView {
                        vertical-stretch: 1;
                        stats: root.sys-stats;
                    }
                    if root.current-view == 3: SessionView {
                        vertical-stretch: 1;
                        sessions: root.sessions;
                        active-session-id: root.current-session-id;
                        restore-session(id) => { root.restore-session(id); }
                        refresh => { root.refresh-sessions(); }
                    }
                    if root.current-view == 4: SettingsView {
                        vertical-stretch: 1;
                        soul-text <=> root.soul-text;
                        policy-mode: root.settings-policy;
                        current-model: root.settings-model;
                        api-key-set: root.settings-api-key-set;
                        models: root.available-models;
                        save-soul(text) => { root.save-soul(text); }
                        set-policy(mode) => { root.set-policy(mode); }
                        set-model(id) => { root.set-model(id); }
                        refresh => { root.refresh-settings(); }
                    }

                    if Palette.scanlines && root.current-view == 0: Rectangle {
                        height: 1px;
                        background: rgba(0, 212, 255, root.jarvis-pulse * 0.5 + 0.1);
                    }

                    if root.current-view == 0: Rectangle {
                        background: Palette.bg;
                        HorizontalLayout {
                            padding: 12px;
                            InputBar {
                                busy: root.agent-busy;
                                glow-alpha: root.jarvis-pulse;
                                recording: root.recording;
                                staged-name: root.staged-image-name;
                                toggle-recording => { root.toggle-recording(); }
                                send(text) => { root.send-message(text); }
                                stop => { root.stop-turn(); }
                                attach => { root.refresh-workspace-images(); root.image-picker-open = true; }
                                clear-attachment => { root.staged-image-path = ""; root.staged-image-name = ""; }
                            }
                        }
                    }
                }
            }

            // ════ DESKTOP MODE: wallpaper + window layer + dock ══════════
            if root.shell-mode == ShellMode.desktop: Rectangle {
                x: 0; y: 0; width: parent.width; height: parent.height;

                // Win-98 chrome flushes the taskbar to the bottom edge (no float,
                // no rounding) and shortens it; everyone else gets the floating bar.
                property <bool> win98: Personas.chrome == ChromeKind.win;
                property <length> tb-h: win98 ? 34px : 56px;
                property <length> tb-margin: win98 ? 0px : 16px;
                property <length> tb-zone: tb-h + tb-margin * 2;

                // Wallpaper — per-persona themed gradient (cheap; tier-safe).
                // Style id from Personas.wallpaper drives angle + wash strength:
                // 0 grid · 1 soft · 2 adwaita-flat · 3 bliss · 4 starfield · 5 alchemy.
                // Win-98 overrides with the iconic flat teal desktop.
                Rectangle {
                    x: 0; y: 0; width: parent.width; height: parent.height;
                    background: win98 ? Win98.desktop : Palette.bg;
                    if !win98: Rectangle {
                        x: 0; y: 0; width: parent.width; height: parent.height;
                        background: @linear-gradient(
                            Personas.wallpaper == 1 ? 120deg :
                            Personas.wallpaper == 2 ? 180deg :
                            Personas.wallpaper == 3 ? 160deg :
                            Personas.wallpaper == 4 ? 135deg : 150deg,
                            Palette.surface 0%, Palette.bg 55%, Palette.surface-hi 100%);
                        opacity:
                            Personas.wallpaper == 1 ? 0.70 :
                            Personas.wallpaper == 2 ? 0.35 :
                            Personas.wallpaper == 4 ? 0.50 : 0.55;
                    }
                    if !win98: Rectangle {
                        x: 0; y: 0; width: parent.width; height: parent.height;
                        background: @radial-gradient(circle, Palette.primary-dim 0%, transparent 65%);
                        opacity:
                            Personas.wallpaper == 2 ? 0.04 :
                            Personas.wallpaper == 1 ? 0.06 :
                            Personas.wallpaper == 4 ? 0.16 :
                            Personas.wallpaper == 5 ? 0.16 : 0.10;
                    }
                    // Secondary accent wash (bliss / starfield / alchemy get a
                    // second tinted glow from the bottom for extra depth).
                    if !win98 && (Personas.wallpaper == 3 || Personas.wallpaper == 4 || Personas.wallpaper == 5): Rectangle {
                        x: 0; y: 0; width: parent.width; height: parent.height;
                        background: @radial-gradient(circle, Palette.secondary 0%, transparent 55%);
                        opacity: 0.07;
                    }
                }

                // Window layer — one frame per (non-minimised) window; paint
                // order = model order, so the last window renders on top.
                for w in root.windows: Rectangle {
                    if !w.minimized: AppWindowFrame {
                        win-id: w.id;
                        kind: w.kind;
                        title: w.title;
                        base-x: w.x;
                        base-y: w.y;
                        base-w: w.w;
                        base-h: w.h;
                        maximized: w.maximized;
                        focused: w.id == root.focused-id;
                        area-w: parent.width;
                        area-h: parent.height - tb-zone;

                        messages: root.messages;
                        agent-busy: root.agent-busy;
                        glow-alpha: root.jarvis-pulse;
                        recording: root.recording;
                        scroll-tick: AgentBridge.chat-scroll-tick;
                        stats: root.sys-stats;
                        sessions: root.sessions;
                        active-session-id: root.current-session-id;
                        soul-text: root.soul-text;
                        policy-mode: root.settings-policy;
                        current-model: root.settings-model;
                        api-key-set: root.settings-api-key-set;
                        models: root.available-models;
                        terminal-text: root.terminal-text;
                        terminal-scroll-tick: root.terminal-scroll-tick;
                        council-agents: root.council-agents;
                        council-topic: root.council-topic;
                        council-round: root.council-round;
                        council-convergence: root.council-convergence;
                        council-active: root.council-active;
                        council-status: root.council-status;
                        council-synthesis: root.council-synthesis;
                        council-scroll-tick: root.council-scroll-tick;
                        event-log: root.event-log;
                        mesh-nodes: root.mesh-nodes;
                        mesh-pair-code <=> root.mesh-pair-code;
                        mesh-pair-remaining <=> root.mesh-pair-remaining;
                        inference-backend: root.inference-backend;
                        inference-base-url: root.inference-base-url;
                        inference-models: root.inference-models;
                        audio-files: root.audio-files;
                        audio-selected-path: root.audio-selected-path;
                        audio-selected-name: root.audio-selected-name;
                        audio-waveform: root.audio-waveform;
                        audio-stats: root.audio-stats;
                        audio-duration: root.audio-duration;
                        audio-busy: root.audio-busy;
                        sonus-files: root.sonus-files;
                        sonus-now-playing: root.sonus-now-playing;
                        notes: root.notes;
                        notes-current-name <=> root.notes-current-name;
                        notes-current-text <=> root.notes-current-text;
                        face-state: root.face-state;
                        face-tick: root.face-tick;
                        face-gaze: root.face-gaze;
                        face-intensity: root.face-intensity;
                        sketch-strokes: root.sketch-strokes;
                        sketch-color: root.sketch-color;
                        sketch-width: root.sketch-width;
                        sketch-tool: root.sketch-tool;
                        web-cerebro-url: root.web-cerebro-url;
                        web-sensorhead-url: root.web-sensorhead-url;
                        web-custom-url <=> root.web-custom-url;
                        calc-display: root.calc-display;
                        staged-image-name: root.staged-image-name;
                        explorer-entries: root.explorer-entries;
                        explorer-current-path: root.explorer-current-path;
                        explorer-selected-path: root.explorer-selected-path;
                        explorer-selected-name: root.explorer-selected-name;
                        explorer-selected-info: root.explorer-selected-info;
                        explorer-preview-kind: root.explorer-preview-kind;
                        explorer-preview-image: root.explorer-preview-image;
                        explorer-preview-text: root.explorer-preview-text;
                        explorer-can-attach: root.explorer-can-attach;

                        send-message(t) => { root.send-message(t); }
                        attach-image => { root.refresh-workspace-images(); root.image-picker-open = true; }
                        clear-attachment => { root.staged-image-path = ""; root.staged-image-name = ""; }
                        refresh-explorer => { root.refresh-explorer(); }
                        explorer-navigate(p) => { root.explorer-navigate(p); }
                        explorer-up => { root.explorer-up(); }
                        explorer-select(p, a, e) => { root.explorer-select(p, a, e); }
                        explorer-attach => { root.explorer-attach(); }
                        stop-turn => { root.stop-turn(); }
                        terminal-send(line) => { root.terminal-send(line); }
                        toggle-recording => { root.toggle-recording(); }
                        restore-session(id) => { root.restore-session(id); }
                        refresh-sessions => { root.refresh-sessions(); }
                        save-soul(t) => { root.save-soul(t); }
                        set-policy(m) => { root.set-policy(m); }
                        set-model(id) => { root.set-model(id); }
                        refresh-settings => { root.refresh-settings(); }
                        refresh-events => { root.refresh-events(); }
                        refresh-mesh => { root.refresh-mesh(); }
                        add-peer(id, url, token) => { root.add-peer(id, url, token); }
                        remove-peer(id) => { root.remove-peer(id); }
                        start-pairing => { root.start-pairing(); }
                        redeem-pairing(url, code) => { root.redeem-pairing(url, code); }
                        refresh-inference => { root.refresh-inference(); }
                        refresh-audio => { root.refresh-audio(); }
                        select-audio(p, n) => { root.select-audio(p, n); }
                        process-audio(p, op) => { root.process-audio(p, op); }
                        refresh-sonus => { root.refresh-sonus(); }
                        play-sonus(name) => { root.play-sonus(name); }
                        stop-sonus => { root.stop-sonus(); }
                        refresh-notes => { root.refresh-notes(); }
                        open-note(name) => { root.open-note(name); }
                        save-note(name, text) => { root.save-note(name, text); }
                        create-note(name) => { root.create-note(name); }
                        sketch-down(x, y) => { root.sketch-down(x, y); }
                        sketch-move(x, y) => { root.sketch-move(x, y); }
                        sketch-up => { root.sketch-up(); }
                        sketch-clear => { root.sketch-clear(); }
                        sketch-send(w, h) => { root.sketch-send(w, h); }
                        sketch-set-color(i) => { root.sketch-set-color(i); }
                        sketch-set-width(i) => { root.sketch-set-width(i); }
                        sketch-set-tool(i) => { root.sketch-set-tool(i); }
                        open-url(u) => { root.open-url(u); }
                        calc-key(k) => { root.calc-key(k); }

                        req-focus => { root.focus-window(w.id); }
                        req-close => { root.close-window(w.id); }
                        req-minimize => { root.minimize-window(w.id); }
                        req-maximize => { root.maximize-window(w.id); }
                        commit-move(nx, ny) => { root.move-window(w.id, nx, ny); }
                        commit-resize(nw, nh) => { root.resize-window(w.id, nw, nh); }
                    }
                }

                // Taskbar (G3) — full-width bottom bar: Start · running windows · tray.
                Taskbar {
                    windows: root.windows;
                    focused-id: root.focused-id;
                    start-open: root.start-menu-open;
                    tray-open: root.notif-center-open;
                    notif-count: root.notif-unread;
                    council-count: root.subagent-count;
                    council-active: root.council-active;
                    x: tb-margin;
                    width: parent.width - tb-margin * 2;
                    y: parent.height - self.height - tb-margin;
                    start-clicked => { root.start-menu-open = !root.start-menu-open; }
                    task-activate(id) => { root.task-activate(id); }
                    council-clicked => { root.launch-app(6); }
                    tray-clicked => {
                        root.notif-center-open = !root.notif-center-open;
                        if root.notif-center-open { root.notif-unread = 0; }
                    }
                }

                // Start menu (G3b) — backdrop dismiss + catalog panel, anchored
                // above the Start button. Layered after the taskbar so it paints
                // on top.
                if root.start-menu-open: TouchArea {
                    x: 0; y: 0; width: parent.width; height: parent.height;
                    clicked => { root.start-menu-open = false; }
                }
                if root.start-menu-open && !win98: StartMenu {
                    x: tb-margin;
                    y: parent.height - tb-h - tb-margin - self.height - 8px;
                    launch(ord) => {
                        root.launch-app(ord);
                        root.start-menu-open = false;
                    }
                }
                if root.start-menu-open && win98: Win98StartMenu {
                    x: tb-margin;
                    y: parent.height - tb-h - self.height;
                    launch(ord) => {
                        root.launch-app(ord);
                        root.start-menu-open = false;
                    }
                }

                // Notification center (G3c) — backdrop dismiss + history panel,
                // anchored above the tray (bottom-right).
                if root.notif-center-open: TouchArea {
                    x: 0; y: 0; width: parent.width; height: parent.height;
                    clicked => { root.notif-center-open = false; }
                }
                if root.notif-center-open: NotifCenter {
                    x: parent.width - self.width - tb-margin;
                    y: parent.height - tb-h - tb-margin - self.height - (win98 ? 0px : 8px);
                }
            }
        }
    }

    // ── Jarvis: full-window ambient overlay ────────────────────────────
    if Palette.scanlines: Rectangle {
        x: 0px; y: 0px;
        width: parent.width; height: parent.height;
        background: @linear-gradient(160deg,
            rgba(0, 212, 255, 0.025) 0%,
            transparent 45%,
            rgba(0, 128, 255, 0.018) 100%);
    }

    // ── Power modal (full-screen dim + centered card) ──────────────────
    if root.power-modal-open: Rectangle {
        x: 0px; y: 0px;
        width: parent.width; height: parent.height;
        background: rgba(0, 0, 0, 0.75);

        Rectangle {
            width: 268px;
            height: 160px;
            x: (parent.width  - self.width)  / 2;
            y: (parent.height - self.height) / 2;
            background: Palette.surface;
            border-radius: Palette.radius;
            border-width: 1px;
            border-color: Palette.border-hi;

            VerticalLayout {
                padding: 24px;
                spacing: 20px;
                alignment: center;

                Text {
                    text: "POWER";
                    color: Palette.text-dim;
                    font-size: 9px;
                    letter-spacing: 2px;
                    horizontal-alignment: center;
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: center;

                    Rectangle {
                        width: 72px; height: 34px;
                        border-radius: Palette.radius;
                        background: reboot-area.has-hover
                            ? rgba(234, 179, 8, 0.2) : Palette.surface-hi;
                        border-width: 1px;
                        border-color: rgba(234, 179, 8, 0.6);
                        animate background { duration: 150ms; }

                        reboot-area := TouchArea {
                            clicked => {
                                root.power-modal-open = false;
                                root.power-action("reboot");
                            }
                        }
                        Text {
                            text: "REBOOT";
                            color: #eab308;
                            font-size: 9px;
                            font-weight: 700;
                            letter-spacing: 1px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        width: 80px; height: 34px;
                        border-radius: Palette.radius;
                        background: shutdown-area.has-hover
                            ? rgba(239, 68, 68, 0.2) : Palette.surface-hi;
                        border-width: 1px;
                        border-color: rgba(239, 68, 68, 0.6);
                        animate background { duration: 150ms; }

                        shutdown-area := TouchArea {
                            clicked => {
                                root.power-modal-open = false;
                                root.power-action("shutdown");
                            }
                        }
                        Text {
                            text: "SHUTDOWN";
                            color: #ef4444;
                            font-size: 9px;
                            font-weight: 700;
                            letter-spacing: 1px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        width: 60px; height: 34px;
                        border-radius: Palette.radius;
                        background: cancel-area.has-hover
                            ? Palette.surface-hi : Palette.surface;
                        border-width: 1px;
                        border-color: Palette.border;
                        animate background { duration: 150ms; }

                        cancel-area := TouchArea {
                            clicked => { root.power-modal-open = false; }
                        }
                        Text {
                            text: "CANCEL";
                            color: Palette.text-dim;
                            font-size: 9px;
                            letter-spacing: 1px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }

    // ── Persona picker (G4) — live theme/chrome/wallpaper/mode switch ──
    // Available in both shell modes; anchored under the title-bar chip.
    // Backdrop-dismiss mirrors the G3 start-menu pattern.
    if root.persona-picker-open: TouchArea {
        x: 0px; y: 0px; width: parent.width; height: parent.height;
        clicked => { root.persona-picker-open = false; }
    }
    if root.persona-picker-open: PersonaPicker {
        defs: Personas.defs;
        current-id: Personas.current-id;
        x: parent.width - self.width - 16px;
        y: 48px;
        pick(id) => {
            Personas.pick(id);
            root.persona-picker-open = false;
        }
    }

    // ── Image attach picker (🖼) — workspace images; sets the staged image ──
    if root.image-picker-open: TouchArea {
        x: 0px; y: 0px; width: parent.width; height: parent.height;
        clicked => { root.image-picker-open = false; }
    }
    if root.image-picker-open: ImagePicker {
        images: root.workspace-images;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        refresh => { root.refresh-workspace-images(); }
        pick(path, name) => {
            root.staged-image-path = path;
            root.staged-image-name = name;
            root.image-picker-open = false;
        }
    }

    // ── Feedback: toast stack (top-right, above everything) ────────────
    ToastHost {
        x: root.width - self.width - 16px;
        y: 52px;
        width: 340px;
    }

    // ── First-boot persona wizard (G4) — shown once on first run ───────
    // Top-most modal: picking a tile applies the persona + dismisses.
    if root.first-boot: FirstBootWizard {
        x: 0px; y: 0px; width: parent.width; height: parent.height;
        defs: Personas.defs;
        current-id: Personas.current-id;
        pick(id) => {
            Personas.pick(id);
            root.first-boot = false;
        }
    }

    // ── Identity boot wizard (3d) — top-most modal, before persona/desktop ──
    if root.identity-wizard-open: IdentityWizard {
        x: 0px; y: 0px; width: parent.width; height: parent.height;
        users: root.identity-users;
        agents: root.identity-agents;
        step: root.identity-step;
        selected-name: root.identity-selected-name;
        pin-filled: root.identity-pin-filled;
        pin-error: root.identity-pin-error;
        pin-message: root.identity-pin-message;
        pick-user(id)  => { root.identity-pick-user(id); }
        key(k)         => { root.identity-key(k); }
        pick-agent(id) => { root.identity-pick-agent(id); }
        back()         => { root.identity-back(); }
    }
}
