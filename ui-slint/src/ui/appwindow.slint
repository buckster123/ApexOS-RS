import { Palette, Theme } from "palette.slint";
import { MessageItem, SysStats, SessionItem, ModelItem } from "types.slint";
import { ChatView } from "components/chat_view.slint";
import { InputBar } from "components/input_bar.slint";
import { Dashboard } from "components/dashboard.slint";
import { SensorView } from "components/sensor_view.slint";
import { SessionView } from "components/session_view.slint";
import { SettingsView } from "components/settings_view.slint";

export { Palette, Theme, MessageItem, SysStats, SessionItem, ModelItem }

export component AppWindow inherits Window {
    title: "ApexOS";
    background: Palette.bg;
    preferred-width: 1280px;
    preferred-height: 720px;

    // ── Properties bound from Rust ──────────────────────────────────────
    in-out property <[MessageItem]>  messages;
    in-out property <string>         status: "Connecting…";
    in-out property <bool>           agent-busy: false;
    in-out property <SysStats>       sys-stats;
    in-out property <[SessionItem]>  sessions;
    in-out property <int>            current-session-id: 0;
    in-out property <int>            current-view: 0;   // 0=chat  1=system  2=sensor  3=sessions
    in-out property <bool>           recording: false;
    in-out property <bool>           tts-enabled: false;
    in-out property <string>         soul-text: "";
    in-out property <string>         settings-policy: "suggest";
    in-out property <string>         settings-model: "";
    in-out property <bool>           settings-api-key-set: false;
    in-out property <[ModelItem]>    available-models;
    in-out property <bool>           power-modal-open: false;

    // ── Callbacks sent to Rust ──────────────────────────────────────────
    callback send-message(string);
    callback refresh-sessions();
    callback restore-session(int);
    callback toggle-recording();
    callback toggle-tts();
    callback refresh-settings();
    callback save-soul(string);
    callback set-policy(string);
    callback set-model(string);
    callback power-action(string);
    // chat always instantiated — aliases always valid
    callback scroll-to-bottom <=> chat.scroll-to-bottom;
    callback approve-tool <=> chat.approve-tool;
    callback reject-tool  <=> chat.reject-tool;

    // ── Jarvis pulse animation ──────────────────────────────────────────
    property <float> jarvis-pulse: 0.0;
    property <bool>  jarvis-phase: false;

    animate jarvis-pulse { duration: 1000ms; easing: ease-in-out; }

    Timer {
        interval: 1000ms;
        running: Palette.scanlines;
        triggered => {
            root.jarvis-phase = !root.jarvis-phase;
            root.jarvis-pulse = root.jarvis-phase ? Palette.glow-max-opacity : 0.0;
        }
    }

    // ── Root layout ────────────────────────────────────────────────────
    VerticalLayout {

        // ── Title bar (42 px) ─────────────────────────────────────────
        Rectangle {
            height: 42px;
            background: Palette.surface;

            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: Palette.border-hi;
            }

            if Palette.scanlines: Rectangle {
                y: 0px;
                height: 2px;
                background: rgba(0, 212, 255, root.jarvis-pulse * 0.8 + 0.2);
            }

            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;
                spacing: 8px;

                Rectangle {
                    width: 8px;
                    height: 8px;
                    border-radius: 4px;
                    y: (parent.height - self.height) / 2;
                    background: root.agent-busy ? Palette.primary : Palette.text-dim;
                    animate background { duration: 300ms; }
                }

                Text {
                    text: "ApexOS";
                    color: Palette.text-bright;
                    font-size: 13px;
                    font-weight: 700;
                    vertical-alignment: center;
                }

                Rectangle { horizontal-stretch: 1; }

                // Power button (⏻ = open power modal)
                Rectangle {
                    width: 28px;
                    height: 28px;
                    border-radius: Palette.radius;
                    background: root.power-modal-open ? rgba(239, 68, 68, 0.15) : transparent;
                    y: (parent.height - self.height) / 2;
                    animate background { duration: 150ms; }

                    TouchArea { clicked => { root.power-modal-open = !root.power-modal-open; } }

                    Text {
                        text: "⏻";
                        color: root.power-modal-open ? #ef4444 : Palette.text-dim;
                        font-size: 13px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        animate color { duration: 150ms; }
                    }
                }

                // TTS toggle (♪ = speak agent responses aloud)
                Rectangle {
                    width: 28px;
                    height: 28px;
                    border-radius: Palette.radius;
                    background: root.tts-enabled ? Palette.primary-dim : transparent;
                    y: (parent.height - self.height) / 2;
                    animate background { duration: 150ms; }

                    TouchArea { clicked => { root.toggle-tts(); } }

                    Text {
                        text: "♪";
                        color: root.tts-enabled ? Palette.primary : Palette.text-dim;
                        font-size: 13px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        animate color { duration: 150ms; }
                    }
                }

                Text {
                    text: Palette.theme-name;
                    color: Palette.secondary;
                    font-size: 10px;
                    vertical-alignment: center;
                    letter-spacing: 1.5px;
                }

                Text {
                    text: root.status;
                    color: root.agent-busy ? Palette.warning : Palette.text-dim;
                    font-size: 11px;
                    vertical-alignment: center;
                    animate color { duration: 300ms; }
                }
            }
        }

        // ── Tab strip (36 px) ─────────────────────────────────────────
        Rectangle {
            height: 36px;
            background: Palette.surface;

            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: Palette.border;
            }

            HorizontalLayout {
                padding-left: 8px;
                spacing: 0px;

                // CHAT tab
                Rectangle {
                    width: 80px;

                    if root.current-view == 0: Rectangle {
                        y: parent.height - 2px;
                        height: 2px;
                        background: Palette.primary;
                        border-radius: 1px;
                    }

                    TouchArea { clicked => { root.current-view = 0; } }

                    Text {
                        text: "CHAT";
                        y: (parent.height - self.height) / 2;
                        color: root.current-view == 0 ? Palette.primary : Palette.text-dim;
                        font-size: 10px;
                        font-weight: root.current-view == 0 ? 700 : 400;
                        horizontal-alignment: center;
                        letter-spacing: 1.2px;
                        animate color { duration: 200ms; }
                    }
                }

                // SYSTEM tab
                Rectangle {
                    width: 80px;

                    if root.current-view == 1: Rectangle {
                        y: parent.height - 2px;
                        height: 2px;
                        background: Palette.primary;
                        border-radius: 1px;
                    }

                    TouchArea { clicked => { root.current-view = 1; } }

                    Text {
                        text: "SYSTEM";
                        y: (parent.height - self.height) / 2;
                        color: root.current-view == 1 ? Palette.primary : Palette.text-dim;
                        font-size: 10px;
                        font-weight: root.current-view == 1 ? 700 : 400;
                        horizontal-alignment: center;
                        letter-spacing: 1.2px;
                        animate color { duration: 200ms; }
                    }
                }

                // SENSOR tab
                Rectangle {
                    width: 80px;

                    if root.current-view == 2: Rectangle {
                        y: parent.height - 2px;
                        height: 2px;
                        background: Palette.primary;
                        border-radius: 1px;
                    }

                    TouchArea { clicked => { root.current-view = 2; } }

                    Text {
                        text: "SENSOR";
                        y: (parent.height - self.height) / 2;
                        color: root.current-view == 2 ? Palette.primary : Palette.text-dim;
                        font-size: 10px;
                        font-weight: root.current-view == 2 ? 700 : 400;
                        horizontal-alignment: center;
                        letter-spacing: 1.2px;
                        animate color { duration: 200ms; }
                    }
                }

                // SESSIONS tab
                Rectangle {
                    width: 80px;

                    if root.current-view == 3: Rectangle {
                        y: parent.height - 2px;
                        height: 2px;
                        background: Palette.primary;
                        border-radius: 1px;
                    }

                    TouchArea {
                        clicked => {
                            root.current-view = 3;
                            root.refresh-sessions();  // auto-fetch on tab open
                        }
                    }

                    Text {
                        text: "SESSIONS";
                        y: (parent.height - self.height) / 2;
                        color: root.current-view == 3 ? Palette.primary : Palette.text-dim;
                        font-size: 10px;
                        font-weight: root.current-view == 3 ? 700 : 400;
                        horizontal-alignment: center;
                        letter-spacing: 1.2px;
                        animate color { duration: 200ms; }
                    }
                }

                // SETTINGS tab
                Rectangle {
                    width: 88px;

                    if root.current-view == 4: Rectangle {
                        y: parent.height - 2px;
                        height: 2px;
                        background: Palette.primary;
                        border-radius: 1px;
                    }

                    TouchArea {
                        clicked => {
                            root.current-view = 4;
                            root.refresh-settings();
                        }
                    }

                    Text {
                        text: "SETTINGS";
                        y: (parent.height - self.height) / 2;
                        color: root.current-view == 4 ? Palette.primary : Palette.text-dim;
                        font-size: 10px;
                        font-weight: root.current-view == 4 ? 700 : 400;
                        horizontal-alignment: center;
                        letter-spacing: 1.2px;
                        animate color { duration: 200ms; }
                    }
                }

                Rectangle { horizontal-stretch: 1; }
            }
        }

        // ── Chat view — always instantiated for callback aliases ───────
        // Collapses to 0 px when system view is active (max-height: 0).
        chat := ChatView {
            vertical-stretch: root.current-view == 0 ? 1 : 0;
            max-height: root.current-view == 0 ? 999999px : 0px;
            messages: root.messages;
            glow-alpha: root.jarvis-pulse;
        }

        // ── System dashboard — collapses when not active ─────────────
        dash := Dashboard {
            vertical-stretch: root.current-view == 1 ? 1 : 0;
            max-height: root.current-view == 1 ? 999999px : 0px;
            stats: root.sys-stats;
            glow-alpha: root.jarvis-pulse;
        }

        // ── Sensor view — collapses when not active ───────────────────
        sensor := SensorView {
            vertical-stretch: root.current-view == 2 ? 1 : 0;
            max-height: root.current-view == 2 ? 999999px : 0px;
            stats: root.sys-stats;
        }

        // ── Session picker — collapses when not active ────────────────
        sess := SessionView {
            vertical-stretch: root.current-view == 3 ? 1 : 0;
            max-height: root.current-view == 3 ? 999999px : 0px;
            sessions: root.sessions;
            active-session-id: root.current-session-id;
            restore-session(id) => { root.restore-session(id); }
            refresh => { root.refresh-sessions(); }
        }

        // ── Settings — collapses when not active ──────────────────────
        stg := SettingsView {
            vertical-stretch: root.current-view == 4 ? 1 : 0;
            max-height: root.current-view == 4 ? 999999px : 0px;
            soul-text <=> root.soul-text;
            policy-mode: root.settings-policy;
            current-model: root.settings-model;
            api-key-set: root.settings-api-key-set;
            models: root.available-models;
            save-soul(text) => { root.save-soul(text); }
            set-policy(mode) => { root.set-policy(mode); }
            set-model(id) => { root.set-model(id); }
            refresh => { root.refresh-settings(); }
        }

        // ── Glow divider (chat view + Jarvis only) ────────────────────
        if Palette.scanlines && root.current-view == 0: Rectangle {
            height: 1px;
            background: rgba(0, 212, 255, root.jarvis-pulse * 0.5 + 0.1);
        }

        // ── Input bar (chat view only) ────────────────────────────────
        if root.current-view == 0: Rectangle {
            background: Palette.bg;
            HorizontalLayout {
                padding: 12px;
                InputBar {
                    busy: root.agent-busy;
                    glow-alpha: root.jarvis-pulse;
                    recording: root.recording;
                    toggle-recording => { root.toggle-recording(); }
                    send(text) => {
                        root.send-message(text);
                    }
                }
            }
        }
    }

    // ── Jarvis: full-window ambient overlay ────────────────────────────
    if Palette.scanlines: Rectangle {
        x: 0px; y: 0px;
        width: parent.width; height: parent.height;
        background: @linear-gradient(160deg,
            rgba(0, 212, 255, 0.025) 0%,
            transparent 45%,
            rgba(0, 128, 255, 0.018) 100%);
    }

    // ── Power modal (full-screen dim + centered card) ──────────────────
    if root.power-modal-open: Rectangle {
        x: 0px; y: 0px;
        width: parent.width; height: parent.height;
        background: rgba(0, 0, 0, 0.75);

        // Modal card
        Rectangle {
            width: 268px;
            height: 160px;
            x: (parent.width  - self.width)  / 2;
            y: (parent.height - self.height) / 2;
            background: Palette.surface;
            border-radius: Palette.radius;
            border-width: 1px;
            border-color: Palette.border-hi;

            VerticalLayout {
                padding: 24px;
                spacing: 20px;
                alignment: center;

                Text {
                    text: "POWER";
                    color: Palette.text-dim;
                    font-size: 9px;
                    letter-spacing: 2px;
                    horizontal-alignment: center;
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: center;

                    // REBOOT
                    Rectangle {
                        width: 72px; height: 34px;
                        border-radius: Palette.radius;
                        background: reboot-area.has-hover
                            ? rgba(234, 179, 8, 0.2) : Palette.surface-hi;
                        border-width: 1px;
                        border-color: rgba(234, 179, 8, 0.6);
                        animate background { duration: 150ms; }

                        reboot-area := TouchArea {
                            clicked => {
                                root.power-modal-open = false;
                                root.power-action("reboot");
                            }
                        }

                        Text {
                            text: "REBOOT";
                            color: #eab308;
                            font-size: 9px;
                            font-weight: 700;
                            letter-spacing: 1px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    // SHUTDOWN
                    Rectangle {
                        width: 80px; height: 34px;
                        border-radius: Palette.radius;
                        background: shutdown-area.has-hover
                            ? rgba(239, 68, 68, 0.2) : Palette.surface-hi;
                        border-width: 1px;
                        border-color: rgba(239, 68, 68, 0.6);
                        animate background { duration: 150ms; }

                        shutdown-area := TouchArea {
                            clicked => {
                                root.power-modal-open = false;
                                root.power-action("shutdown");
                            }
                        }

                        Text {
                            text: "SHUTDOWN";
                            color: #ef4444;
                            font-size: 9px;
                            font-weight: 700;
                            letter-spacing: 1px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    // CANCEL
                    Rectangle {
                        width: 60px; height: 34px;
                        border-radius: Palette.radius;
                        background: cancel-area.has-hover
                            ? Palette.surface-hi : Palette.surface;
                        border-width: 1px;
                        border-color: Palette.border;
                        animate background { duration: 150ms; }

                        cancel-area := TouchArea {
                            clicked => { root.power-modal-open = false; }
                        }

                        Text {
                            text: "CANCEL";
                            color: Palette.text-dim;
                            font-size: 9px;
                            letter-spacing: 1px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}
