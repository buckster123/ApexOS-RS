// ApexOS-RS — root window (scaffold)
// Replace this with the full windowed desktop layout as each build step lands.

import { VerticalBox, HorizontalBox, Button, ScrollView } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "ApexOS";
    width: 1280px;
    height: 720px;
    background: #0f172a;

    // ── Properties bound from Rust ──────────────────────────────────
    in-out property <string> status: "Connecting…";
    in-out property <string> agent-text: "";
    in-out property <bool>   agent-busy: false;

    // ── Callbacks sent to Rust ──────────────────────────────────────
    callback send-message(string);

    VerticalBox {
        padding: 16px;
        spacing: 12px;

        // Status bar
        HorizontalBox {
            Text {
                text: "ApexOS-RS";
                color: #38bdf8;
                font-size: 14px;
                font-weight: 700;
            }
            Rectangle { horizontal-stretch: 1; }
            Text {
                text: root.status;
                color: root.agent-busy ? #f59e0b : #64748b;
                font-size: 12px;
            }
        }

        // Agent output
        ScrollView {
            vertical-stretch: 1;
            Text {
                text: root.agent-text == "" ? "Say 'apex' or type below…" : root.agent-text;
                color: root.agent-text == "" ? #475569 : #e2e8f0;
                font-size: 13px;
                wrap: word-wrap;
            }
        }

        // Input row (placeholder — wired in a later build step)
        HorizontalBox {
            spacing: 8px;
            Rectangle {
                height: 36px;
                border-radius: 6px;
                background: #1e293b;
                horizontal-stretch: 1;
                Text {
                    x: 12px;
                    y: 10px;
                    text: "Input — TODO";
                    color: #475569;
                    font-size: 12px;
                }
            }
            Button {
                text: "Send";
                clicked => { root.send-message("hello"); }
            }
        }
    }
}
